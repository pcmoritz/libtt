+// SPDX-FileCopyrightText: (c) 2026 Tenstorrent AI ULC
+// SPDX-License-Identifier: Apache-2.0
+
+#include "ttnn/operations/transformer/gated_delta_attn/gated_delta_decode.hpp"
+
+#include <algorithm>
+#include <variant>
+
+#include <tt-metalium/buffer.hpp>
+#include <tt-metalium/host_api.hpp>
+#include <tt-metalium/tensor_accessor_args.hpp>
+#include <tt-metalium/work_split.hpp>
+#include "ttnn/device.hpp"
+#include "ttnn/device_operation.hpp"
+#include "ttnn/operation.hpp"
+#include "ttnn/tensor/tensor_ops.hpp"
+
+using namespace tt::tt_metal;
+
+namespace ttnn::prim {
+namespace {
+
+struct DecodeParams {};
+
+struct DecodeInputs {
+    Tensor query;
+    Tensor key;
+    Tensor value;
+    Tensor beta;
+    Tensor decay;
+    Tensor state;
+    Tensor output;
+    Tensor state_indices;
+    Tensor has_initial_state;
+};
+
+struct DecodeSharedVariables {
+    KernelHandle reader_kernel_id;
+    KernelHandle writer_kernel_id;
+    uint32_t grid_y;
+    uint32_t num_workers;
+};
+
+struct DecodeProgramFactory {
+    using shared_variables_t = DecodeSharedVariables;
+    using cached_program_t = device_operation::CachedProgram<shared_variables_t>;
+    using operation_attributes_t = DecodeParams;
+    using tensor_args_t = DecodeInputs;
+    using tensor_return_value_t = Tensor;
+
+    static cached_program_t create(
+        const operation_attributes_t&, const tensor_args_t&, tensor_return_value_t&);
+    static void override_runtime_arguments(
+        cached_program_t&, const operation_attributes_t&, const tensor_args_t&, tensor_return_value_t&);
+};
+
+struct DecodeOperation {
+    using operation_attributes_t = DecodeParams;
+    using tensor_args_t = DecodeInputs;
+    using spec_return_value_t = TensorSpec;
+    using tensor_return_value_t = Tensor;
+    using program_factory_t = std::variant<DecodeProgramFactory>;
+
+    static void validate_on_program_cache_miss(const operation_attributes_t&, const tensor_args_t&);
+    static void validate_on_program_cache_hit(const operation_attributes_t& attrs, const tensor_args_t& inputs) {
+        validate_on_program_cache_miss(attrs, inputs);
+    }
+    static spec_return_value_t compute_output_specs(const operation_attributes_t&, const tensor_args_t&);
+    static tensor_return_value_t create_output_tensors(const operation_attributes_t&, const tensor_args_t&);
+    static ttsl::hash::hash_t compute_program_hash(const operation_attributes_t&, const tensor_args_t&);
+};
+
+void validate_tensor(const Tensor& tensor, DataType dtype, const char* name) {
+    TT_FATAL(tensor.storage_type() == StorageType::DEVICE, "{} must be on device", name);
+    TT_FATAL(tensor.buffer() != nullptr, "{} must be allocated", name);
+    TT_FATAL(tensor.layout() == Layout::TILE, "{} must use TILE layout", name);
+    TT_FATAL(tensor.dtype() == dtype, "{} has an unsupported dtype", name);
+}
+
+void check_shape(const Tensor& tensor, std::initializer_list<uint32_t> expected, const char* name) {
+    const auto& shape = tensor.logical_shape();
+    TT_FATAL(shape.rank() == expected.size(), "{} rank mismatch", name);
+    size_t dim = 0;
+    for (uint32_t value : expected) {
+        TT_FATAL(static_cast<uint32_t>(shape[dim]) == value, "{} dimension {} mismatch", name, dim);
+        ++dim;
+    }
+}
+
+void DecodeOperation::validate_on_program_cache_miss(const operation_attributes_t&, const tensor_args_t& in) {
+    const auto& query_shape = in.query.logical_shape();
+    TT_FATAL(query_shape.rank() == 4, "query must have rank 4");
+    const uint32_t batch_size = query_shape[0];
+    const uint32_t num_heads = query_shape[1];
+    validate_tensor(in.query, DataType::FLOAT32, "query");
+    validate_tensor(in.key, DataType::FLOAT32, "key");
+    validate_tensor(in.value, DataType::FLOAT32, "value");
+    validate_tensor(in.beta, DataType::FLOAT32, "beta");
+    validate_tensor(in.decay, DataType::FLOAT32, "decay");
+    validate_tensor(in.state, DataType::FLOAT32, "state");
+    validate_tensor(in.output, DataType::BFLOAT16, "output");
+    validate_tensor(in.state_indices, DataType::INT32, "state indices");
+    validate_tensor(in.has_initial_state, DataType::BFLOAT16, "initial-state mask");
+
+    constexpr uint32_t dim = 128;
+    check_shape(in.query, {batch_size, num_heads, 1, dim}, "query");
+    check_shape(in.key, {batch_size, num_heads, 1, dim}, "key");
+    check_shape(in.value, {batch_size, num_heads, 1, dim}, "value");
+    check_shape(in.beta, {batch_size, num_heads}, "beta");
+    check_shape(in.decay, {batch_size, num_heads}, "decay");
+    const auto& state_shape = in.state.logical_shape();
+    TT_FATAL(
+        state_shape.rank() == 4 && state_shape[0] >= 2 &&
+            state_shape[1] == num_heads && state_shape[2] == dim &&
+            state_shape[3] == dim,
+        "state shape mismatch");
+    check_shape(in.output, {batch_size, num_heads, 1, dim}, "output");
+    check_shape(in.state_indices, {batch_size}, "state indices");
+    check_shape(in.has_initial_state, {batch_size}, "initial-state mask");
+}
+
+DecodeOperation::spec_return_value_t DecodeOperation::compute_output_specs(
+    const operation_attributes_t&, const tensor_args_t& in) {
+    return in.output.tensor_spec();
+}
+
+DecodeOperation::tensor_return_value_t DecodeOperation::create_output_tensors(
+    const operation_attributes_t&, const tensor_args_t& in) {
+    return in.output;
+}
+
+ttsl::hash::hash_t DecodeOperation::compute_program_hash(
+    const operation_attributes_t&, const tensor_args_t& in) {
+    return operation::hash_operation<DecodeOperation>(
+        in.query, in.key, in.value, in.beta, in.decay, in.state, in.output,
+        in.state_indices, in.has_initial_state);
+}
+
+DecodeProgramFactory::cached_program_t DecodeProgramFactory::create(
+    const operation_attributes_t&, const tensor_args_t& in, tensor_return_value_t& output) {
+    constexpr uint32_t kt = 4;
+    constexpr uint32_t vt = 4;
+    constexpr uint32_t state_tiles = kt * vt;
+    const uint32_t batch_size = in.query.logical_shape()[0];
+    const uint32_t num_heads = in.query.logical_shape()[1];
+    Program program;
+
+    auto* device = in.query.device();
+    const CoreCoord grid = device->compute_with_storage_grid_size();
+    const uint32_t num_workers =
+        std::min(batch_size * num_heads,
+                 static_cast<uint32_t>(grid.x * grid.y));
+    CoreRangeSet cores = num_cores_to_corerangeset(num_workers, grid);
+
+    auto make_cb = [&](uint32_t index, uint32_t tiles,
+                       tt::DataFormat format = tt::DataFormat::Float32) {
+        const uint32_t page_size = tt::tile_size(format);
+        CircularBufferConfig config(tiles * page_size, {{index, format}});
+        config.set_page_size(index, page_size);
+        CreateCircularBuffer(program, cores, config);
+    };
+    make_cb(0, state_tiles);  // state
+    make_cb(1, kt);           // query
+    make_cb(2, kt);           // key
+    make_cb(3, vt);           // value
+    make_cb(4, 1);            // decay
+    make_cb(5, 1);            // beta
+    make_cb(6, state_tiles);  // decayed state
+    make_cb(7, vt);           // key * state
+    make_cb(8, vt);           // delta
+    make_cb(9, kt);           // transposed key
+    make_cb(10, vt);          // scaled delta
+    make_cb(11, state_tiles); // updated state
+    make_cb(12, vt, tt::DataFormat::Float16_b); // output
+    make_cb(15, 1, tt::DataFormat::Int32);      // state index (reader)
+    make_cb(17, 1, tt::DataFormat::Float16_b);  // has-initial-state flag
+    make_cb(29, 1, tt::DataFormat::Int32);      // state index (writer)
+
+    std::vector<uint32_t> reader_args = {
+        kt, vt, batch_size, num_heads, num_workers};
+    TensorAccessorArgs(in.query.buffer()).append_to(reader_args);
+    TensorAccessorArgs(in.key.buffer()).append_to(reader_args);
+    TensorAccessorArgs(in.value.buffer()).append_to(reader_args);
+    TensorAccessorArgs(in.beta.buffer()).append_to(reader_args);
+    TensorAccessorArgs(in.decay.buffer()).append_to(reader_args);
+    TensorAccessorArgs(in.state.buffer()).append_to(reader_args);
+    TensorAccessorArgs(in.state_indices.buffer()).append_to(reader_args);
+    TensorAccessorArgs(in.has_initial_state.buffer()).append_to(reader_args);
+
+    std::vector<uint32_t> writer_args = {
+        kt, vt, batch_size, num_heads, num_workers};
+    TensorAccessorArgs(output.buffer()).append_to(writer_args);
+    TensorAccessorArgs(in.state.buffer()).append_to(writer_args);
+    TensorAccessorArgs(in.state_indices.buffer()).append_to(writer_args);
+
+    const std::string kernel_dir =
+        "ttnn/cpp/ttnn/operations/transformer/gated_delta_attn/device/kernels/";
+    auto reader = CreateKernel(
+        program,
+        kernel_dir + "dataflow/reader_gated_delta_decode.cpp",
+        cores,
+        DataMovementConfig{
+            .processor = DataMovementProcessor::RISCV_1,
+            .noc = NOC::RISCV_1_default,
+            .compile_args = reader_args});
+    auto writer = CreateKernel(
+        program,
+        kernel_dir + "dataflow/writer_gated_delta_decode.cpp",
+        cores,
+        DataMovementConfig{
+            .processor = DataMovementProcessor::RISCV_0,
+            .noc = NOC::RISCV_0_default,
+            .compile_args = writer_args});
+    auto compute = CreateKernel(
+        program,
+        kernel_dir + "compute/gated_delta_decode.cpp",
+        cores,
+        ComputeConfig{
+            .math_fidelity = tt::tt_metal::MathFidelity::HiFi2,
+            .fp32_dest_acc_en = true,
+            .math_approx_mode = false,
+            .compile_args = {
+                kt, vt, batch_size, num_heads, num_workers}});
+
+    for (uint32_t worker = 0; worker < num_workers; ++worker) {
+        const CoreCoord core{worker / grid.y, worker % grid.y};
+        SetRuntimeArgs(
+            program,
+            reader,
+            core,
+            {worker,
+             in.query.buffer()->address(),
+             in.key.buffer()->address(),
+             in.value.buffer()->address(),
+             in.beta.buffer()->address(),
+             in.decay.buffer()->address(),
+             in.state.buffer()->address(),
+             in.state_indices.buffer()->address(),
+             in.has_initial_state.buffer()->address()});
+        SetRuntimeArgs(
+            program,
+            writer,
+            core,
+            {worker, output.buffer()->address(), in.state.buffer()->address(),
+             in.state_indices.buffer()->address()});
+        SetRuntimeArgs(program, compute, core, {worker});
+    }
+
+    return cached_program_t{
+        std::move(program),
+        {.reader_kernel_id = reader,
+         .writer_kernel_id = writer,
+         .grid_y = static_cast<uint32_t>(grid.y),
+         .num_workers = num_workers}};
+}
+
+void DecodeProgramFactory::override_runtime_arguments(
+    cached_program_t& cached,
+    const operation_attributes_t&,
+    const tensor_args_t& in,
+    tensor_return_value_t& output) {
+    for (uint32_t worker = 0; worker < cached.shared_variables.num_workers; ++worker) {
+        CoreCoord core{worker / cached.shared_variables.grid_y, worker % cached.shared_variables.grid_y};
+        auto& reader_args = GetRuntimeArgs(cached.program, cached.shared_variables.reader_kernel_id, core);
+        reader_args[1] = in.query.buffer()->address();
+        reader_args[2] = in.key.buffer()->address();
+        reader_args[3] = in.value.buffer()->address();
+        reader_args[4] = in.beta.buffer()->address();
+        reader_args[5] = in.decay.buffer()->address();
+        reader_args[6] = in.state.buffer()->address();
+        reader_args[7] = in.state_indices.buffer()->address();
+        reader_args[8] = in.has_initial_state.buffer()->address();
+        auto& writer_args = GetRuntimeArgs(cached.program, cached.shared_variables.writer_kernel_id, core);
+        writer_args[1] = output.buffer()->address();
+        writer_args[2] = in.state.buffer()->address();
+        writer_args[3] = in.state_indices.buffer()->address();
+    }
+}
+
+}  // namespace
+}  // namespace ttnn::prim
+
+namespace ttnn::transformer {
+
+Tensor gated_delta_decode(
+    const Tensor& query,
+    const Tensor& key,
+    const Tensor& value,
+    const Tensor& beta,
+    const Tensor& decay,
+    const Tensor& state,
+    const Tensor& output,
+    const Tensor& state_indices,
+    const Tensor& has_initial_state) {
+    using Op = prim::DecodeOperation;
+    return device_operation::launch<Op>(
+        {},
+        {.query = query,
+         .key = key,
+         .value = value,
+         .beta = beta,
+         .decay = decay,
+         .state = state,
+         .output = output,
+         .state_indices = state_indices,
+         .has_initial_state = has_initial_state});
+}
+
+}  // namespace ttnn::transformer

+// SPDX-FileCopyrightText: (c) 2026 Tenstorrent AI ULC
+// SPDX-License-Identifier: Apache-2.0
+
+#include <stdint.h>
+
+#include "api/dataflow/circular_buffer.h"
+#include "api/dataflow/dataflow_api.h"
+#include "api/dataflow/noc.h"
+
+namespace {
+
+FORCE_INLINE void make_scalar_tile(uint32_t address, uint32_t row, uint32_t column) {
+    volatile tt_l1_ptr uint32_t* tile = reinterpret_cast<volatile tt_l1_ptr uint32_t*>(address);
+    const uint32_t face = (row / 16) * 2 + column / 16;
+    const uint32_t element = tile[face * 256 + (row % 16) * 16 + column % 16];
+    for (uint32_t i = 0; i < 1024; ++i) {
+        tile[i] = 0;
+    }
+    tile[0] = element;
+    tile[256] = element;
+    tile[512] = element;
+    tile[768] = element;
+}
+
+FORCE_INLINE void transpose_row_tile(uint32_t source_address, uint32_t destination_address) {
+    volatile tt_l1_ptr uint32_t* source = reinterpret_cast<volatile tt_l1_ptr uint32_t*>(source_address);
+    volatile tt_l1_ptr uint32_t* destination =
+        reinterpret_cast<volatile tt_l1_ptr uint32_t*>(destination_address);
+    for (uint32_t i = 0; i < 1024; ++i) {
+        destination[i] = 0;
+    }
+    for (uint32_t i = 0; i < 16; ++i) {
+        destination[i * 16] = source[i];
+        destination[512 + i * 16] = source[256 + i];
+    }
+}
+
+FORCE_INLINE uint32_t tile_element_offset(uint32_t row, uint32_t column) {
+    const uint32_t face = (row / 16) * 2 + column / 16;
+    return face * 256 + (row % 16) * 16 + column % 16;
+}
+
+FORCE_INLINE uint32_t read_int32_tile(uint32_t address, uint32_t row, uint32_t column) {
+    const volatile tt_l1_ptr uint32_t* tile =
+        reinterpret_cast<const volatile tt_l1_ptr uint32_t*>(address);
+    return tile[tile_element_offset(row, column)];
+}
+
+FORCE_INLINE bool read_bfloat16_tile(uint32_t address, uint32_t row, uint32_t column) {
+    const volatile tt_l1_ptr uint16_t* tile =
+        reinterpret_cast<const volatile tt_l1_ptr uint16_t*>(address);
+    return tile[tile_element_offset(row, column)] != 0;
+}
+
+FORCE_INLINE void zero_tiles(uint32_t address, uint32_t tiles) {
+    volatile tt_l1_ptr uint32_t* data =
+        reinterpret_cast<volatile tt_l1_ptr uint32_t*>(address);
+    for (uint32_t i = 0; i < tiles * 1024; ++i) {
+        data[i] = 0;
+    }
+}
+
+}  // namespace
+
+void kernel_main() {
+    constexpr uint32_t kt = get_compile_time_arg_val(0);
+    constexpr uint32_t vt = get_compile_time_arg_val(1);
+    constexpr uint32_t batch_size = get_compile_time_arg_val(2);
+    constexpr uint32_t num_heads = get_compile_time_arg_val(3);
+    constexpr uint32_t num_workers = get_compile_time_arg_val(4);
+    constexpr uint32_t state_tiles = kt * vt;
+    constexpr uint32_t tile_bytes = 4096;
+
+    const uint32_t worker = get_arg_val<uint32_t>(0);
+    const uint32_t query_address = get_arg_val<uint32_t>(1);
+    const uint32_t key_address = get_arg_val<uint32_t>(2);
+    const uint32_t value_address = get_arg_val<uint32_t>(3);
+    const uint32_t beta_address = get_arg_val<uint32_t>(4);
+    const uint32_t decay_address = get_arg_val<uint32_t>(5);
+    const uint32_t state_address = get_arg_val<uint32_t>(6);
+    const uint32_t state_indices_address = get_arg_val<uint32_t>(7);
+    const uint32_t has_initial_state_address = get_arg_val<uint32_t>(8);
+
+    constexpr auto query_args = TensorAccessorArgs<5>();
+    constexpr auto key_args = TensorAccessorArgs<query_args.next_compile_time_args_offset()>();
+    constexpr auto value_args = TensorAccessorArgs<key_args.next_compile_time_args_offset()>();
+    constexpr auto beta_args = TensorAccessorArgs<value_args.next_compile_time_args_offset()>();
+    constexpr auto decay_args = TensorAccessorArgs<beta_args.next_compile_time_args_offset()>();
+    constexpr auto state_args = TensorAccessorArgs<decay_args.next_compile_time_args_offset()>();
+    constexpr auto state_indices_args = TensorAccessorArgs<state_args.next_compile_time_args_offset()>();
+    constexpr auto has_initial_state_args =
+        TensorAccessorArgs<state_indices_args.next_compile_time_args_offset()>();
+    const auto query = TensorAccessor(query_args, query_address, tile_bytes);
+    const auto key = TensorAccessor(key_args, key_address, tile_bytes);
+    const auto value = TensorAccessor(value_args, value_address, tile_bytes);
+    const auto beta = TensorAccessor(beta_args, beta_address, tile_bytes);
+    const auto decay = TensorAccessor(decay_args, decay_address, tile_bytes);
+    const auto state = TensorAccessor(state_args, state_address, tile_bytes);
+    constexpr uint32_t index_tile_bytes = 4096;
+    constexpr uint32_t flag_tile_bytes = 2048;
+    const auto state_indices =
+        TensorAccessor(state_indices_args, state_indices_address, index_tile_bytes);
+    const auto has_initial_state =
+        TensorAccessor(has_initial_state_args, has_initial_state_address, flag_tile_bytes);
+
+    CircularBuffer state_cb(tt::CBIndex::c_0);
+    CircularBuffer query_cb(tt::CBIndex::c_1);
+    CircularBuffer key_cb(tt::CBIndex::c_2);
+    CircularBuffer value_cb(tt::CBIndex::c_3);
+    CircularBuffer decay_cb(tt::CBIndex::c_4);
+    CircularBuffer beta_cb(tt::CBIndex::c_5);
+    CircularBuffer key_transposed_cb(tt::CBIndex::c_9);
+    CircularBuffer state_indices_cb(tt::CBIndex::c_15);
+    CircularBuffer has_initial_state_cb(tt::CBIndex::c_17);
+    Noc noc;
+
+    // Metadata is shared by every head handled by this core.
+    state_indices_cb.reserve_back(1);
+    has_initial_state_cb.reserve_back(1);
+    noc.async_read(state_indices, state_indices_cb, index_tile_bytes,
+                   {.page_id = 0}, {.offset_bytes = 0});
+    noc.async_read(has_initial_state, has_initial_state_cb, flag_tile_bytes,
+                   {.page_id = 0}, {.offset_bytes = 0});
+    noc.async_read_barrier();
+
+    for (uint32_t work = worker; work < batch_size * num_heads; work += num_workers) {
+    const uint32_t batch = work / num_heads;
+    const uint32_t head = work % num_heads;
+
+    const uint32_t state_slot =
+        read_int32_tile(state_indices_cb.get_write_ptr(), 0, batch);
+    const bool has_state =
+        read_bfloat16_tile(has_initial_state_cb.get_write_ptr(), 0, batch);
+
+    const uint32_t state_base = (state_slot * num_heads + head) * state_tiles;
+    state_cb.reserve_back(state_tiles);
+    if (has_state) {
+        for (uint32_t tile = 0; tile < state_tiles; ++tile) {
+            noc.async_read(
+                state,
+                state_cb,
+                tile_bytes,
+                {.page_id = state_base + tile},
+                {.offset_bytes = tile * tile_bytes});
+        }
+    }
+
+    const uint32_t vector_base = (batch * num_heads + head) * kt;
+    query_cb.reserve_back(kt);
+    for (uint32_t tile = 0; tile < kt; ++tile) {
+        noc.async_read(
+            query,
+            query_cb,
+            tile_bytes,
+            {.page_id = vector_base + tile},
+            {.offset_bytes = tile * tile_bytes});
+    }
+
+    key_cb.reserve_back(kt);
+    key_transposed_cb.reserve_back(kt);
+    for (uint32_t tile = 0; tile < kt; ++tile) {
+        noc.async_read(
+            key,
+            key_cb,
+            tile_bytes,
+            {.page_id = vector_base + tile},
+            {.offset_bytes = tile * tile_bytes});
+    }
+
+    const uint32_t value_base = (batch * num_heads + head) * vt;
+    value_cb.reserve_back(vt);
+    for (uint32_t tile = 0; tile < vt; ++tile) {
+        noc.async_read(
+            value,
+            value_cb,
+            tile_bytes,
+            {.page_id = value_base + tile},
+            {.offset_bytes = tile * tile_bytes});
+    }
+
+    const uint32_t scalar_page =
+        (batch / 32) * ((num_heads + 31) / 32) + head / 32;
+    const uint32_t scalar_row = batch % 32;
+    const uint32_t scalar_column = head % 32;
+    beta_cb.reserve_back(1);
+    noc.async_read(beta, beta_cb, tile_bytes, {.page_id = scalar_page}, {.offset_bytes = 0});
+    decay_cb.reserve_back(1);
+    noc.async_read(decay, decay_cb, tile_bytes, {.page_id = scalar_page}, {.offset_bytes = 0});
+    noc.async_read_barrier();
+
+    if (!has_state) {
+        zero_tiles(state_cb.get_write_ptr(), state_tiles);
+    }
+    state_cb.push_back(state_tiles);
+    query_cb.push_back(kt);
+    for (uint32_t tile = 0; tile < kt; ++tile) {
+        transpose_row_tile(
+            key_cb.get_write_ptr() + tile * tile_bytes,
+            key_transposed_cb.get_write_ptr() + tile * tile_bytes);
+    }
+    key_cb.push_back(kt);
+    key_transposed_cb.push_back(kt);
+    value_cb.push_back(vt);
+    make_scalar_tile(beta_cb.get_write_ptr(), scalar_row, scalar_column);
+    beta_cb.push_back(1);
+    make_scalar_tile(decay_cb.get_write_ptr(), scalar_row, scalar_column);
+    decay_cb.push_back(1);
+    }
+}
diff --git ttnn/cpp/ttnn/operations/transformer/gated_delta_attn/device/kernels/dataflow/writer_gated_delta_decode.cpp ttnn/cpp/ttnn/operations/transformer/gated_delta_attn/device/kernels/dataflow/writer_gated_delta_decode.cpp

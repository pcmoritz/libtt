+// SPDX-FileCopyrightText: (c) 2026 Tenstorrent AI ULC
+// SPDX-License-Identifier: Apache-2.0
+
+#include <stdint.h>
+
+#include "api/dataflow/circular_buffer.h"
+#include "api/dataflow/dataflow_api.h"
+#include "api/dataflow/noc.h"
+
+void kernel_main() {
+    constexpr uint32_t kt = get_compile_time_arg_val(0);
+    constexpr uint32_t vt = get_compile_time_arg_val(1);
+    constexpr uint32_t batch_size = get_compile_time_arg_val(2);
+    constexpr uint32_t num_heads = get_compile_time_arg_val(3);
+    constexpr uint32_t num_workers = get_compile_time_arg_val(4);
+    constexpr uint32_t state_tiles = kt * vt;
+    constexpr uint32_t state_tile_bytes = 4096;
+    constexpr uint32_t output_tile_bytes = 2048;
+
+    const uint32_t worker = get_arg_val<uint32_t>(0);
+    const uint32_t output_address = get_arg_val<uint32_t>(1);
+    const uint32_t state_address = get_arg_val<uint32_t>(2);
+    const uint32_t state_indices_address = get_arg_val<uint32_t>(3);
+
+    constexpr auto output_args = TensorAccessorArgs<5>();
+    constexpr auto state_args =
+        TensorAccessorArgs<output_args.next_compile_time_args_offset()>();
+    constexpr auto state_indices_args =
+        TensorAccessorArgs<state_args.next_compile_time_args_offset()>();
+    const auto output = TensorAccessor(output_args, output_address, output_tile_bytes);
+    const auto state = TensorAccessor(state_args, state_address, state_tile_bytes);
+    const auto state_indices =
+        TensorAccessor(state_indices_args, state_indices_address, 4096);
+
+    CircularBuffer output_cb(tt::CBIndex::c_12);
+    CircularBuffer state_cb(tt::CBIndex::c_11);
+    CircularBuffer state_indices_cb(tt::CBIndex::c_29);
+    Noc noc;
+
+    for (uint32_t work = worker; work < batch_size * num_heads; work += num_workers) {
+        const uint32_t batch = work / num_heads;
+        const uint32_t head = work % num_heads;
+        const uint32_t vector_base = (batch * num_heads + head) * vt;
+
+        state_indices_cb.reserve_back(1);
+        noc.async_read(
+            state_indices, state_indices_cb, 4096,
+            {.page_id = 0}, {.offset_bytes = 0});
+        noc.async_read_barrier();
+        const volatile tt_l1_ptr uint32_t* index_tile =
+            reinterpret_cast<const volatile tt_l1_ptr uint32_t*>(
+                state_indices_cb.get_write_ptr());
+        const uint32_t index_offset =
+            (batch / 16) * 256 + batch % 16;
+        const uint32_t state_slot = index_tile[index_offset];
+        state_indices_cb.push_back(1);
+        state_indices_cb.pop_front(1);
+
+        const uint32_t state_base =
+            (state_slot * num_heads + head) * state_tiles;
+
+        output_cb.wait_front(vt);
+        state_cb.wait_front(state_tiles);
+        for (uint32_t tile = 0; tile < vt; ++tile) {
+            noc.async_write(
+                output_cb, output, output_tile_bytes,
+                {.offset_bytes = tile * output_tile_bytes},
+                {.page_id = vector_base + tile});
+        }
+        for (uint32_t tile = 0; state_slot != 0 && tile < state_tiles; ++tile) {
+            noc.async_write(
+                state_cb, state, state_tile_bytes,
+                {.offset_bytes = tile * state_tile_bytes},
+                {.page_id = state_base + tile});
+        }
+        noc.async_write_barrier();
+        output_cb.pop_front(vt);
+        state_cb.pop_front(state_tiles);
+    }
+}

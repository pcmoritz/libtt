+// SPDX-FileCopyrightText: (c) 2026 Tenstorrent AI ULC
+// SPDX-License-Identifier: Apache-2.0
+
+#include <stdint.h>
+
+#include "api/compute/bcast.h"
+#include "api/compute/compute_kernel_api.h"
+#include "api/compute/eltwise_binary.h"
+#include "api/compute/matmul.h"
+#include "api/compute/tile_move_copy.h"
+
+void kernel_main() {
+    constexpr uint32_t kt = get_compile_time_arg_val(0);
+    constexpr uint32_t vt = get_compile_time_arg_val(1);
+    constexpr uint32_t batch_size = get_compile_time_arg_val(2);
+    constexpr uint32_t num_heads = get_compile_time_arg_val(3);
+    constexpr uint32_t num_workers = get_compile_time_arg_val(4);
+    const uint32_t worker = get_arg_val<uint32_t>(0);
+    constexpr uint32_t state_tiles = kt * vt;
+
+    constexpr uint32_t state = tt::CBIndex::c_0;
+    constexpr uint32_t query = tt::CBIndex::c_1;
+    constexpr uint32_t key = tt::CBIndex::c_2;
+    constexpr uint32_t value = tt::CBIndex::c_3;
+    constexpr uint32_t decay = tt::CBIndex::c_4;
+    constexpr uint32_t beta = tt::CBIndex::c_5;
+    constexpr uint32_t state_mid = tt::CBIndex::c_6;
+    constexpr uint32_t value_read = tt::CBIndex::c_7;
+    constexpr uint32_t delta = tt::CBIndex::c_8;
+    constexpr uint32_t key_transposed = tt::CBIndex::c_9;
+    constexpr uint32_t scaled_delta = tt::CBIndex::c_10;
+    constexpr uint32_t state_new = tt::CBIndex::c_11;
+    constexpr uint32_t output = tt::CBIndex::c_12;
+
+    // Configure the FP32 unpack/pack paths before the first compute API call.
+    mm_init(key, state, value_read);
+    for (uint32_t work = worker; work < batch_size * num_heads; work += num_workers) {
+    // state_mid = decay * state
+    mul_tiles_bcast_scalar_init_short(state, decay);
+    cb_wait_front(state, state_tiles);
+    cb_wait_front(decay, 1);
+    cb_reserve_back(state_mid, state_tiles);
+    for (uint32_t tile = 0; tile < state_tiles; ++tile) {
+        tile_regs_acquire();
+        mul_tiles_bcast_scalar(state, decay, tile, 0, 0);
+        tile_regs_commit();
+        tile_regs_wait();
+        pack_tile(0, state_mid, tile);
+        tile_regs_release();
+    }
+    cb_push_back(state_mid, state_tiles);
+    cb_pop_front(state, state_tiles);
+
+    // value_read = key * state_mid
+    mm_init(key, state_mid, value_read);
+    cb_wait_front(key, kt);
+    cb_wait_front(state_mid, state_tiles);
+    cb_reserve_back(value_read, vt);
+    for (uint32_t column = 0; column < vt; ++column) {
+        tile_regs_acquire();
+        for (uint32_t inner = 0; inner < kt; ++inner) {
+            matmul_tiles(key, state_mid, inner, inner * vt + column, 0);
+        }
+        tile_regs_commit();
+        tile_regs_wait();
+        pack_tile(0, value_read, column);
+        tile_regs_release();
+    }
+    cb_push_back(value_read, vt);
+
+    // scaled_delta = beta * (value - value_read)
+    binary_op_init_common(value, value_read, delta);
+    sub_tiles_init(value, value_read);
+    cb_wait_front(value, vt);
+    cb_wait_front(value_read, vt);
+    cb_reserve_back(delta, vt);
+    for (uint32_t tile = 0; tile < vt; ++tile) {
+        tile_regs_acquire();
+        sub_tiles(value, value_read, tile, tile, 0);
+        tile_regs_commit();
+        tile_regs_wait();
+        pack_tile(0, delta, tile);
+        tile_regs_release();
+    }
+    cb_push_back(delta, vt);
+    cb_pop_front(value_read, vt);
+
+    mul_tiles_bcast_scalar_init_short(delta, beta);
+    cb_wait_front(delta, vt);
+    cb_wait_front(beta, 1);
+    cb_reserve_back(scaled_delta, vt);
+    for (uint32_t tile = 0; tile < vt; ++tile) {
+        tile_regs_acquire();
+        mul_tiles_bcast_scalar(delta, beta, tile, 0, 0);
+        tile_regs_commit();
+        tile_regs_wait();
+        pack_tile(0, scaled_delta, tile);
+        tile_regs_release();
+    }
+    cb_push_back(scaled_delta, vt);
+    cb_pop_front(delta, vt);
+
+    // state_new = state_mid + key^T * scaled_delta
+    cb_wait_front(key_transposed, kt);
+    cb_wait_front(scaled_delta, vt);
+    cb_reserve_back(state_new, state_tiles);
+    for (uint32_t row = 0; row < kt; ++row) {
+        for (uint32_t column = 0; column < vt; ++column) {
+            tile_regs_acquire();
+            copy_tile_to_dst_init_short(state_mid);
+            copy_tile(state_mid, row * vt + column, 0);
+            mm_init_short(key_transposed, scaled_delta);
+            matmul_tiles(key_transposed, scaled_delta, row, column, 0);
+            tile_regs_commit();
+            tile_regs_wait();
+            pack_tile(0, state_new, row * vt + column);
+            tile_regs_release();
+        }
+    }
+    cb_push_back(state_new, state_tiles);
+    cb_pop_front(state_mid, state_tiles);
+    cb_pop_front(key_transposed, kt);
+    cb_pop_front(scaled_delta, vt);
+
+    // Accumulate the output matmul in FP32, then pack it to BF16.
+    mm_init(query, state_new, value_read);
+    cb_wait_front(query, kt);
+    cb_wait_front(state_new, state_tiles);
+    cb_reserve_back(value_read, vt);
+    for (uint32_t column = 0; column < vt; ++column) {
+        tile_regs_acquire();
+        for (uint32_t inner = 0; inner < kt; ++inner) {
+            matmul_tiles(query, state_new, inner, inner * vt + column, 0);
+        }
+        tile_regs_commit();
+        tile_regs_wait();
+        pack_tile(0, value_read, column);
+        tile_regs_release();
+    }
+    cb_push_back(value_read, vt);
+
+    cb_wait_front(value_read, vt);
+    cb_reserve_back(output, vt);
+    copy_tile_to_dst_init_short(value_read);
+    pack_reconfig_data_format(value_read, output);
+    for (uint32_t tile = 0; tile < vt; ++tile) {
+        tile_regs_acquire();
+        copy_tile(value_read, tile, 0);
+        tile_regs_commit();
+        tile_regs_wait();
+        pack_tile(0, output, tile);
+        tile_regs_release();
+    }
+    cb_push_back(output, vt);
+    cb_pop_front(value_read, vt);
+    pack_reconfig_data_format(output, state_mid);
+
+    cb_pop_front(query, kt);
+    cb_pop_front(key, kt);
+    cb_pop_front(value, vt);
+    cb_pop_front(decay, 1);
+    cb_pop_front(beta, 1);
+    }
+}

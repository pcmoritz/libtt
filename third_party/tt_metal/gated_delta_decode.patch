+#pragma once
+
+#include "ttnn/tensor/tensor.hpp"
+
+namespace ttnn::transformer {
+
+// One recurrent gated-delta decode step. Inputs are normalized/preprocessed:
+// state_mid = decay * state
+// state' = state_mid + k^T * (beta * (v - k * state_mid))
+// output = q * state'
+Tensor gated_delta_decode(
+    const Tensor& query,
+    const Tensor& key,
+    const Tensor& value,
+    const Tensor& beta,
+    const Tensor& decay,
+    const Tensor& state,
+    const Tensor& output,
+    const Tensor& state_indices,
+    const Tensor& has_initial_state);
+
+}  // namespace ttnn::transformer

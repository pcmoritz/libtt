+// SPDX-FileCopyrightText: (c) 2026 Tenstorrent AI ULC
+// SPDX-License-Identifier: Apache-2.0
+
+#pragma once
+
+#include "ttnn/tensor/tensor.hpp"
+
+namespace ttnn::transformer {
+
+// One four-tap depthwise causal convolution decode step. The operation
+// gathers and updates request state in place, and returns silu(conv).
+Tensor causal_conv1d_update(
+    const Tensor& input,
+    const Tensor& state,
+    const Tensor& weight,
+    const Tensor& state_indices,
+    const Tensor& has_initial_state);
+
+}  // namespace ttnn::transformer

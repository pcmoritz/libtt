@@ -0,0 +1,155 @@
+// SPDX-FileCopyrightText: (c) 2026 Tenstorrent AI ULC
+// SPDX-License-Identifier: Apache-2.0
+
+#include <stdint.h>
+
+#include "api/dataflow/circular_buffer.h"
+#include "api/dataflow/dataflow_api.h"
+#include "api/dataflow/noc.h"
+#include "api/core_local_mem.h"
+#include "recurrent_utils.hpp"
+
+namespace {
+
+FORCE_INLINE void copy_channel_to_row(
+    uint32_t source_address, uint32_t source_column,
+    uint32_t destination_address, uint32_t destination_row) {
+    const volatile tt_l1_ptr uint16_t* source =
+        reinterpret_cast<const volatile tt_l1_ptr uint16_t*>(source_address);
+    volatile tt_l1_ptr uint16_t* destination =
+        reinterpret_cast<volatile tt_l1_ptr uint16_t*>(destination_address);
+    for (uint32_t channel = 0; channel < 32; ++channel) {
+        destination[tile_offset(destination_row, channel)] =
+            source[tile_offset(channel, source_column)];
+    }
+}
+
+FORCE_INLINE void update_state_tile(
+    uint32_t state_address, uint32_t input_address, uint32_t batch,
+    bool has_initial_state) {
+    volatile tt_l1_ptr uint16_t* state =
+        reinterpret_cast<volatile tt_l1_ptr uint16_t*>(state_address);
+    const volatile tt_l1_ptr uint16_t* input =
+        reinterpret_cast<const volatile tt_l1_ptr uint16_t*>(input_address);
+    for (uint32_t channel = 0; channel < 32; ++channel) {
+        const uint32_t old1 = tile_offset(channel, 1);
+        const uint32_t old2 = tile_offset(channel, 2);
+        state[tile_offset(channel, 0)] = has_initial_state ? state[old1] : 0;
+        state[tile_offset(channel, 1)] = has_initial_state ? state[old2] : 0;
+        state[tile_offset(channel, 2)] = input[tile_offset(batch, channel)];
+    }
+}
+
+}  // namespace
+
+void kernel_main() {
+    constexpr uint32_t channel_tiles = get_compile_time_arg_val(0);
+    constexpr uint32_t batch_size = get_compile_time_arg_val(1);
+    constexpr uint32_t num_workers = get_compile_time_arg_val(2);
+    constexpr uint32_t tile_bytes = 2048;
+    const uint32_t worker = get_arg_val<uint32_t>(0);
+    const uint32_t input_address = get_arg_val<uint32_t>(1);
+    const uint32_t state_address = get_arg_val<uint32_t>(2);
+    const uint32_t weight_address = get_arg_val<uint32_t>(3);
+    const uint32_t indices_address = get_arg_val<uint32_t>(4);
+    const uint32_t flags_address = get_arg_val<uint32_t>(5);
+
+    constexpr auto input_args = TensorAccessorArgs<3>();
+    constexpr auto state_args = TensorAccessorArgs<input_args.next_compile_time_args_offset()>();
+    constexpr auto weight_args = TensorAccessorArgs<state_args.next_compile_time_args_offset()>();
+    constexpr auto indices_args = TensorAccessorArgs<weight_args.next_compile_time_args_offset()>();
+    constexpr auto flags_args = TensorAccessorArgs<indices_args.next_compile_time_args_offset()>();
+    const auto input = TensorAccessor(input_args, input_address, tile_bytes);
+    const auto state = TensorAccessor(state_args, state_address, tile_bytes);
+    const auto weight = TensorAccessor(weight_args, weight_address, tile_bytes);
+    const auto indices = TensorAccessor(indices_args, indices_address, 4096);
+    const auto flags = TensorAccessor(flags_args, flags_address, tile_bytes);
+
+    CircularBuffer operands_cb(tt::CBIndex::c_0);
+    CircularBuffer state_scratch(tt::CBIndex::c_1);
+    CircularBuffer weight_scratch(tt::CBIndex::c_2);
+    CircularBuffer indices_scratch(tt::CBIndex::c_3);
+    CircularBuffer flags_scratch(tt::CBIndex::c_4);
+    Noc noc;
+
+    state_scratch.reserve_back(batch_size);
+    weight_scratch.reserve_back(1);
+    indices_scratch.reserve_back(1);
+    flags_scratch.reserve_back(1);
+    noc.async_read(indices, indices_scratch, 4096, {.page_id = 0}, {.offset_bytes = 0});
+    noc.async_read(flags, flags_scratch, tile_bytes, {.page_id = 0}, {.offset_bytes = 0});
+    noc.async_read_barrier();
+
+    for (uint32_t channel_tile = worker; channel_tile < channel_tiles;
+         channel_tile += num_workers) {
+        operands_cb.reserve_back(8);
+        const uint32_t operands_address = operands_cb.get_write_ptr();
+        zero_tiles<uint16_t>(operands_address, 8);
+
+        // x already has the desired [batch, channel] tile orientation.
+        noc.async_read(
+            input, operands_cb, tile_bytes, {.page_id = channel_tile},
+            {.offset_bytes = 6 * tile_bytes});
+        noc.async_read(
+            weight, weight_scratch, tile_bytes, {.page_id = channel_tile},
+            {.offset_bytes = 0});
+        noc.async_read_barrier();
+
+        // Read active state tiles together. Dummy rows stay zero and do not
+        // need weights because their input rows are zero as well.
+        for (uint32_t batch = 0; batch < batch_size; ++batch) {
+            const uint32_t slot = read_index(indices_scratch.get_write_ptr(), batch);
+            if (slot == 0) {
+                continue;
+            }
+            for (uint32_t tap = 0; tap < 4; ++tap) {
+                copy_channel_to_row(
+                    weight_scratch.get_write_ptr(), tap,
+                    operands_address + (2 * tap + 1) * tile_bytes, batch);
+            }
+            if (read_flag(flags_scratch.get_write_ptr(), batch)) {
+                noc.async_read(
+                    state, state_scratch, tile_bytes,
+                    {.page_id = slot * channel_tiles + channel_tile},
+                    {.offset_bytes = batch * tile_bytes});
+            } else {
+                zero_tiles<uint16_t>(
+                    state_scratch.get_write_ptr() + batch * tile_bytes, 1);
+            }
+        }
+        noc.async_read_barrier();
+
+        // Gather the old state rows before updating the state in place.
+        for (uint32_t batch = 0; batch < batch_size; ++batch) {
+            const uint32_t slot = read_index(indices_scratch.get_write_ptr(), batch);
+            if (slot == 0) {
+                continue;
+            }
+            const uint32_t state_address =
+                state_scratch.get_write_ptr() + batch * tile_bytes;
+            for (uint32_t tap = 0; tap < 3; ++tap) {
+                copy_channel_to_row(
+                    state_address, tap,
+                    operands_address + 2 * tap * tile_bytes, batch);
+            }
+        }
+        operands_cb.push_back(8);
+
+        // All old state values are now in the operands CB, so this core can
+        // safely update its disjoint channel tile in DRAM.
+        for (uint32_t batch = 0; batch < batch_size; ++batch) {
+            const uint32_t slot = read_index(indices_scratch.get_write_ptr(), batch);
+            if (slot == 0) {
+                continue;
+            }
+            uint32_t state_tile = state_scratch.get_write_ptr() + batch * tile_bytes;
+            update_state_tile(
+                state_tile, operands_address + 6 * tile_bytes, batch,
+                read_flag(flags_scratch.get_write_ptr(), batch));
+            noc.async_write(
+                CoreLocalMem<uint32_t>(state_tile), state, tile_bytes, {},
+                {.page_id = slot * channel_tiles + channel_tile});
+        }
+        noc.async_write_barrier();
+    }
+}

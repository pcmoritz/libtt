@@ -0,0 +1,258 @@
+// SPDX-FileCopyrightText: (c) 2026 Tenstorrent AI ULC
+// SPDX-License-Identifier: Apache-2.0
+
+#include "ttnn/operations/transformer/gated_delta_attn/causal_conv1d_update.hpp"
+
+#include <algorithm>
+#include <variant>
+
+#include <tt-metalium/buffer.hpp>
+#include <tt-metalium/host_api.hpp>
+#include <tt-metalium/tensor_accessor_args.hpp>
+#include <tt-metalium/work_split.hpp>
+#include "ttnn/device.hpp"
+#include "ttnn/device_operation.hpp"
+#include "ttnn/operation.hpp"
+#include "ttnn/tensor/tensor_ops.hpp"
+
+using namespace tt::tt_metal;
+
+namespace ttnn::prim {
+namespace {
+
+struct ConvParams {};
+
+struct ConvInputs {
+    Tensor input;
+    Tensor state;
+    Tensor weight;
+    Tensor state_indices;
+    Tensor has_initial_state;
+};
+
+struct ConvSharedVariables {
+    KernelHandle reader_kernel_id;
+    KernelHandle writer_kernel_id;
+    uint32_t grid_y;
+    uint32_t num_workers;
+};
+
+struct ConvProgramFactory {
+    using shared_variables_t = ConvSharedVariables;
+    using cached_program_t = device_operation::CachedProgram<shared_variables_t>;
+    using operation_attributes_t = ConvParams;
+    using tensor_args_t = ConvInputs;
+    using tensor_return_value_t = Tensor;
+
+    static cached_program_t create(
+        const operation_attributes_t&, const tensor_args_t&, tensor_return_value_t&);
+    static void override_runtime_arguments(
+        cached_program_t&, const operation_attributes_t&, const tensor_args_t&,
+        tensor_return_value_t&);
+};
+
+struct ConvOperation {
+    using operation_attributes_t = ConvParams;
+    using tensor_args_t = ConvInputs;
+    using spec_return_value_t = TensorSpec;
+    using tensor_return_value_t = Tensor;
+    using program_factory_t = std::variant<ConvProgramFactory>;
+
+    static void validate_on_program_cache_miss(
+        const operation_attributes_t&, const tensor_args_t&);
+    static void validate_on_program_cache_hit(
+        const operation_attributes_t& attrs, const tensor_args_t& inputs) {
+        validate_on_program_cache_miss(attrs, inputs);
+    }
+    static spec_return_value_t compute_output_specs(
+        const operation_attributes_t&, const tensor_args_t&);
+    static tensor_return_value_t create_output_tensors(
+        const operation_attributes_t&, const tensor_args_t&);
+    static ttsl::hash::hash_t compute_program_hash(
+        const operation_attributes_t&, const tensor_args_t&);
+};
+
+void validate_tensor(const Tensor& tensor, DataType dtype, const char* name) {
+    TT_FATAL(tensor.storage_type() == StorageType::DEVICE, "{} must be on device", name);
+    TT_FATAL(tensor.buffer() != nullptr, "{} must be allocated", name);
+    TT_FATAL(tensor.layout() == Layout::TILE, "{} must use TILE layout", name);
+    TT_FATAL(tensor.dtype() == dtype, "{} has an unsupported dtype", name);
+    TT_FATAL(
+        tensor.buffer()->buffer_layout() == TensorMemoryLayout::INTERLEAVED,
+        "{} must be interleaved", name);
+}
+
+void check_shape(const Tensor& tensor, std::initializer_list<uint32_t> expected, const char* name) {
+    TT_FATAL(tensor.logical_shape() == Shape(expected), "{} shape mismatch", name);
+}
+
+void ConvOperation::validate_on_program_cache_miss(
+    const operation_attributes_t&, const tensor_args_t& in) {
+    validate_tensor(in.input, DataType::BFLOAT16, "input");
+    validate_tensor(in.state, DataType::BFLOAT16, "state");
+    validate_tensor(in.weight, DataType::BFLOAT16, "weight");
+    validate_tensor(in.state_indices, DataType::INT32, "state indices");
+    validate_tensor(
+        in.has_initial_state, DataType::BFLOAT16, "initial-state mask");
+
+    const auto& input_shape = in.input.logical_shape();
+    const auto& state_shape = in.state.logical_shape();
+    TT_FATAL(input_shape.rank() == 2, "input must have rank 2");
+    const uint32_t batch_size = input_shape[0];
+    const uint32_t channels = input_shape[1];
+    TT_FATAL(batch_size > 0 && batch_size <= 32, "batch size must be in [1, 32]");
+    TT_FATAL(channels > 0 && channels % 32 == 0, "channels must be tile aligned");
+    TT_FATAL(
+        state_shape.rank() == 3 && state_shape[0] >= 2 &&
+            state_shape[1] == channels && state_shape[2] == 3,
+        "state must have shape [slots, channels, 3]");
+    check_shape(in.weight, {channels, 4}, "weight");
+    check_shape(in.state_indices, {batch_size}, "state indices");
+    check_shape(in.has_initial_state, {batch_size}, "initial-state mask");
+}
+
+ConvOperation::spec_return_value_t ConvOperation::compute_output_specs(
+    const operation_attributes_t&, const tensor_args_t& in) {
+    return in.input.tensor_spec();
+}
+
+ConvOperation::tensor_return_value_t ConvOperation::create_output_tensors(
+    const operation_attributes_t&, const tensor_args_t& in) {
+    return create_device_tensor(in.input.tensor_spec(), in.input.device());
+}
+
+ttsl::hash::hash_t ConvOperation::compute_program_hash(
+    const operation_attributes_t&, const tensor_args_t& in) {
+    return operation::hash_operation<ConvOperation>(
+        in.input, in.state, in.weight, in.state_indices,
+        in.has_initial_state);
+}
+
+ConvProgramFactory::cached_program_t ConvProgramFactory::create(
+    const operation_attributes_t&, const tensor_args_t& in,
+    tensor_return_value_t& outputs) {
+    const uint32_t batch_size = in.input.logical_shape()[0];
+    const uint32_t channels = in.input.logical_shape()[1];
+    const uint32_t channel_tiles = channels / 32;
+    Program program;
+
+    auto* device = in.input.device();
+    const CoreCoord grid = device->compute_with_storage_grid_size();
+    const uint32_t num_workers = std::min(
+        channel_tiles, static_cast<uint32_t>(grid.x * grid.y));
+    CoreRangeSet cores = num_cores_to_corerangeset(num_workers, grid);
+
+    auto make_cb = [&](uint32_t index, uint32_t tiles, tt::DataFormat format) {
+        const uint32_t page_size = tt::tile_size(format);
+        CircularBufferConfig config(tiles * page_size, {{index, format}});
+        config.set_page_size(index, page_size);
+        CreateCircularBuffer(program, cores, config);
+    };
+    make_cb(0, 8, tt::DataFormat::Float16_b);  // compute operands
+    make_cb(1, batch_size, tt::DataFormat::Float16_b);  // reader state scratch
+    make_cb(2, 1, tt::DataFormat::Float16_b);  // reader weight scratch
+    make_cb(3, 1, tt::DataFormat::Int32);      // reader indices
+    make_cb(4, 1, tt::DataFormat::Float16_b);  // reader flags
+    make_cb(
+        5, (channel_tiles + num_workers - 1) / num_workers,
+        tt::DataFormat::Float16_b);  // output
+
+    std::vector<uint32_t> reader_args = {
+        channel_tiles, batch_size, num_workers};
+    TensorAccessorArgs(in.input.buffer()).append_to(reader_args);
+    TensorAccessorArgs(in.state.buffer()).append_to(reader_args);
+    TensorAccessorArgs(in.weight.buffer()).append_to(reader_args);
+    TensorAccessorArgs(in.state_indices.buffer()).append_to(reader_args);
+    TensorAccessorArgs(in.has_initial_state.buffer()).append_to(reader_args);
+
+    std::vector<uint32_t> writer_args = {channel_tiles, num_workers};
+    TensorAccessorArgs(outputs.buffer()).append_to(writer_args);
+
+    const std::string kernel_dir =
+        "ttnn/cpp/ttnn/operations/transformer/gated_delta_attn/device/kernels/";
+    auto reader = CreateKernel(
+        program, kernel_dir + "dataflow/reader_causal_conv1d_update.cpp",
+        cores,
+        DataMovementConfig{
+            .processor = DataMovementProcessor::RISCV_1,
+            .noc = NOC::RISCV_1_default,
+            .compile_args = reader_args});
+    auto writer = CreateKernel(
+        program, kernel_dir + "dataflow/writer_causal_conv1d_update.cpp",
+        cores,
+        DataMovementConfig{
+            .processor = DataMovementProcessor::RISCV_0,
+            .noc = NOC::RISCV_0_default,
+            .compile_args = writer_args});
+    auto compute = CreateKernel(
+        program, kernel_dir + "compute/causal_conv1d_update.cpp", cores,
+        ComputeConfig{
+            .math_fidelity = tt::tt_metal::MathFidelity::HiFi2,
+            .fp32_dest_acc_en = false,
+            .math_approx_mode = false,
+            .compile_args = {channel_tiles, num_workers}});
+
+    for (uint32_t worker = 0; worker < num_workers; ++worker) {
+        const CoreCoord core{worker / grid.y, worker % grid.y};
+        SetRuntimeArgs(
+            program, reader, core,
+            {worker, in.input.buffer()->address(), in.state.buffer()->address(),
+             in.weight.buffer()->address(), in.state_indices.buffer()->address(),
+             in.has_initial_state.buffer()->address()});
+        SetRuntimeArgs(
+            program, writer, core,
+            {worker, outputs.buffer()->address()});
+        SetRuntimeArgs(program, compute, core, {worker});
+    }
+
+    return cached_program_t{
+        std::move(program),
+        {.reader_kernel_id = reader,
+         .writer_kernel_id = writer,
+         .grid_y = static_cast<uint32_t>(grid.y),
+         .num_workers = num_workers}};
+}
+
+void ConvProgramFactory::override_runtime_arguments(
+    cached_program_t& cached, const operation_attributes_t&,
+    const tensor_args_t& in, tensor_return_value_t& outputs) {
+    for (uint32_t worker = 0; worker < cached.shared_variables.num_workers;
+         ++worker) {
+        CoreCoord core{
+            worker / cached.shared_variables.grid_y,
+            worker % cached.shared_variables.grid_y};
+        auto& reader_args = GetRuntimeArgs(
+            cached.program, cached.shared_variables.reader_kernel_id, core);
+        reader_args[1] = in.input.buffer()->address();
+        reader_args[2] = in.state.buffer()->address();
+        reader_args[3] = in.weight.buffer()->address();
+        reader_args[4] = in.state_indices.buffer()->address();
+        reader_args[5] = in.has_initial_state.buffer()->address();
+        auto& writer_args = GetRuntimeArgs(
+            cached.program, cached.shared_variables.writer_kernel_id, core);
+        writer_args[1] = outputs.buffer()->address();
+    }
+}
+
+}  // namespace
+}  // namespace ttnn::prim
+
+namespace ttnn::transformer {
+
+Tensor causal_conv1d_update(
+    const Tensor& input,
+    const Tensor& state,
+    const Tensor& weight,
+    const Tensor& state_indices,
+    const Tensor& has_initial_state) {
+    using Op = prim::ConvOperation;
+    return device_operation::launch<Op>(
+        {},
+        {.input = input,
+         .state = state,
+         .weight = weight,
+         .state_indices = state_indices,
+         .has_initial_state = has_initial_state});
+}

+// SPDX-FileCopyrightText: (c) 2026 Tenstorrent AI ULC
+// SPDX-License-Identifier: Apache-2.0
+
+#include <stdint.h>
+
+#include "api/dataflow/circular_buffer.h"
+#include "api/dataflow/dataflow_api.h"
+#include "api/dataflow/noc.h"
+
+void kernel_main() {
+    constexpr uint32_t channel_tiles = get_compile_time_arg_val(0);
+    constexpr uint32_t num_workers = get_compile_time_arg_val(1);
+    constexpr uint32_t tile_bytes = 2048;
+    const uint32_t worker = get_arg_val<uint32_t>(0);
+    const uint32_t output_address = get_arg_val<uint32_t>(1);
+
+    constexpr auto output_args = TensorAccessorArgs<2>();
+    const auto output = TensorAccessor(output_args, output_address, tile_bytes);
+    CircularBuffer output_cb(tt::CBIndex::c_5);
+    Noc noc;
+
+    for (uint32_t channel_tile = worker; channel_tile < channel_tiles;
+         channel_tile += num_workers) {
+        output_cb.wait_front(1);
+        noc.async_write(
+            output_cb, output, tile_bytes, {.offset_bytes = 0},
+            {.page_id = channel_tile});
+        noc.async_write_barrier();
+        output_cb.pop_front(1);
+    }
+}

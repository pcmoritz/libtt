+// SPDX-FileCopyrightText: (c) 2026 Tenstorrent AI ULC
+// SPDX-License-Identifier: Apache-2.0
+
+#include <stdint.h>
+
+#include "api/compute/common.h"
+#include "api/compute/compute_kernel_api.h"
+#include "api/compute/eltwise_binary_sfpu.h"
+#include "api/compute/eltwise_unary/eltwise_unary.h"
+#include "api/compute/tile_move_copy.h"
+#include "api/dataflow/circular_buffer.h"
+
+void kernel_main() {
+    constexpr uint32_t channel_tiles = get_compile_time_arg_val(0);
+    constexpr uint32_t num_workers = get_compile_time_arg_val(1);
+    const uint32_t worker = get_arg_val<uint32_t>(0);
+
+    constexpr uint32_t operands = tt::CBIndex::c_0;
+    constexpr uint32_t output = tt::CBIndex::c_5;
+    CircularBuffer operands_cb(operands);
+    CircularBuffer output_cb(output);
+
+    init_sfpu(operands, output);
+    for (uint32_t channel_tile = worker; channel_tile < channel_tiles;
+         channel_tile += num_workers) {
+        operands_cb.wait_front(8);
+        output_cb.reserve_back(1);
+        tile_regs_acquire();
+
+        copy_tile_to_dst_init_short(operands);
+        for (uint32_t tile = 0; tile < 8; ++tile) {
+            copy_tile(operands, tile, tile);
+        }
+        // Four depthwise products occupy even DST registers.
+        mul_binary_tile_init();
+        mul_binary_tile(0, 1, 0);
+        mul_binary_tile(2, 3, 2);
+        mul_binary_tile(4, 5, 4);
+        mul_binary_tile(6, 7, 6);
+
+        add_binary_tile_init();
+        add_binary_tile(0, 2, 0);
+        add_binary_tile(4, 6, 4);
+        add_binary_tile(0, 4, 0);
+        silu_tile_init();
+        silu_tile(0);
+
+        tile_regs_commit();
+        tile_regs_wait();
+        pack_tile(0, output);
+        operands_cb.pop_front(8);
+        output_cb.push_back(1);
+        tile_regs_release();
+    }
+}

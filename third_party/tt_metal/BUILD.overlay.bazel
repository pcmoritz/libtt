genrule(
    name = "tt_metal_hal_generated_headers",
    srcs = [
        "tt_metal/hw/inc/hostdev/dev_msgs.h",
        "tt_metal/hw/inc/hostdev/fabric_telemetry_msgs.h",
        "tt_metal/hw/inc/hostdev/realtime_profiler_msgs.h",
        "tt_metal/llrt/hal/codegen/codegen.py",
        "tt_metal/llrt/hal/codegen/codegen.sh",
    ],
    outs = [
        "hal/generated/dev_msgs.hpp",
        "hal/generated/dev_msgs_impl.hpp",
        "hal/generated/fabric_telemetry.hpp",
        "hal/generated/fabric_telemetry_impl.hpp",
        "hal/generated/realtime_profiler_msgs.hpp",
        "hal/generated/realtime_profiler_msgs_impl.hpp",
        "llrt/hal/generated/dev_msgs.hpp",
        "llrt/hal/generated/dev_msgs_impl.hpp",
        "llrt/hal/generated/fabric_telemetry.hpp",
        "llrt/hal/generated/fabric_telemetry_impl.hpp",
        "llrt/hal/generated/realtime_profiler_msgs.hpp",
        "llrt/hal/generated/realtime_profiler_msgs_impl.hpp",
    ],
    cmd = "src=$(location tt_metal/hw/inc/hostdev/dev_msgs.h); " +
          "root=$${src%/tt_metal/hw/inc/hostdev/dev_msgs.h}; " +
          "outdir=$$(dirname $(location hal/generated/dev_msgs.hpp)); " +
          "llrt_outdir=$$(dirname $(location llrt/hal/generated/dev_msgs.hpp)); " +
          "bash $(location tt_metal/llrt/hal/codegen/codegen.sh) $$root $$outdir; " +
          "mkdir -p $$llrt_outdir; " +
          "cp $(location hal/generated/dev_msgs.hpp) $(location llrt/hal/generated/dev_msgs.hpp); " +
          "cp $(location hal/generated/dev_msgs_impl.hpp) $(location llrt/hal/generated/dev_msgs_impl.hpp); " +
          "cp $(location hal/generated/fabric_telemetry.hpp) $(location llrt/hal/generated/fabric_telemetry.hpp); " +
          "cp $(location hal/generated/fabric_telemetry_impl.hpp) $(location llrt/hal/generated/fabric_telemetry_impl.hpp); " +
          "cp $(location hal/generated/realtime_profiler_msgs.hpp) $(location llrt/hal/generated/realtime_profiler_msgs.hpp); " +
          "cp $(location hal/generated/realtime_profiler_msgs_impl.hpp) $(location llrt/hal/generated/realtime_profiler_msgs_impl.hpp)",
    tools = [
        "tt_metal/llrt/hal/codegen/codegen.py",
        "tt_metal/llrt/hal/codegen/codegen.sh",
    ],
)

filegroup(
    name = "tt_metal_flatbuffer_headers",
    srcs = [
        ":tt_metal_api_flatbuffer_headers",
        ":tt_metal_distributed_flatbuffer_headers",
        ":tt_metal_impl_flatbuffer_headers",
    ],
)

genrule(

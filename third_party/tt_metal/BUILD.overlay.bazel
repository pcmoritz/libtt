BLACKHOLE_RUNTIME_PROCS = [
    ("brisc", "brisc"),
    ("ncrisc", "ncrisc"),
    ("ierisc", "ierisc"),
    ("subordinate_ierisc", "subordinate_ierisc"),
    ("trisc=0", "trisc0"),
    ("trisc=1", "trisc1"),
    ("trisc=2", "trisc2"),
    ("aerisc", "aerisc"),
    ("main_aerisc", "main_aerisc"),
    ("subordinate_aerisc", "subordinate_aerisc"),
    ("drisc", "drisc"),
]

BLACKHOLE_RUNTIME_LD_OUTS = [
    "runtime/hw/toolchain/blackhole/%s_%s.ld" % (kind, proc_file)
    for kind in ["firmware", "kernel"]
    for _, proc_file in BLACKHOLE_RUNTIME_PROCS
]

BLACKHOLE_RUNTIME_OBJ_OUTS = [
    "runtime/hw/lib/blackhole/noc.o",
    "runtime/hw/lib/blackhole/substitutes.o",
    "runtime/hw/lib/blackhole/tdma_xmov.o",
    "runtime/hw/lib/blackhole/tmu-crt0.o",
]

genrule(
    name = "tt_metal_blackhole_runtime_hw_assets",
    srcs = glob([
        "tt_metal/hw/firmware/src/tt-1xx/**/*",
        "tt_metal/hw/inc/**/*",
        "tt_metal/hw/toolchain/**/*",
        "tt_metal/tt-llk/common/**/*",
        "tt_metal/tt-llk/tt_llk_blackhole/**/*",
    ], allow_empty = True),
    tools = [
        "@sfpi//:all_files",
        "@sfpi//:riscv_gpp",
    ],
    outs = BLACKHOLE_RUNTIME_LD_OUTS + BLACKHOLE_RUNTIME_OBJ_OUTS,
    cmd = """
set -eu
main_ld=$(location tt_metal/hw/toolchain/main.ld)
root=$${main_ld%/tt_metal/hw/toolchain/main.ld}
toolchain_out="$(RULEDIR)/runtime/hw/toolchain/blackhole"
lib_out="$(RULEDIR)/runtime/hw/lib/blackhole"
mkdir -p "$$toolchain_out" "$$lib_out"

for item in \
  brisc:brisc \
  ncrisc:ncrisc \
  ierisc:ierisc \
  subordinate_ierisc:subordinate_ierisc \
  trisc=0:trisc0 \
  trisc=1:trisc1 \
  trisc=2:trisc2 \
  aerisc:aerisc \
  main_aerisc:main_aerisc \
  subordinate_aerisc:subordinate_aerisc \
  drisc:drisc; do
  proc_define=$${item%%:*}
  proc_file=$${item##*:}
  proc_define_upper=$$(printf '%s' "$$proc_define" | tr '[:lower:]' '[:upper:]')
  for kind in firmware kernel; do
    kind_upper=$$(printf '%s' "$$kind" | tr '[:lower:]' '[:upper:]')
    gcc -DTYPE_$$kind_upper -DCOMPILE_FOR_$$proc_define_upper -DARCH_BLACKHOLE \
      -I"$$root/tt_metal/hw/inc/internal/tt-1xx/blackhole" \
      -E -P -x c -o "$$toolchain_out/$${kind}_$${proc_file}.ld" \
      "$$root/tt_metal/hw/toolchain/main.ld"
  done
done

gpp=$(location @sfpi//:riscv_gpp)
common_flags="-mcpu=tt-bh -std=c++17 -flto=auto -ffast-math -fno-use-cxa-atexit -fno-exceptions -Wall -Werror -Wno-deprecated-declarations -Wno-unknown-pragmas -Wno-error=multistatement-macros -Wno-error=parentheses -Wno-error=unused-but-set-variable -Wno-unused-variable -Wno-unused-function -Os -fno-tree-loop-distribute-patterns"
defines="-DTENSIX_FIRMWARE"
includes="-I. -I.. -I$$root -I$$root/tt_metal -I$$root/tt_metal/api -I$$root/tt_metal/api/tt-metalium -I$$root/tt_metal/hw/inc -I$$root/tt_metal/hw/inc/debug -I$$root/tt_metal/hw/firmware/src/tt-1xx -I$$root/tt_metal/hw/inc/internal/tt-1xx/blackhole -I$$root/tt_metal/hw/inc/internal/tt-1xx/blackhole/blackhole_defines -I$$root/tt_metal/hw/inc/internal/tt-1xx/blackhole/noc -I$$root/tt_metal/hw/inc/internal/tt-1xx/blackhole/overlay -I$$root/tt_metal/third_party/umd/device/blackhole -I$$root/tt_metal/hw/ckernels/blackhole/metal/common -I$$root/tt_metal/hw/ckernels/blackhole/metal/llk_io -I$$root/tt_metal/tt-llk/tt_llk_blackhole/common/inc -I$$root/tt_metal/tt-llk/tt_llk_blackhole/llk_lib"

"$$gpp" $$common_flags $$defines $$includes -c -o "$$lib_out/substitutes.o" "$$root/tt_metal/hw/toolchain/substitutes.cpp"
"$$gpp" $$common_flags $$defines $$includes -c -o "$$lib_out/tdma_xmov.o" "$$root/tt_metal/hw/firmware/src/tt-1xx/tdma_xmov.c"
"$$gpp" $$common_flags $$defines $$includes -c -o "$$lib_out/noc.o" "$$root/tt_metal/hw/firmware/src/tt-1xx/blackhole/noc.c"
"$$gpp" $$common_flags $$defines $$includes -c -o "$$lib_out/tmu-crt0.o" "$$root/tt_metal/hw/toolchain/tmu-crt0.S"
""",
    local = True,
)

cc_binary(
    name = "libtt_zstd_compressor",
    srcs = ["@//third_party/tt_metal:libtt_zstd_compressor.cc"],
    copts = ["-std=c++17"],
    deps = ["@llvm_zstd//:zstd"],
)

filegroup(
    name = "tt_metal_runtime_sources",
    srcs = glob([
        "tt_metal/**",
        "ttnn/**",
    ]),
)

pkg_tar(
    name = "tt_metal_runtime_archive",
    srcs = [
        "@sfpi//:all_files",
        ":tt_metal_blackhole_runtime_hw_assets",
        ":tt_metal_runtime_sources",
    ],
    compressor = ":libtt_zstd_compressor",
    compressor_args = "19",
    extension = "tar.zst",
    owner = "0.0",
    ownername = ".",
    portable_mtime = True,
    remap_paths = {
        "../+http_archive+sfpi/": "runtime/sfpi/",
        "../sfpi/": "runtime/sfpi/",
        "../+http_archive+tt_metal/": "",
        "../tt_metal/": "",
        "external/+http_archive+sfpi/": "runtime/sfpi/",
        "external/sfpi/": "runtime/sfpi/",
        "external/+http_archive+tt_metal/": "",
        "external/tt_metal/": "",
    },
    strip_prefix = ".",
)

genrule(
    name = "tt_metal_runtime_embedded_src",
    srcs = [":tt_metal_runtime_archive"],
    outs = [
        "libtt_embedded_runtime_assets.S",
        "libtt_embedded_runtime_assets.h",
    ],
    cmd = """
set -eu
archive="$(location :tt_metal_runtime_archive)"
fingerprint=$$(sha256sum "$$archive" | cut -d ' ' -f 1)
asm="$(@D)/libtt_embedded_runtime_assets.S"
hdr="$(@D)/libtt_embedded_runtime_assets.h"

cat > "$$hdr" <<'EOF'
#pragma once

#include <cstddef>

namespace libtt::tt_metal_runtime_assets {

extern "C" {

extern const unsigned char kRuntimeArchiveZstd[];
extern const std::size_t kRuntimeArchiveZstdSize;
extern const char kRuntimeArchiveFingerprint[];

}  // extern "C"

}  // namespace libtt::tt_metal_runtime_assets
EOF

cat > "$$asm" <<EOF
.section .rodata
.balign 16
.global kRuntimeArchiveZstd
kRuntimeArchiveZstd:
  .incbin "$$archive"
kRuntimeArchiveZstdEnd:
.balign 8
.global kRuntimeArchiveZstdSize
kRuntimeArchiveZstdSize:
  .quad kRuntimeArchiveZstdEnd - kRuntimeArchiveZstd
.global kRuntimeArchiveFingerprint
kRuntimeArchiveFingerprint:
  .asciz "$$fingerprint"
.section .note.GNU-stack,"",@progbits
EOF
""",
    local = True,
)

cc_library(
    name = "tt_metal_runtime_embedded",
    srcs = ["libtt_embedded_runtime_assets.S"],
    additional_compiler_inputs = [":tt_metal_runtime_archive"],
    hdrs = ["libtt_embedded_runtime_assets.h"],
    includes = ["."],
    linkstatic = True,
)


        "inspector_stubs/debug/inspector/inspector.hpp",
        "inspector_stubs/impl/debug/inspector/data.hpp",
        "inspector_stubs/impl/debug/inspector/inspector.hpp",
        "inspector_stubs/tt_metal/impl/debug/inspector/data.hpp",
        "inspector_stubs/tt_metal/impl/debug/inspector/inspector.hpp",
    ],
    cmd = "mkdir -p $(@D)/inspector_stubs/debug/inspector " +
          "$(@D)/inspector_stubs/impl/debug/inspector " +
          "$(@D)/inspector_stubs/tt_metal/impl/debug/inspector; " +
          "printf '%s\\n' " +
          "'#pragma once' " +
          "'namespace tt::tt_metal::inspector {' " +
          "'class Data {};' " +
          "'class RpcServer {};' " +
          "'}  // namespace tt::tt_metal::inspector' " +
          "> $(@D)/inspector_stubs/debug/inspector/data.hpp; " +
          "printf '%s\\n' " +
          "'#pragma once' " +
          "'#include <memory>' " +
          "'#include <optional>' " +
          "'#include <string>' " +
          "'#include \"debug/inspector/data.hpp\"' " +
          "'namespace tt::tt_metal {' " +
          "'class Inspector {' " +
          "'public:' " +
          "'    static bool is_enabled() { return false; }' " +
          "'    static std::unique_ptr<inspector::Data> initialize(std::optional<int>) { return {}; }' " +
          "'    static void serialize_rpc() {}' " +
          "'    template <typename... Args> static void program_created(Args&&...) noexcept {}' " +
          "'    template <typename... Args> static void program_destroyed(Args&&...) noexcept {}' " +
          "'    template <typename... Args> static void program_set_binary_status(Args&&...) noexcept {}' " +
          "'    template <typename... Args> static void program_compile_started(Args&&...) noexcept {}' " +
          "'    template <typename... Args> static void program_compile_already_exists(Args&&...) noexcept {}' " +
          "'    template <typename... Args> static void program_kernel_compile_finished(Args&&...) noexcept {}' " +
          "'    template <typename... Args> static void program_compile_finished(Args&&...) noexcept {}' " +
          "'    template <typename... Args> static void mesh_device_created(Args&&...) noexcept {}' " +
          "'    template <typename... Args> static void mesh_device_destroyed(Args&&...) noexcept {}' " +
          "'    template <typename... Args> static void mesh_device_initialized(Args&&...) noexcept {}' " +
          "'    template <typename... Args> static void mesh_workload_created(Args&&...) noexcept {}' " +
          "'    template <typename... Args> static void mesh_workload_destroyed(Args&&...) noexcept {}' " +
          "'    template <typename... Args> static void mesh_workload_add_program(Args&&...) noexcept {}' " +
          "'    template <typename... Args> static void mesh_workload_set_program_binary_status(Args&&...) noexcept {}' " +
          "'    template <typename... Args> static void emit_debug_entry(Args&&...) noexcept {}' " +
          "'    template <typename... Args> static void release_trace(Args&&...) noexcept {}' " +
          "'    template <typename... Args> static void set_dispatch_core_info(Args&&...) {}' " +
          "'    template <typename... Args> static void set_dispatch_s_core_info(Args&&...) {}' " +
          "'    template <typename... Args> static void set_prefetcher_core_info(Args&&...) {}' " +
          "'    static void clear_all_core_info() {}' " +
          "'    static std::string get_kernel_path_from_watcher_kernel_id(int) { return {}; }' " +
          "'    static void enable_kernel_path_collection() {}' " +
          "'    static inspector::RpcServer& get_rpc_server() { static inspector::RpcServer server; return server; }' " +
          "'    template <typename... Args> static void set_build_env_fw_compile_hash(Args&&...) {}' " +
          "'};' " +
          "'}  // namespace tt::tt_metal' " +
          "> $(@D)/inspector_stubs/debug/inspector/inspector.hpp; " +
          "cp $(@D)/inspector_stubs/debug/inspector/data.hpp $(@D)/inspector_stubs/impl/debug/inspector/data.hpp; " +
          "cp $(@D)/inspector_stubs/debug/inspector/inspector.hpp $(@D)/inspector_stubs/impl/debug/inspector/inspector.hpp; " +
          "cp $(@D)/inspector_stubs/debug/inspector/data.hpp $(@D)/inspector_stubs/tt_metal/impl/debug/inspector/data.hpp; " +
          "cp $(@D)/inspector_stubs/debug/inspector/inspector.hpp $(@D)/inspector_stubs/tt_metal/impl/debug/inspector/inspector.hpp",
)


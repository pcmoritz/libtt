load("@rules_pkg//pkg:tar.bzl", "pkg_tar")
load("@rules_cc//cc:defs.bzl", "cc_binary", "cc_library")
load("@//:bazel/cc_embed_data.bzl", "cc_embed_data")
load("@//third_party/sfpi:sfpi_cc_objects.bzl", "sfpi_cc_objects")

package(default_visibility = ["//visibility:public"])

genrule(
    name = "tt_metal_api_flatbuffer_headers",
    srcs = ["tt_metal/api/tt-metalium/serialized_descriptors/mesh_coordinate.fbs"],
    outs = ["api/tt-metalium/serialized_descriptors/mesh_coordinate_generated.h"],
    cmd = "api_fbs=$(location tt_metal/api/tt-metalium/serialized_descriptors/mesh_coordinate.fbs); " +
          "api_dir=$${api_fbs%/tt-metalium/serialized_descriptors/mesh_coordinate.fbs}; " +
          "$(location @com_github_google_flatbuffers//:flatc) --keep-prefix --cpp --scoped-enums -I $$api_dir -o $(@D) $$api_fbs",
    tools = ["@com_github_google_flatbuffers//:flatc"],
)

genrule(
    name = "tt_metal_impl_flatbuffer_headers",
    srcs = [
        "tt_metal/impl/flatbuffer/base_types.fbs",
        "tt_metal/impl/flatbuffer/buffer_types.fbs",
        "tt_metal/impl/flatbuffer/command.fbs",
        "tt_metal/impl/flatbuffer/light_metal_binary.fbs",
        "tt_metal/impl/flatbuffer/program_types.fbs",
    ],
    outs = [
        "flatbuffers/base_types_generated.h",
        "flatbuffers/buffer_types_generated.h",
        "flatbuffers/command_generated.h",
        "flatbuffers/light_metal_binary_generated.h",
        "flatbuffers/program_types_generated.h",
    ],
    cmd = "impl_fbs=$(location tt_metal/impl/flatbuffer/base_types.fbs); " +
          "impl_dir=$${impl_fbs%/base_types.fbs}; " +
          "mkdir -p $(@D)/flatbuffers; " +
          "$(location @com_github_google_flatbuffers//:flatc) --keep-prefix --cpp --scoped-enums -I $$impl_dir -o $(@D)/flatbuffers $(SRCS)",
    tools = ["@com_github_google_flatbuffers//:flatc"],
)

genrule(
    name = "tt_metal_distributed_flatbuffer_headers",
    srcs = [
        "tt_metal/api/tt-metalium/serialized_descriptors/mesh_coordinate.fbs",
        "tt_metal/distributed/flatbuffer/h2d_stream_service_descriptor.fbs",
        "tt_metal/distributed/flatbuffer/hd_socket_descriptor.fbs",
        "tt_metal/distributed/flatbuffer/socket_peer_descriptor.fbs",
    ],
    outs = [
        "distributed_flatbuffers/h2d_stream_service_descriptor_generated.h",
        "distributed_flatbuffers/hd_socket_descriptor_generated.h",
        "distributed_flatbuffers/socket_peer_descriptor_generated.h",
    ],
    cmd = "api_fbs=$(location tt_metal/api/tt-metalium/serialized_descriptors/mesh_coordinate.fbs); " +
          "api_dir=$${api_fbs%/tt-metalium/serialized_descriptors/mesh_coordinate.fbs}; " +
          "dist_fbs=$(location tt_metal/distributed/flatbuffer/h2d_stream_service_descriptor.fbs); " +
          "dist_dir=$${dist_fbs%/h2d_stream_service_descriptor.fbs}; " +
          "mkdir -p $(@D)/distributed_flatbuffers; " +
          "$(location @com_github_google_flatbuffers//:flatc) --keep-prefix --cpp --scoped-enums -I $$api_dir -I $$dist_dir -o $(@D)/distributed_flatbuffers " +
          "$(location tt_metal/distributed/flatbuffer/h2d_stream_service_descriptor.fbs) " +
          "$(location tt_metal/distributed/flatbuffer/hd_socket_descriptor.fbs) " +
          "$(location tt_metal/distributed/flatbuffer/socket_peer_descriptor.fbs)",
    tools = ["@com_github_google_flatbuffers//:flatc"],
)

genrule(
    name = "tt_metal_hal_generated_headers",
    srcs = [
        "tt_metal/hw/inc/hostdev/dev_msgs.h",
        "tt_metal/hw/inc/hostdev/fabric_telemetry_msgs.h",
        "tt_metal/hw/inc/hostdev/realtime_profiler_msgs.h",
        "tt_metal/llrt/hal/codegen/codegen.py",
        "tt_metal/llrt/hal/codegen/codegen.sh",
    ],
    outs = [
        "hal/generated/dev_msgs.hpp",
        "hal/generated/dev_msgs_impl.hpp",
        "hal/generated/fabric_telemetry.hpp",
        "hal/generated/fabric_telemetry_impl.hpp",
        "hal/generated/realtime_profiler_msgs.hpp",
        "hal/generated/realtime_profiler_msgs_impl.hpp",
        "llrt/hal/generated/dev_msgs.hpp",
        "llrt/hal/generated/dev_msgs_impl.hpp",
        "llrt/hal/generated/fabric_telemetry.hpp",
        "llrt/hal/generated/fabric_telemetry_impl.hpp",
        "llrt/hal/generated/realtime_profiler_msgs.hpp",
        "llrt/hal/generated/realtime_profiler_msgs_impl.hpp",
    ],
    cmd = "src=$(location tt_metal/hw/inc/hostdev/dev_msgs.h); " +
          "root=$${src%/tt_metal/hw/inc/hostdev/dev_msgs.h}; " +
          "outdir=$$(dirname $(location hal/generated/dev_msgs.hpp)); " +
          "llrt_outdir=$$(dirname $(location llrt/hal/generated/dev_msgs.hpp)); " +
          "bash $(location tt_metal/llrt/hal/codegen/codegen.sh) $$root $$outdir; " +
          "mkdir -p $$llrt_outdir; " +
          "printf '%s\\n' '#pragma once' '#include \"hal/generated/dev_msgs.hpp\"' > $(location llrt/hal/generated/dev_msgs.hpp); " +
          "printf '%s\\n' '#pragma once' '#include \"hal/generated/dev_msgs_impl.hpp\"' > $(location llrt/hal/generated/dev_msgs_impl.hpp); " +
          "printf '%s\\n' '#pragma once' '#include \"hal/generated/fabric_telemetry.hpp\"' > $(location llrt/hal/generated/fabric_telemetry.hpp); " +
          "printf '%s\\n' '#pragma once' '#include \"hal/generated/fabric_telemetry_impl.hpp\"' > $(location llrt/hal/generated/fabric_telemetry_impl.hpp); " +
          "printf '%s\\n' '#pragma once' '#include \"hal/generated/realtime_profiler_msgs.hpp\"' > $(location llrt/hal/generated/realtime_profiler_msgs.hpp); " +
          "printf '%s\\n' '#pragma once' '#include \"hal/generated/realtime_profiler_msgs_impl.hpp\"' > $(location llrt/hal/generated/realtime_profiler_msgs_impl.hpp)",
    tools = [
        "tt_metal/llrt/hal/codegen/codegen.py",
        "tt_metal/llrt/hal/codegen/codegen.sh",
    ],
)

filegroup(
    name = "tt_metal_flatbuffer_headers",
    srcs = [
        ":tt_metal_api_flatbuffer_headers",
        ":tt_metal_distributed_flatbuffer_headers",
        ":tt_metal_impl_flatbuffer_headers",
    ],
)

BLACKHOLE_RUNTIME_PROCS = [
    ("brisc", "BRISC"),
    ("ncrisc", "NCRISC"),
    ("ierisc", "IERISC"),
    ("subordinate_ierisc", "SUBORDINATE_IERISC"),
    ("trisc0", "TRISC=0"),
    ("trisc1", "TRISC=1"),
    ("trisc2", "TRISC=2"),
    ("aerisc", "AERISC"),
    ("main_aerisc", "MAIN_AERISC"),
    ("subordinate_aerisc", "SUBORDINATE_AERISC"),
    ("drisc", "DRISC"),
]

BLACKHOLE_RUNTIME_KINDS = [
    ("firmware", "FIRMWARE"),
    ("kernel", "KERNEL"),
]

BLACKHOLE_RUNTIME_LD_DIR = "runtime/hw/toolchain/blackhole"

BLACKHOLE_RUNTIME_LD_SCRIPTS = [
    ("%s/%s_%s.ld" % (BLACKHOLE_RUNTIME_LD_DIR, kind, proc), kind_define, proc_define)
    for kind, kind_define in BLACKHOLE_RUNTIME_KINDS
    for proc, proc_define in BLACKHOLE_RUNTIME_PROCS
]

BLACKHOLE_RUNTIME_OBJS = [
    ("noc.o", "tt_metal/hw/firmware/src/tt-1xx/blackhole/noc.c"),
    ("substitutes.o", "tt_metal/hw/toolchain/substitutes.cpp"),
    ("tdma_xmov.o", "tt_metal/hw/firmware/src/tt-1xx/tdma_xmov.c"),
    ("tmu-crt0.o", "tt_metal/hw/toolchain/tmu-crt0.S"),
]

BLACKHOLE_RUNTIME_COPTS = [
    "-mcpu=tt-bh",
    "-std=c++17",
    "-flto=auto",
    "-ffast-math",
    "-fno-use-cxa-atexit",
    "-fno-exceptions",
    "-Wall",
    "-Werror",
    "-Wno-deprecated-declarations",
    "-Wno-unknown-pragmas",
    "-Wno-error=multistatement-macros",
    "-Wno-error=parentheses",
    "-Wno-error=unused-but-set-variable",
    "-Wno-unused-variable",
    "-Wno-unused-function",
    "-Os",
    "-fno-tree-loop-distribute-patterns",
]

BLACKHOLE_RUNTIME_INCLUDES = [
    ".",
    "tt_metal",
    "tt_metal/api",
    "tt_metal/api/tt-metalium",
    "tt_metal/hw/inc",
    "tt_metal/hw/inc/debug",
    "tt_metal/hw/firmware/src/tt-1xx",
    "tt_metal/hw/inc/internal/tt-1xx/blackhole",
    "tt_metal/hw/inc/internal/tt-1xx/blackhole/blackhole_defines",
    "tt_metal/hw/inc/internal/tt-1xx/blackhole/noc",
    "tt_metal/hw/inc/internal/tt-1xx/blackhole/overlay",
    "tt_metal/third_party/umd/device/blackhole",
    "tt_metal/hw/ckernels/blackhole/metal/common",
    "tt_metal/hw/ckernels/blackhole/metal/llk_io",
    "tt_metal/tt-llk/tt_llk_blackhole/common/inc",
    "tt_metal/tt-llk/tt_llk_blackhole/llk_lib",
]

sfpi_cc_objects(
    name = "blackhole_runtime_obj_files",
    hdrs = glob([
        "tt_metal/hw/firmware/src/tt-1xx/**/*",
        "tt_metal/hw/inc/**/*",
        "tt_metal/hw/toolchain/**/*",
        "tt_metal/tt-llk/common/**/*",
        "tt_metal/tt-llk/tt_llk_blackhole/**/*",
    ], allow_empty = True),
    srcs = [source for _, source in BLACKHOLE_RUNTIME_OBJS],
    copts = BLACKHOLE_RUNTIME_COPTS,
    defines = ["TENSIX_FIRMWARE"],
    includes = BLACKHOLE_RUNTIME_INCLUDES,
)

pkg_tar(
    name = "blackhole_runtime_obj_tar",
    package_dir = "runtime/hw/lib/blackhole",
    srcs = [":blackhole_runtime_obj_files"],
)

genrule(
    name = "tt_metal_blackhole_runtime_hw_assets",
    srcs = [
        "tt_metal/hw/inc/internal/tt-1xx/blackhole/dev_mem_map.h",
        "tt_metal/hw/toolchain/main.ld",
    ],
    tools = [
        "@sfpi//:all_files",
        "@sfpi//:riscv_gpp",
    ],
    outs = [out for out, _, _ in BLACKHOLE_RUNTIME_LD_SCRIPTS],
    cmd = "\n".join([
        "set -euo pipefail",
        "mkdir -p '$(RULEDIR)/%s'" % BLACKHOLE_RUNTIME_LD_DIR,
    ] + [
        " ".join([
            "$(location @sfpi//:riscv_gpp)",
            "-DTYPE_%s" % type_define,
            "-DCOMPILE_FOR_%s" % proc_define,
            "-DARCH_BLACKHOLE",
            "-I$$(dirname '$(location tt_metal/hw/inc/internal/tt-1xx/blackhole/dev_mem_map.h)')",
            "-E",
            "-P",
            "-x c",
            "-o '$(RULEDIR)/%s'" % out,
            "'$(location tt_metal/hw/toolchain/main.ld)'",
        ])
        for out, type_define, proc_define in BLACKHOLE_RUNTIME_LD_SCRIPTS
    ]),
)

cc_binary(
    name = "libtt_zstd_compressor",
    srcs = ["@//third_party/tt_metal:libtt_zstd_compressor.cc"],
    copts = ["-std=c++17"],
    deps = ["@llvm_zstd//:zstd"],
)

filegroup(
    name = "tt_metal_runtime_sources",
    srcs = glob([
        "tt_metal/**",
        "ttnn/**",
    ]),
)

pkg_tar(
    name = "tt_metal_runtime_archive",
    deps = [":blackhole_runtime_obj_tar"],
    srcs = [
        "@sfpi//:all_files",
        ":tt_metal_blackhole_runtime_hw_assets",
        ":tt_metal_runtime_sources",
    ],
    compressor = ":libtt_zstd_compressor",
    compressor_args = "19",
    extension = "tar.zst",
    owner = "0.0",
    ownername = ".",
    portable_mtime = True,
    remap_paths = {
        "../+http_archive+sfpi/": "runtime/sfpi/",
        "../sfpi/": "runtime/sfpi/",
        "../+http_archive+tt_metal/": "",
        "../tt_metal/": "",
        "external/+http_archive+sfpi/": "runtime/sfpi/",
        "external/sfpi/": "runtime/sfpi/",
        "external/+http_archive+tt_metal/": "",
        "external/tt_metal/": "",
    },
    strip_prefix = ".",
)

cc_embed_data(
    name = "tt_metal_runtime_embedded",
    src = ":tt_metal_runtime_archive",
    data_symbol = "kRuntimeArchiveZstd",
    fingerprint_symbol = "kRuntimeArchiveFingerprint",
    namespace = "libtt::tt_metal_runtime_assets",
    out_prefix = "libtt_embedded_runtime_assets",
    size_symbol = "kRuntimeArchiveZstdSize",
)


+std::string with_trailing_slash(std::string path) {
+    if (!path.empty() && path.back() != '/') {
+        path.push_back('/');
+    }
+    return path;
+}
+
+std::string get_runtime_asset_root(const std::string& source_root) {
+    const char* asset_root = std::getenv("TT_METAL_RUNTIME_ASSET_ROOT");
+    if (asset_root != nullptr && asset_root[0] != '\0') {
+        return with_trailing_slash(asset_root);
+    }
+    return source_root;
+}
+
+std::vector<std::string> get_sfpi_roots(const std::string& source_root) {
+    std::vector<std::string> roots;
+    const char* sfpi_root = std::getenv("TT_METAL_SFPI_ROOT");
+    if (sfpi_root != nullptr && sfpi_root[0] != '\0') {
+        roots.emplace_back(sfpi_root);
+    }
+    roots.push_back(source_root + "runtime/sfpi");
+    roots.push_back("/opt/tenstorrent/sfpi");
+    return roots;
+}
+

+// SPDX-FileCopyrightText: (c) 2026 Tenstorrent AI ULC
+// SPDX-License-Identifier: Apache-2.0
+
+#include <stdint.h>
+
+#include "api/dataflow/circular_buffer.h"
+#include "api/dataflow/dataflow_api.h"
+#include "api/dataflow/noc.h"
+
+namespace {
+
+FORCE_INLINE uint32_t tile_offset(uint32_t row, uint32_t column) {
+    const uint32_t face = (row / 16) * 2 + column / 16;
+    return face * 256 + (row % 16) * 16 + column % 16;
+}
+
+}  // namespace
+
+void kernel_main() {
+    constexpr uint32_t batch_size = get_compile_time_arg_val(0);
+    constexpr uint32_t pages_per_slice = get_compile_time_arg_val(1);
+    constexpr uint32_t num_workers = get_compile_time_arg_val(2);
+    constexpr uint32_t tile_bytes = get_compile_time_arg_val(3);
+
+    const uint32_t worker = get_arg_val<uint32_t>(0);
+    const uint32_t state_pool_address = get_arg_val<uint32_t>(1);
+    const uint32_t state_indices_address = get_arg_val<uint32_t>(2);
+    const uint32_t updates_address = get_arg_val<uint32_t>(3);
+
+    constexpr auto state_pool_args = TensorAccessorArgs<4>();
+    constexpr auto state_indices_args =
+        TensorAccessorArgs<state_pool_args.next_compile_time_args_offset()>();
+    constexpr auto updates_args =
+        TensorAccessorArgs<state_indices_args.next_compile_time_args_offset()>();
+    const auto state_pool =
+        TensorAccessor(state_pool_args, state_pool_address, tile_bytes);
+    const auto state_indices =
+        TensorAccessor(state_indices_args, state_indices_address, 4096);
+    const auto updates = TensorAccessor(updates_args, updates_address, tile_bytes);
+
+    CircularBuffer data_cb(tt::CBIndex::c_0);
+    CircularBuffer indices_cb(tt::CBIndex::c_1);
+    Noc noc;
+
+    indices_cb.reserve_back(1);
+    noc.async_read(
+        state_indices, indices_cb, 4096,
+        {.page_id = 0}, {.offset_bytes = 0});
+    noc.async_read_barrier();
+    indices_cb.push_back(1);
+    indices_cb.wait_front(1);
+    const volatile tt_l1_ptr uint32_t* index_tile =
+        reinterpret_cast<const volatile tt_l1_ptr uint32_t*>(
+            indices_cb.get_read_ptr());
+
+    const uint32_t total_pages = batch_size * pages_per_slice;
+    for (uint32_t work = worker; work < total_pages; work += num_workers) {
+        const uint32_t batch = work / pages_per_slice;
+        const uint32_t page = work % pages_per_slice;
+        const uint32_t slot = index_tile[tile_offset(0, batch)];
+        if (slot == 0) {
+            continue;
+        }
+
+        data_cb.reserve_back(1);
+        noc.async_read(
+            updates, data_cb, tile_bytes,
+            {.page_id = batch * pages_per_slice + page},
+            {.offset_bytes = 0});
+        noc.async_read_barrier();
+        data_cb.push_back(1);
+        data_cb.wait_front(1);
+        noc.async_write(
+            data_cb, state_pool, tile_bytes,
+            {.offset_bytes = 0},
+            {.page_id = slot * pages_per_slice + page});
+        noc.async_write_barrier();
+        data_cb.pop_front(1);
+    }
+    indices_cb.pop_front(1);
+}

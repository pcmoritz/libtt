 namespace detail {
 
+namespace {
+std::mutex profiler_optional_metadata_provider_mutex;
+ProfilerOptionalMetadataProvider profiler_optional_metadata_provider;
+}  // namespace
+
+void SetProfilerOptionalMetadataProvider(ProfilerOptionalMetadataProvider provider) {
+    std::scoped_lock<std::mutex> lock(profiler_optional_metadata_provider_mutex);
+    profiler_optional_metadata_provider = std::move(provider);
+}
+
+std::optional<ProfilerOptionalMetadata> GetProfilerOptionalMetadata() {
+    ProfilerOptionalMetadataProvider provider;
+    {
+        std::scoped_lock<std::mutex> lock(profiler_optional_metadata_provider_mutex);
+        provider = profiler_optional_metadata_provider;
+    }
+    return provider ? provider() : std::optional<ProfilerOptionalMetadata>{};
+}

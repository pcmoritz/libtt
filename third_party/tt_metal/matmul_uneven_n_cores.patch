diff --git ttnn/cpp/ttnn/operations/matmul/device/factory/matmul_multicore_program_factory.cpp ttnn/cpp/ttnn/operations/matmul/device/factory/matmul_multicore_program_factory.cpp
index 7d68dcf..bf12d29 100644
--- ttnn/cpp/ttnn/operations/matmul/device/factory/matmul_multicore_program_factory.cpp
+++ ttnn/cpp/ttnn/operations/matmul/device/factory/matmul_multicore_program_factory.cpp
@@ -465,4 +465,213 @@ ProgramDescriptor MatmulSwiGLUProgramFactory::create_descriptor(
     return desc;
 }

+ProgramDescriptor MatmulUnevenNProgramFactory::create_descriptor(
+    const ttnn::prim::MatmulParams& operation_attributes,
+    const ttnn::prim::MatmulInputs& tensor_args,
+    std::vector<ttnn::Tensor>& tensor_return_value,
+    const std::optional<CoreRangeSet>& /*core_range_set*/) {
+    const auto& a = tensor_args.input_tensors.at(0).mesh_tensor();
+    const auto& b = tensor_args.input_tensors.at(1).mesh_tensor();
+    const auto& addend = tensor_args.optional_input_tensors.at(0).value().mesh_tensor();
+    const auto& output = tensor_return_value.at(0).mesh_tensor();
+
+    constexpr uint32_t grid_x = 11;
+    constexpr uint32_t grid_y = 10;
+    constexpr uint32_t num_cores = grid_x * grid_y;
+    constexpr uint32_t in0_block_w = 4;
+    constexpr uint32_t wide_per_core_N = 2;
+
+    const uint32_t Kt = a.padded_shape()[-1] / TILE_WIDTH;
+    const uint32_t Nt = b.padded_shape()[-1] / TILE_WIDTH;
+    const uint32_t num_wide_cores = Nt - num_cores;
+    const uint32_t num_narrow_cores = num_cores - num_wide_cores;
+    const uint32_t num_blocks = Kt / in0_block_w;
+
+    TT_FATAL(Kt % in0_block_w == 0, "Uneven-N matmul K tiles must divide by the K block width");
+    TT_FATAL(Nt > num_cores && Nt < 2 * num_cores,
+             "Uneven-N matmul requires between one and two output tiles per worker");
+
+    const CoreCoord grid_size(grid_x, grid_y);
+    const auto all_cores = tt::tt_metal::num_cores_to_corerangeset(num_cores, grid_size, true);
+    const auto wide_cores = tt::tt_metal::num_cores_to_corerangeset(num_wide_cores, grid_size, true);
+    const CoreCoord narrow_start(num_wide_cores % grid_x, num_wide_cores / grid_x);
+    const auto narrow_cores =
+        tt::tt_metal::num_cores_to_corerangeset(narrow_start, num_narrow_cores, grid_size, true);
+    const auto in0_format = tt_metal::datatype_to_dataformat_converter(a.dtype());
+    const auto in1_format = tt_metal::datatype_to_dataformat_converter(b.dtype());
+    const auto output_format = tt_metal::datatype_to_dataformat_converter(output.dtype());
+    const uint32_t in0_tile_size = tt::tile_size(in0_format);
+    const uint32_t in1_tile_size = tt::tile_size(in1_format);
+    const uint32_t output_tile_size = tt::tile_size(output_format);
+
+    TT_FATAL(operation_attributes.compute_kernel_config.has_value(), "Uneven-N matmul compute config is required");
+    auto [math_fidelity, math_approx_mode, fp32_dest_acc_en, packer_l1_acc, dst_full_sync_en] =
+        get_compute_kernel_config_args(a.mutable_device().arch(), operation_attributes.compute_kernel_config.value());
+    const auto partial_format = fp32_dest_acc_en ? tt::DataFormat::Float32 : output_format;
+    const uint32_t partial_tile_size = tt::tile_size(partial_format);
+
+    ProgramDescriptor desc;
+    auto add_cb_on = [&](const CoreRangeSet& cores, uint32_t index, uint32_t tiles,
+                         tt::DataFormat format, uint32_t page_size) {
+        desc.cbs.push_back(CBDescriptor{
+            .total_size = tiles * page_size,
+            .core_ranges = cores,
+            .format_descriptors = {{CBFormatDescriptor{
+                .buffer_index = index,
+                .data_format = format,
+                .page_size = page_size,
+            }}},
+        });
+    };
+    auto add_cb = [&](uint32_t index, uint32_t tiles, tt::DataFormat format, uint32_t page_size) {
+        add_cb_on(all_cores, index, tiles, format, page_size);
+    };
+    add_cb(tt::CBIndex::c_0, 2 * in0_block_w, in0_format, in0_tile_size);
+    add_cb(tt::CBIndex::c_1, 2 * in0_block_w * wide_per_core_N, in1_format, in1_tile_size);
+    add_cb(tt::CBIndex::c_2, wide_per_core_N, output_format, output_tile_size);
+    add_cb_on(wide_cores, tt::CBIndex::c_3, wide_per_core_N, partial_format, partial_tile_size);
+    add_cb_on(narrow_cores, tt::CBIndex::c_3, 1, partial_format, partial_tile_size);
+    add_cb(tt::CBIndex::c_16, wide_per_core_N, output_format, output_tile_size);
+
+    constexpr uint32_t sender_sem_id = 0;
+    constexpr uint32_t receiver_sem_id = 1;
+    const CoreCoord sender_core(0, 0);
+    const CoreRangeSet sender_cores(CoreRange(sender_core, sender_core));
+    const auto receiver_cores =
+        tt::tt_metal::num_cores_to_corerangeset(CoreCoord(1, 0), num_cores - 1, grid_size, true);
+    auto* device = &a.mutable_device();
+    const auto sender_physical = device->worker_core_from_logical_core(sender_core);
+    auto mcast_start = device->worker_core_from_logical_core(CoreCoord(0, 0));
+    auto mcast_end = device->worker_core_from_logical_core(CoreCoord(grid_x - 1, grid_y - 1));
+    const auto in0_noc = tt::tt_metal::detail::preferred_noc_for_dram_write(device->arch());
+    const auto in1_noc = tt::tt_metal::detail::preferred_noc_for_dram_read(device->arch());
+    if (in0_noc == tt::tt_metal::NOC::NOC_1) {
+        std::swap(mcast_start, mcast_end);
+    }
+
+    std::vector<uint32_t> in0_sender_compile_args;
+    tt::tt_metal::TensorAccessorArgs(a).append_to(in0_sender_compile_args);
+    KernelDescriptor in0_sender_desc;
+    in0_sender_desc.kernel_source =
+        "ttnn/cpp/ttnn/operations/matmul/device/kernels/dataflow/reader_matmul_swiglu_in0_sender.cpp";
+    in0_sender_desc.source_type = KernelDescriptor::SourceType::FILE_PATH;
+    in0_sender_desc.core_ranges = sender_cores;
+    in0_sender_desc.compile_time_args = in0_sender_compile_args;
+    in0_sender_desc.named_compile_time_args = {
+        {"cb_in0", tt::CBIndex::c_0},
+        {"Kt", Kt},
+        {"in0_mcast_w", in0_block_w},
+        {"num_dests", num_cores - 1},
+        {"sender_sem", sender_sem_id},
+        {"receiver_sem", receiver_sem_id},
+    };
+    in0_sender_desc.config = tt::tt_metal::DataMovementConfigDescriptor{
+        .processor = tt_metal::DataMovementProcessor::RISCV_1, .noc = in0_noc};
+    in0_sender_desc.emplace_runtime_args(
+        sender_core,
+        {a,
+         static_cast<uint32_t>(mcast_start.x),
+         static_cast<uint32_t>(mcast_start.y),
+         static_cast<uint32_t>(mcast_end.x),
+         static_cast<uint32_t>(mcast_end.y)});
+
+    KernelDescriptor in0_receiver_desc;
+    in0_receiver_desc.kernel_source =
+        "ttnn/cpp/ttnn/operations/matmul/device/kernels/dataflow/reader_matmul_swiglu_in0_receiver.cpp";
+    in0_receiver_desc.source_type = KernelDescriptor::SourceType::FILE_PATH;
+    in0_receiver_desc.core_ranges = receiver_cores;
+    in0_receiver_desc.named_compile_time_args = {
+        {"cb_in0", tt::CBIndex::c_0},
+        {"Kt", Kt},
+        {"in0_mcast_w", in0_block_w},
+        {"sender_sem", sender_sem_id},
+        {"receiver_sem", receiver_sem_id},
+    };
+    in0_receiver_desc.config = tt::tt_metal::DataMovementConfigDescriptor{
+        .processor = tt_metal::DataMovementProcessor::RISCV_1, .noc = in0_noc};
+
+    std::vector<uint32_t> reader_compile_time_args;
+    tt::tt_metal::TensorAccessorArgs(b).append_to(reader_compile_time_args);
+    tt::tt_metal::TensorAccessorArgs(addend).append_to(reader_compile_time_args);
+    tt::tt_metal::TensorAccessorArgs(output).append_to(reader_compile_time_args);
+    auto make_reader_desc = [&](const CoreRangeSet& cores, uint32_t per_core_N) {
+        KernelDescriptor reader_desc;
+        reader_desc.kernel_source =
+            "ttnn/cpp/ttnn/operations/matmul/device/kernels/dataflow/reader_matmul_uneven_n.cpp";
+        reader_desc.source_type = KernelDescriptor::SourceType::FILE_PATH;
+        reader_desc.core_ranges = cores;
+        reader_desc.compile_time_args = reader_compile_time_args;
+        reader_desc.named_compile_time_args = {
+            {"cb_weights", tt::CBIndex::c_1},
+            {"cb_addend", tt::CBIndex::c_2},
+            {"cb_out", tt::CBIndex::c_16},
+            {"Kt", Kt},
+            {"Nt", Nt},
+            {"per_core_N", per_core_N},
+            {"in0_block_w", in0_block_w},
+        };
+        reader_desc.config = tt::tt_metal::DataMovementConfigDescriptor{
+            .processor = tt_metal::DataMovementProcessor::RISCV_0, .noc = in1_noc};
+        return reader_desc;
+    };
+    auto wide_reader_desc = make_reader_desc(wide_cores, wide_per_core_N);
+    auto narrow_reader_desc = make_reader_desc(narrow_cores, 1);
+
+    for (uint32_t i = 0; i < num_cores; ++i) {
+        const CoreCoord core{i % grid_x, i / grid_x};
+        const uint32_t n_start = i < num_wide_cores ? wide_per_core_N * i : i + num_wide_cores;
+        auto& reader_desc = i < num_wide_cores ? wide_reader_desc : narrow_reader_desc;
+        reader_desc.emplace_runtime_args(core, {b, addend, output, n_start});
+        if (core != sender_core) {
+            in0_receiver_desc.emplace_runtime_args(
+                core,
+                {static_cast<uint32_t>(sender_physical.x), static_cast<uint32_t>(sender_physical.y)});
+        }
+    }
+
+    auto make_compute_desc = [&](const CoreRangeSet& cores, uint32_t per_core_N) {
+        KernelDescriptor compute_desc;
+        compute_desc.kernel_source =
+            "ttnn/cpp/ttnn/operations/matmul/device/kernels/compute/matmul_uneven_n.cpp";
+        compute_desc.source_type = KernelDescriptor::SourceType::FILE_PATH;
+        compute_desc.core_ranges = cores;
+        compute_desc.compile_time_args = {
+            in0_block_w,
+            in0_block_w,
+            in0_block_w * per_core_N,
+            per_core_N,
+            num_blocks,
+        };
+        compute_desc.named_compile_time_args = {
+            {"cb_in0", tt::CBIndex::c_0},
+            {"cb_weights", tt::CBIndex::c_1},
+            {"cb_addend", tt::CBIndex::c_2},
+            {"cb_partials", tt::CBIndex::c_3},
+            {"cb_out", tt::CBIndex::c_16},
+        };
+        compute_desc.defines = {{"PACKER_L1_ACC", "1"}};
+        if (fp32_dest_acc_en) {
+            compute_desc.defines.emplace_back("FP32_DEST_ACC_EN", "1");
+        }
+        compute_desc.config = ComputeConfigDescriptor{
+            .math_fidelity = math_fidelity,
+            .fp32_dest_acc_en = fp32_dest_acc_en,
+            .dst_full_sync_en = dst_full_sync_en,
+            .math_approx_mode = math_approx_mode};
+        return compute_desc;
+    };
+
+    desc.semaphores.push_back(tt::tt_metal::SemaphoreDescriptor{
+        .id = sender_sem_id, .core_ranges = all_cores, .initial_value = 0});
+    desc.semaphores.push_back(tt::tt_metal::SemaphoreDescriptor{
+        .id = receiver_sem_id, .core_ranges = all_cores, .initial_value = 0});
+    desc.kernels.push_back(std::move(in0_sender_desc));
+    desc.kernels.push_back(std::move(in0_receiver_desc));
+    desc.kernels.push_back(std::move(wide_reader_desc));
+    desc.kernels.push_back(std::move(narrow_reader_desc));
+    desc.kernels.push_back(make_compute_desc(wide_cores, wide_per_core_N));
+    desc.kernels.push_back(make_compute_desc(narrow_cores, 1));
+    return desc;
+}
+
 }  // namespace ttnn::prim

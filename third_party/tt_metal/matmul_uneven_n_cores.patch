new file mode 100644
index 0000000..a2dab67
--- /dev/null
+++ ttnn/cpp/ttnn/operations/matmul/device/kernels/compute/matmul_uneven_n.cpp
@@ -0,0 +1,94 @@
+// SPDX-FileCopyrightText: © 2026 Tenstorrent USA, Inc.
+// SPDX-License-Identifier: Apache-2.0
+
+#include <cstdint>
+#include "api/compute/compute_kernel_hw_startup.h"
+#include "api/compute/eltwise_binary.h"
+#include "api/compute/matmul.h"
+#include "api/compute/tile_move_copy.h"
+#include "api/dataflow/circular_buffer.h"
+#include "api/compute/compute_kernel_api.h"
+
+namespace {
+
+template <uint32_t in0_block_w, uint32_t in0_block_tiles,
+          uint32_t in1_block_tiles, uint32_t per_core_N,
+          uint32_t num_blocks>
+FORCE_INLINE void uneven_n_matmul(
+    uint32_t cb_in0, uint32_t cb_weights, uint32_t cb_addend,
+    uint32_t cb_partials, uint32_t cb_out) {
+    PACK((pack_reconfig_data_format(cb_partials)));
+    PACK((llk_pack_reconfig_l1_acc(0)));
+
+    for (uint32_t block = 0; block < num_blocks; ++block) {
+        cb_reserve_back(cb_partials, per_core_N);
+        tile_regs_acquire();
+        cb_wait_front(cb_in0, in0_block_tiles);
+        cb_wait_front(cb_weights, in1_block_tiles);
+        for (uint32_t k = 0; k < in0_block_w; ++k) {
+            matmul_block(
+                cb_in0, cb_weights, k, k * per_core_N, 0,
+                /*transpose=*/0, per_core_N, 1, in0_block_w);
+        }
+        cb_pop_front(cb_in0, in0_block_tiles);
+        cb_pop_front(cb_weights, in1_block_tiles);
+        tile_regs_commit();
+        tile_regs_wait();
+        for (uint32_t i = 0; i < per_core_N; ++i) {
+            pack_tile(i, cb_partials);
+        }
+        tile_regs_release();
+        cb_push_back(cb_partials, per_core_N);
+
+        if (block == 0) {
+            PACK((llk_pack_reconfig_l1_acc(1)));
+        }
+        if (block + 1 < num_blocks) {
+            cb_wait_front(cb_partials, per_core_N);
+            cb_pop_front(cb_partials, per_core_N);
+        }
+    }
+
+    PACK((llk_pack_reconfig_l1_acc(0)));
+    PACK((pack_reconfig_data_format(cb_out)));
+    reconfig_data_format(cb_weights, cb_partials, cb_in0, cb_addend);
+    add_tiles_init(cb_partials, cb_addend);
+    cb_wait_front(cb_partials, per_core_N);
+    cb_wait_front(cb_addend, per_core_N);
+    tile_regs_acquire();
+    for (uint32_t i = 0; i < per_core_N; ++i) {
+        add_tiles(cb_partials, cb_addend, i, i, i);
+    }
+    cb_pop_front(cb_partials, per_core_N);
+    cb_pop_front(cb_addend, per_core_N);
+    tile_regs_commit();
+    tile_regs_wait();
+    cb_reserve_back(cb_out, per_core_N);
+    for (uint32_t i = 0; i < per_core_N; ++i) {
+        pack_tile(i, cb_out);
+    }
+    cb_push_back(cb_out, per_core_N);
+    tile_regs_release();
+}
+
+}  // namespace
+
+void kernel_main() {
+    constexpr uint32_t in0_block_w = get_compile_time_arg_val(0);
+    constexpr uint32_t in0_block_tiles = get_compile_time_arg_val(1);
+    constexpr uint32_t in1_block_tiles = get_compile_time_arg_val(2);
+    constexpr uint32_t per_core_N = get_compile_time_arg_val(3);
+    constexpr uint32_t num_blocks = get_compile_time_arg_val(4);
+
+    constexpr uint32_t cb_in0 = get_named_compile_time_arg_val("cb_in0");
+    constexpr uint32_t cb_weights = get_named_compile_time_arg_val("cb_weights");
+    constexpr uint32_t cb_addend = get_named_compile_time_arg_val("cb_addend");
+    constexpr uint32_t cb_partials = get_named_compile_time_arg_val("cb_partials");
+    constexpr uint32_t cb_out = get_named_compile_time_arg_val("cb_out");
+
+    compute_kernel_hw_startup<SrcOrder::Reverse>(cb_in0, cb_weights, cb_out);
+    matmul_block_init(cb_in0, cb_weights, 0, per_core_N, 1, in0_block_w);
+    uneven_n_matmul<in0_block_w, in0_block_tiles, in1_block_tiles,
+                    per_core_N, num_blocks>(
+        cb_in0, cb_weights, cb_addend, cb_partials, cb_out);
+}
diff --git ttnn/cpp/ttnn/operations/matmul/device/kernels/dataflow/reader_matmul_uneven_n.cpp ttnn/cpp/ttnn/operations/matmul/device/kernels/dataflow/reader_matmul_uneven_n.cpp
new file mode 100644
index 0000000..ca1df85
--- /dev/null
+++ ttnn/cpp/ttnn/operations/matmul/device/kernels/dataflow/reader_matmul_uneven_n.cpp
@@ -0,0 +1,64 @@
+// SPDX-FileCopyrightText: © 2026 Tenstorrent USA, Inc.
+// SPDX-License-Identifier: Apache-2.0
+
+#include <cstdint>
+#include "api/dataflow/dataflow_api.h"
+#include "api/dataflow/noc.h"
+#include "api/dataflow/circular_buffer.h"
+
+void kernel_main() {
+    const uint32_t weight_addr = get_arg_val<uint32_t>(0);
+    const uint32_t addend_addr = get_arg_val<uint32_t>(1);
+    const uint32_t output_addr = get_arg_val<uint32_t>(2);
+    const uint32_t n_start = get_arg_val<uint32_t>(3);
+
+    constexpr uint32_t cb_weights = get_named_compile_time_arg_val("cb_weights");
+    constexpr uint32_t cb_addend = get_named_compile_time_arg_val("cb_addend");
+    constexpr uint32_t cb_out = get_named_compile_time_arg_val("cb_out");
+    constexpr uint32_t Kt = get_named_compile_time_arg_val("Kt");
+    constexpr uint32_t Nt = get_named_compile_time_arg_val("Nt");
+    constexpr uint32_t per_core_N = get_named_compile_time_arg_val("per_core_N");
+    constexpr uint32_t in0_block_w = get_named_compile_time_arg_val("in0_block_w");
+    constexpr uint32_t in1_block_tiles = in0_block_w * per_core_N;
+
+    constexpr auto weight_args = TensorAccessorArgs<0>();
+    constexpr auto addend_args = TensorAccessorArgs<weight_args.next_compile_time_args_offset()>();
+    constexpr auto output_args = TensorAccessorArgs<addend_args.next_compile_time_args_offset()>();
+    const auto weight = TensorAccessor(weight_args, weight_addr);
+    const auto addend = TensorAccessor(addend_args, addend_addr);
+    const auto output = TensorAccessor(output_args, output_addr);
+
+    for (uint32_t k0 = 0; k0 < Kt; k0 += in0_block_w) {
+        cb_reserve_back(cb_weights, in1_block_tiles);
+        uint32_t weights_ptr = get_write_ptr(cb_weights);
+        for (uint32_t k = 0; k < in0_block_w; ++k) {
+            const uint32_t row = (k0 + k) * Nt + n_start;
+            for (uint32_t n = 0; n < per_core_N; ++n) {
+                const uint32_t local = (k * per_core_N + n) * get_tile_size(cb_weights);
+                noc_async_read_tile(row + n, weight, weights_ptr + local);
+            }
+        }
+        noc_async_read_barrier();
+        cb_push_back(cb_weights, in1_block_tiles);
+    }
+
+    cb_reserve_back(cb_addend, per_core_N);
+    uint32_t addend_ptr = get_write_ptr(cb_addend);
+    for (uint32_t n = 0; n < per_core_N; ++n) {
+        noc_async_read_tile(
+            n_start + n, addend, addend_ptr + n * get_tile_size(cb_addend));
+    }
+    noc_async_read_barrier();
+    cb_push_back(cb_addend, per_core_N);
+
+    Noc noc;
+    CircularBuffer out_cb(cb_out);
+    const uint32_t page_bytes = get_local_cb_interface(cb_out).fifo_page_size;
+    for (uint32_t n = 0; n < per_core_N; ++n) {
+        out_cb.wait_front(1);
+        noc.async_write(out_cb, output, page_bytes, {}, {.page_id = n_start + n});
+        noc.async_writes_flushed();
+        out_cb.pop_front(1);
+    }
+    noc.async_write_barrier();
+}

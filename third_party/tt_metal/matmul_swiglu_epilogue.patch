diff --git ttnn/cpp/ttnn/operations/matmul/device/kernels/compute/matmul_swiglu.cpp ttnn/cpp/ttnn/operations/matmul/device/kernels/compute/matmul_swiglu.cpp
new file mode 100644
index 0000000..3f1946a
--- /dev/null
+++ ttnn/cpp/ttnn/operations/matmul/device/kernels/compute/matmul_swiglu.cpp
@@ -0,0 +1,110 @@
+// SPDX-FileCopyrightText: © 2026 Tenstorrent USA, Inc.
+// SPDX-License-Identifier: Apache-2.0
+
+#include <cstdint>
+#include "api/compute/compute_kernel_hw_startup.h"
+#include "api/compute/eltwise_binary_sfpu.h"
+#include "api/compute/matmul.h"
+#include "api/compute/tile_move_copy.h"
+#include "api/dataflow/circular_buffer.h"
+#include "api/compute/compute_kernel_api.h"
+
+namespace {
+
+template <uint32_t in0_block_w, uint32_t in0_block_tiles,
+          uint32_t in1_block_tiles, uint32_t per_core_N,
+          uint32_t num_blocks>
+FORCE_INLINE void dst_resident_swiglu(
+    uint32_t cb_in0, uint32_t cb_weights, uint32_t cb_partials, uint32_t cb_out) {
+    constexpr uint32_t combined_per_core_N = 2 * per_core_N;
+    constexpr uint32_t out_subblock_w = 2;
+    static_assert(combined_per_core_N == 8, "gate and up must exactly fill DST");
+
+    PACK((pack_reconfig_data_format(cb_partials)));
+    PACK((llk_pack_reconfig_l1_acc(0)));
+
+    // Accumulate each K block in all eight DST tiles, then fold the block into
+    // the same L1 partial slots. This preserves the validated BF16 reduction
+    // order while reducing register synchronization to once per K block.
+    for (uint32_t block = 0; block < num_blocks; ++block) {
+        cb_reserve_back(cb_partials, combined_per_core_N);
+        tile_regs_acquire();
+        cb_wait_front(cb_in0, in0_block_tiles);
+        cb_wait_front(cb_weights, in1_block_tiles);
+        for (uint32_t k = 0; k < in0_block_w; ++k) {
+            for (uint32_t sb = 0; sb < combined_per_core_N / out_subblock_w; ++sb) {
+                const uint32_t offset = sb * out_subblock_w;
+                matmul_block(
+                    cb_in0, cb_weights, k, k * combined_per_core_N + offset, offset,
+                    /*transpose=*/0, out_subblock_w, 1, in0_block_w);
+            }
+        }
+        cb_pop_front(cb_in0, in0_block_tiles);
+        cb_pop_front(cb_weights, in1_block_tiles);
+        tile_regs_commit();
+        tile_regs_wait();
+        for (uint32_t i = 0; i < combined_per_core_N; ++i) {
+            pack_tile(i, cb_partials);
+        }
+        tile_regs_release();
+        cb_push_back(cb_partials, combined_per_core_N);
+
+        if (block == 0) {
+            PACK((llk_pack_reconfig_l1_acc(1)));
+        }
+        if (block + 1 < num_blocks) {
+            cb_wait_front(cb_partials, combined_per_core_N);
+            cb_pop_front(cb_partials, combined_per_core_N);
+        }
+    }
+
+    // Reload the final gate/up values together and apply silu(gate) * up in
+    // DST. Gate occupies DST[0..3], up occupies DST[4..7].
+    PACK((llk_pack_reconfig_l1_acc(0)));
+    PACK((pack_reconfig_data_format(cb_out)));
+    copy_tile_to_dst_init_short_with_dt(cb_weights, cb_partials);
+    cb_wait_front(cb_partials, combined_per_core_N);
+    tile_regs_acquire();
+    for (uint32_t i = 0; i < combined_per_core_N; ++i) {
+        copy_tile(cb_partials, i, i);
+    }
+    cb_pop_front(cb_partials, combined_per_core_N);
+    silu_tile_init();
+    for (uint32_t i = 0; i < per_core_N; ++i) {
+        silu_tile(i);
+    }
+    mul_binary_tile_init();
+    for (uint32_t i = 0; i < per_core_N; ++i) {
+        mul_binary_tile(i, per_core_N + i, i);
+    }
+
+    tile_regs_commit();
+    tile_regs_wait();
+    cb_reserve_back(cb_out, per_core_N);
+    for (uint32_t i = 0; i < per_core_N; ++i) {
+        pack_tile(i, cb_out);
+    }
+    cb_push_back(cb_out, per_core_N);
+    tile_regs_release();
+}
+
+}  // namespace
+
+void kernel_main() {
+    constexpr uint32_t in0_block_w = get_compile_time_arg_val(0);
+    constexpr uint32_t in0_block_tiles = get_compile_time_arg_val(1);
+    constexpr uint32_t in1_block_tiles = get_compile_time_arg_val(2);
+    constexpr uint32_t per_core_N = get_compile_time_arg_val(3);
+    constexpr uint32_t num_blocks = get_compile_time_arg_val(4);
+
+    constexpr uint32_t cb_in0 = get_named_compile_time_arg_val("cb_in0");
+    constexpr uint32_t cb_weights = get_named_compile_time_arg_val("cb_weights");
+    constexpr uint32_t cb_partials = get_named_compile_time_arg_val("cb_partials");
+    constexpr uint32_t cb_out = get_named_compile_time_arg_val("cb_out");
+
+    constexpr uint32_t combined_per_core_N = 2 * per_core_N;
+    compute_kernel_hw_startup<SrcOrder::Reverse>(cb_in0, cb_weights, cb_out);
+    matmul_block_init(cb_in0, cb_weights, 0, 2, 1, in0_block_w);
+    dst_resident_swiglu<in0_block_w, in0_block_tiles, in1_block_tiles,
+                        per_core_N, num_blocks>(cb_in0, cb_weights, cb_partials, cb_out);
+}
diff --git ttnn/cpp/ttnn/operations/matmul/device/kernels/dataflow/reader_matmul_swiglu.cpp ttnn/cpp/ttnn/operations/matmul/device/kernels/dataflow/reader_matmul_swiglu.cpp

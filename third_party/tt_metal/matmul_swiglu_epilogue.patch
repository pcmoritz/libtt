diff --git ttnn/cpp/ttnn/operations/matmul/device/factory/matmul_multicore_program_factory.cpp ttnn/cpp/ttnn/operations/matmul/device/factory/matmul_multicore_program_factory.cpp
index 8affb04..7d68dcf 100644
--- ttnn/cpp/ttnn/operations/matmul/device/factory/matmul_multicore_program_factory.cpp
+++ ttnn/cpp/ttnn/operations/matmul/device/factory/matmul_multicore_program_factory.cpp
@@ -241,4 +241,218 @@ ProgramDescriptor MatmulMultiCoreProgramFactory::create_descriptor(
     return desc;
 }
 
+ProgramDescriptor MatmulSwiGLUProgramFactory::create_descriptor(
+    const ttnn::prim::MatmulParams& operation_attributes,
+    const ttnn::prim::MatmulInputs& tensor_args,
+    std::vector<ttnn::Tensor>& tensor_return_value,
+    const std::optional<CoreRangeSet>& /*core_range_set*/) {
+    const auto& a = tensor_args.input_tensors.at(0).mesh_tensor();
+    const auto& b = tensor_args.input_tensors.at(1).mesh_tensor();
+    const auto& output = tensor_return_value.at(0).mesh_tensor();
+
+    constexpr uint32_t grid_x = 11;
+    constexpr uint32_t num_cores = 96;
+    constexpr uint32_t group0_y = 8;
+    constexpr uint32_t group1_x = 8;
+    constexpr uint32_t in0_block_w = 2;
+    constexpr uint32_t in0_mcast_w = 2;
+
+    const uint32_t Kt = a.padded_shape()[-1] / TILE_WIDTH;
+    const uint32_t fused_Nt = b.padded_shape()[-1] / TILE_WIDTH;
+    const uint32_t half_Nt = fused_Nt / 2;
+    const uint32_t per_core_N = half_Nt / num_cores;
+    const uint32_t combined_per_core_N = 2 * per_core_N;
+    const uint32_t num_blocks = Kt / in0_block_w;
+    const uint32_t in1_block_num_tiles = in0_block_w * combined_per_core_N;
+
+    TT_FATAL(half_Nt % num_cores == 0, "SwiGLU output tiles must divide across 96 cores");
+    TT_FATAL(Kt % in0_block_w == 0, "SwiGLU K tiles must divide by the K block width");
+    TT_FATAL(Kt % in0_mcast_w == 0, "SwiGLU K tiles must divide by the multicast width");
+    TT_FATAL(combined_per_core_N == 8, "SwiGLU gate and up outputs must exactly fill the 8-tile DST");
+
+    const CoreRangeSet all_cores(std::vector<CoreRange>{
+        CoreRange(CoreCoord(0, 0), CoreCoord(grid_x - 1, group0_y - 1)),
+        CoreRange(CoreCoord(0, group0_y), CoreCoord(group1_x - 1, group0_y)),
+    });
+    const auto in0_format = tt_metal::datatype_to_dataformat_converter(a.dtype());
+    const auto in1_format = tt_metal::datatype_to_dataformat_converter(b.dtype());
+    const auto output_format = tt_metal::datatype_to_dataformat_converter(output.dtype());
+    const uint32_t in0_tile_size = tt::tile_size(in0_format);
+    const uint32_t in1_tile_size = tt::tile_size(in1_format);
+    const uint32_t output_tile_size = tt::tile_size(output_format);
+
+    ProgramDescriptor desc;
+    auto add_cb = [&](uint32_t index, uint32_t tiles, tt::DataFormat format, uint32_t page_size) {
+        desc.cbs.push_back(CBDescriptor{
+            .total_size = tiles * page_size,
+            .core_ranges = all_cores,
+            .format_descriptors = {{CBFormatDescriptor{
+                .buffer_index = index,
+                .data_format = format,
+                .page_size = page_size,
+            }}},
+        });
+    };
+    add_cb(tt::CBIndex::c_0, 2 * in0_mcast_w, in0_format, in0_tile_size);
+    add_cb(tt::CBIndex::c_1, 2 * in1_block_num_tiles, in1_format, in1_tile_size);
+    add_cb(tt::CBIndex::c_3, combined_per_core_N, output_format, output_tile_size);
+    add_cb(tt::CBIndex::c_16, per_core_N, output_format, output_tile_size);
+
+    constexpr uint32_t sender_sem_id = 0;
+    constexpr uint32_t receiver_sem_id = 1;
+    const CoreCoord sender_core0(0, 0);
+    const CoreCoord sender_core1(0, group0_y);
+    const CoreRangeSet sender_cores0(CoreRange(sender_core0, sender_core0));
+    const CoreRangeSet sender_cores1(CoreRange(sender_core1, sender_core1));
+    const CoreRangeSet receiver_cores(std::vector<CoreRange>{
+        CoreRange(CoreCoord(1, 0), CoreCoord(grid_x - 1, 0)),
+        CoreRange(CoreCoord(0, 1), CoreCoord(grid_x - 1, group0_y - 1)),
+        CoreRange(CoreCoord(1, group0_y), CoreCoord(group1_x - 1, group0_y)),
+    });
+    auto* device = &a.mutable_device();
+    const auto sender_physical0 = device->worker_core_from_logical_core(sender_core0);
+    const auto sender_physical1 = device->worker_core_from_logical_core(sender_core1);
+    auto mcast_start0 = device->worker_core_from_logical_core(CoreCoord(0, 0));
+    auto mcast_end0 = device->worker_core_from_logical_core(CoreCoord(grid_x - 1, group0_y - 1));
+    auto mcast_start1 = device->worker_core_from_logical_core(CoreCoord(0, group0_y));
+    auto mcast_end1 = device->worker_core_from_logical_core(CoreCoord(group1_x - 1, group0_y));
+    const auto in0_noc = tt::tt_metal::detail::preferred_noc_for_dram_write(device->arch());
+    const auto in1_noc = tt::tt_metal::detail::preferred_noc_for_dram_read(device->arch());
+    if (in0_noc == tt::tt_metal::NOC::NOC_1) {
+        auto tmp = mcast_start0;
+        mcast_start0 = mcast_end0;
+        mcast_end0 = tmp;
+        tmp = mcast_start1;
+        mcast_start1 = mcast_end1;
+        mcast_end1 = tmp;
+    }
+
+    std::vector<uint32_t> in0_sender_compile_args;
+    tt::tt_metal::TensorAccessorArgs(a).append_to(in0_sender_compile_args);
+    auto make_sender_desc = [&](const CoreRangeSet& sender_cores, uint32_t num_dests) {
+        KernelDescriptor sender_desc;
+        sender_desc.kernel_source =
+            "ttnn/cpp/ttnn/operations/matmul/device/kernels/dataflow/reader_matmul_swiglu_in0_sender.cpp";
+        sender_desc.source_type = KernelDescriptor::SourceType::FILE_PATH;
+        sender_desc.core_ranges = sender_cores;
+        sender_desc.compile_time_args = in0_sender_compile_args;
+        sender_desc.named_compile_time_args = {
+            {"cb_in0", tt::CBIndex::c_0},
+            {"Kt", Kt},
+            {"in0_mcast_w", in0_mcast_w},
+            {"num_dests", num_dests},
+            {"sender_sem", sender_sem_id},
+            {"receiver_sem", receiver_sem_id},
+        };
+        sender_desc.config = tt::tt_metal::DataMovementConfigDescriptor{
+            .processor = tt_metal::DataMovementProcessor::RISCV_1, .noc = in0_noc};
+        return sender_desc;
+    };
+    auto in0_sender_desc0 = make_sender_desc(sender_cores0, grid_x * group0_y - 1);
+    auto in0_sender_desc1 = make_sender_desc(sender_cores1, group1_x - 1);
+    in0_sender_desc0.emplace_runtime_args(
+        sender_core0,
+        {a,
+         static_cast<uint32_t>(mcast_start0.x),
+         static_cast<uint32_t>(mcast_start0.y),
+         static_cast<uint32_t>(mcast_end0.x),
+         static_cast<uint32_t>(mcast_end0.y)});
+    in0_sender_desc1.emplace_runtime_args(
+        sender_core1,
+        {a,
+         static_cast<uint32_t>(mcast_start1.x),
+         static_cast<uint32_t>(mcast_start1.y),
+         static_cast<uint32_t>(mcast_end1.x),
+         static_cast<uint32_t>(mcast_end1.y)});
+
+    KernelDescriptor in0_receiver_desc;
+    in0_receiver_desc.kernel_source =
+        "ttnn/cpp/ttnn/operations/matmul/device/kernels/dataflow/reader_matmul_swiglu_in0_receiver.cpp";
+    in0_receiver_desc.source_type = KernelDescriptor::SourceType::FILE_PATH;
+    in0_receiver_desc.core_ranges = receiver_cores;
+    in0_receiver_desc.named_compile_time_args = {
+        {"cb_in0", tt::CBIndex::c_0},
+        {"Kt", Kt},
+        {"in0_mcast_w", in0_mcast_w},
+        {"sender_sem", sender_sem_id},
+        {"receiver_sem", receiver_sem_id},
+    };
+    in0_receiver_desc.config = tt::tt_metal::DataMovementConfigDescriptor{
+        .processor = tt_metal::DataMovementProcessor::RISCV_1, .noc = in0_noc};
+
+    std::vector<uint32_t> reader_compile_time_args;
+    tt::tt_metal::TensorAccessorArgs(b).append_to(reader_compile_time_args);
+    tt::tt_metal::TensorAccessorArgs(output).append_to(reader_compile_time_args);
+    KernelDescriptor reader_desc;
+    reader_desc.kernel_source =
+        "ttnn/cpp/ttnn/operations/matmul/device/kernels/dataflow/reader_matmul_swiglu.cpp";
+    reader_desc.source_type = KernelDescriptor::SourceType::FILE_PATH;
+    reader_desc.core_ranges = all_cores;
+    reader_desc.compile_time_args = reader_compile_time_args;
+    reader_desc.named_compile_time_args = {
+        {"cb_weights", tt::CBIndex::c_1},
+        {"cb_out", tt::CBIndex::c_16},
+        {"Kt", Kt},
+        {"half_Nt", half_Nt},
+        {"per_core_N", per_core_N},
+        {"in0_block_w", in0_block_w},
+    };
+    reader_desc.config = tt::tt_metal::DataMovementConfigDescriptor{
+        .processor = tt_metal::DataMovementProcessor::RISCV_0, .noc = in1_noc};
+
+    for (uint32_t i = 0; i < num_cores; ++i) {
+        CoreCoord core{i % grid_x, i / grid_x};
+        reader_desc.emplace_runtime_args(core, {b, output, i});
+        const bool group0 = core.y < group0_y;
+        const auto group_sender = group0 ? sender_core0 : sender_core1;
+        const auto group_sender_physical = group0 ? sender_physical0 : sender_physical1;
+        if (core != group_sender) {
+            in0_receiver_desc.emplace_runtime_args(
+                core,
+                {static_cast<uint32_t>(group_sender_physical.x),
+                 static_cast<uint32_t>(group_sender_physical.y)});
+        }
+    }
+    desc.semaphores.push_back(tt::tt_metal::SemaphoreDescriptor{
+        .id = sender_sem_id, .core_ranges = all_cores, .initial_value = 0});
+    desc.semaphores.push_back(tt::tt_metal::SemaphoreDescriptor{
+        .id = receiver_sem_id, .core_ranges = all_cores, .initial_value = 0});
+    desc.kernels.push_back(std::move(in0_sender_desc0));
+    desc.kernels.push_back(std::move(in0_sender_desc1));
+    desc.kernels.push_back(std::move(in0_receiver_desc));
+    desc.kernels.push_back(std::move(reader_desc));
+
+    TT_FATAL(operation_attributes.compute_kernel_config.has_value(), "SwiGLU compute config is required");
+    auto [math_fidelity, math_approx_mode, fp32_dest_acc_en, packer_l1_acc, dst_full_sync_en] =
+        get_compute_kernel_config_args(a.mutable_device().arch(), operation_attributes.compute_kernel_config.value());
+    TT_FATAL(!fp32_dest_acc_en && packer_l1_acc, "SwiGLU requires BF16 packer-L1 accumulation");
+
+    KernelDescriptor compute_desc;
+    compute_desc.kernel_source =
+        "ttnn/cpp/ttnn/operations/matmul/device/kernels/compute/matmul_swiglu.cpp";
+    compute_desc.source_type = KernelDescriptor::SourceType::FILE_PATH;
+    compute_desc.core_ranges = all_cores;
+    compute_desc.compile_time_args = {
+        in0_block_w,
+        in0_block_w,
+        in1_block_num_tiles,
+        per_core_N,
+        num_blocks,
+    };
+    compute_desc.named_compile_time_args = {
+        {"cb_in0", tt::CBIndex::c_0},
+        {"cb_weights", tt::CBIndex::c_1},
+        {"cb_partials", tt::CBIndex::c_3},
+        {"cb_out", tt::CBIndex::c_16},
+    };
+    compute_desc.defines = {{"PACKER_L1_ACC", "1"}};
+    compute_desc.config = ComputeConfigDescriptor{
+        .math_fidelity = math_fidelity,
+        .fp32_dest_acc_en = false,
+        .dst_full_sync_en = dst_full_sync_en,
+        .math_approx_mode = math_approx_mode};
+    desc.kernels.push_back(std::move(compute_desc));
+    return desc;
+}
+
 }  // namespace ttnn::prim

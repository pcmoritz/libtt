+// SPDX-FileCopyrightText: © 2026 Tenstorrent USA, Inc.
+// SPDX-License-Identifier: Apache-2.0
+
+#include <cstdint>
+#include "api/dataflow/dataflow_api.h"
+#include "api/dataflow/noc.h"
+#include "api/dataflow/circular_buffer.h"
+#include "api/dataflow/noc_semaphore.h"
+#include "api/dataflow/endpoints.h"
+#include "api/core_local_mem.h"
+
+void kernel_main() {
+    const uint32_t input_addr = get_arg_val<uint32_t>(0);
+    const uint32_t dest_start_x = get_arg_val<uint32_t>(1);
+    const uint32_t dest_start_y = get_arg_val<uint32_t>(2);
+    const uint32_t dest_end_x = get_arg_val<uint32_t>(3);
+    const uint32_t dest_end_y = get_arg_val<uint32_t>(4);
+
+    constexpr uint32_t cb_in0_id = get_named_compile_time_arg_val("cb_in0");
+    constexpr uint32_t Kt = get_named_compile_time_arg_val("Kt");
+    constexpr uint32_t in0_mcast_w = get_named_compile_time_arg_val("in0_mcast_w");
+    constexpr uint32_t num_dests = get_named_compile_time_arg_val("num_dests");
+    constexpr uint32_t sender_sem_id = get_named_compile_time_arg_val("sender_sem");
+    constexpr uint32_t receiver_sem_id = get_named_compile_time_arg_val("receiver_sem");
+    constexpr auto input_args = TensorAccessorArgs<0>();
+
+    const auto input = TensorAccessor(input_args, input_addr);
+    Noc noc;
+    CircularBuffer cb_in0(cb_in0_id);
+    Semaphore<> sender_sem(sender_sem_id);
+    Semaphore<> receiver_sem(receiver_sem_id);
+    receiver_sem.set(VALID);
+    constexpr uint32_t block_bytes = in0_mcast_w * get_tile_size(cb_in0_id);
+
+    for (uint32_t k0 = 0; k0 < Kt; k0 += in0_mcast_w) {
+        cb_in0.reserve_back(in0_mcast_w);
+        const uint32_t write_ptr = cb_in0.get_write_ptr();
+        for (uint32_t k = 0; k < in0_mcast_w; ++k) {
+            noc_async_read_tile(k0 + k, input, write_ptr + k * get_tile_size(cb_in0_id));
+        }
+        noc.async_read_barrier();
+
+        sender_sem.wait(num_dests);
+        sender_sem.set(0);
+        MulticastEndpoint mcast_dst;
+        noc.async_write_multicast(
+            CoreLocalMem<uint32_t>(write_ptr), mcast_dst, block_bytes, num_dests, {},
+            {.noc_x_start = dest_start_x, .noc_y_start = dest_start_y,
+             .noc_x_end = dest_end_x, .noc_y_end = dest_end_y, .addr = write_ptr}, true);
+#ifdef ARCH_BLACKHOLE
+        noc.async_writes_flushed();
+#endif
+        receiver_sem.set_multicast(
+            noc, dest_start_x, dest_start_y, dest_end_x, dest_end_y, num_dests);
+        cb_in0.push_back(in0_mcast_w);
+    }
+}

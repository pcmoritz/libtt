index 0000000..2e8dc74
--- /dev/null
+++ ttnn/cpp/ttnn/operations/matmul/device/kernels/dataflow/reader_matmul_swiglu.cpp
@@ -0,0 +1,59 @@
+// SPDX-FileCopyrightText: © 2026 Tenstorrent USA, Inc.
+// SPDX-License-Identifier: Apache-2.0
+
+#include <cstdint>
+#include "api/dataflow/dataflow_api.h"
+#include "api/dataflow/noc.h"
+#include "api/dataflow/circular_buffer.h"
+
+void kernel_main() {
+    const uint32_t weight_addr = get_arg_val<uint32_t>(0);
+    const uint32_t output_addr = get_arg_val<uint32_t>(1);
+    const uint32_t core_n = get_arg_val<uint32_t>(2);
+
+    constexpr uint32_t cb_weights = get_named_compile_time_arg_val("cb_weights");
+    constexpr uint32_t cb_out = get_named_compile_time_arg_val("cb_out");
+    constexpr uint32_t Kt = get_named_compile_time_arg_val("Kt");
+    constexpr uint32_t half_Nt = get_named_compile_time_arg_val("half_Nt");
+    constexpr uint32_t per_core_N = get_named_compile_time_arg_val("per_core_N");
+    constexpr uint32_t in0_block_w = get_named_compile_time_arg_val("in0_block_w");
+    constexpr uint32_t fused_Nt = 2 * half_Nt;
+    constexpr uint32_t combined_per_core_N = 2 * per_core_N;
+    constexpr uint32_t in1_block_tiles = in0_block_w * combined_per_core_N;
+
+    constexpr auto weight_args = TensorAccessorArgs<0>();
+    constexpr auto output_args = TensorAccessorArgs<weight_args.next_compile_time_args_offset()>();
+    const auto weight = TensorAccessor(weight_args, weight_addr);
+    const auto output = TensorAccessor(output_args, output_addr);
+
+    const uint32_t n_start = core_n * per_core_N;
+
+    for (uint32_t k0 = 0; k0 < Kt; k0 += in0_block_w) {
+        cb_reserve_back(cb_weights, in1_block_tiles);
+        uint32_t weights_ptr = get_write_ptr(cb_weights);
+        for (uint32_t k = 0; k < in0_block_w; ++k) {
+            const uint32_t row = (k0 + k) * fused_Nt + n_start;
+            const uint32_t up_row = row;
+            const uint32_t gate_row = row + half_Nt;
+            for (uint32_t n = 0; n < per_core_N; ++n) {
+                const uint32_t gate_local = (k * combined_per_core_N + n) * get_tile_size(cb_weights);
+                const uint32_t up_local = gate_local + per_core_N * get_tile_size(cb_weights);
+                noc_async_read_tile(gate_row + n, weight, weights_ptr + gate_local);
+                noc_async_read_tile(up_row + n, weight, weights_ptr + up_local);
+            }
+        }
+        noc_async_read_barrier();
+        cb_push_back(cb_weights, in1_block_tiles);
+    }
+
+    Noc noc;
+    CircularBuffer out_cb(cb_out);
+    const uint32_t page_bytes = get_local_cb_interface(cb_out).fifo_page_size;
+    for (uint32_t n = 0; n < per_core_N; ++n) {
+        out_cb.wait_front(1);
+        noc.async_write(out_cb, output, page_bytes, {}, {.page_id = n_start + n});
+        noc.async_writes_flushed();
+        out_cb.pop_front(1);
+    }
+    noc.async_write_barrier();
+}
diff --git ttnn/cpp/ttnn/operations/matmul/device/kernels/dataflow/reader_matmul_swiglu_in0_receiver.cpp ttnn/cpp/ttnn/operations/matmul/device/kernels/dataflow/reader_matmul_swiglu_in0_receiver.cpp

+bool is_standard_32x32_tile(const std::optional<tt::tt_metal::Tile>& tile) {
+    if (!tile.has_value()) {
+        return true;
+    }
+    const auto tile_shape = tile->get_tile_shape();
+    const auto face_shape = tile->get_face_shape();
+    return tile_shape[0] == tt::constants::TILE_HEIGHT && tile_shape[1] == tt::constants::TILE_WIDTH &&
+           face_shape[0] == tt::constants::FACE_HEIGHT && face_shape[1] == tt::constants::FACE_WIDTH;
+}
+
+const std::array<uint8_t, 256 * 256>& bfloat16_to_bfp8_b_lut() {
+    static const auto table = [] {
+        std::array<uint8_t, 256 * 256> result{};
+        constexpr uint32_t exp = 1;
+        for (uint32_t exp_diff = 0; exp_diff < 255; ++exp_diff) {
+            const uint32_t shared_exp = exp + exp_diff;
+            for (uint32_t sign_mantissa = 0; sign_mantissa < 256; ++sign_mantissa) {
+                const uint32_t sign = (sign_mantissa & 0x80) << 8;
+                const uint32_t mantissa = sign_mantissa & 0x7f;
+                const uint32_t bits = sign | (exp << 7) | mantissa;
+                result[(exp_diff << 8) | sign_mantissa] =
+                    convert_u32_to_bfp<tt::DataFormat::Bfp8_b, false>(bits << 16, shared_exp, false);
+            }
+        }
+        return result;
+    }();
+    return table;
+}
+
+uint8_t pack_bfloat16_as_bfp8_b(uint16_t bits, uint32_t shared_exp) {
+    const uint32_t exp = (bits & 0x7f80) >> 7;
+    if (exp == 0) {
+        return 0;
+    }
+    const uint32_t sign_mantissa = ((bits & 0x8000) >> 8) | (bits & 0x007f);
+    return bfloat16_to_bfp8_b_lut()[((shared_exp - exp) << 8) | sign_mantissa];
+}
+
+std::vector<uint32_t> pack_tiled_bfloat16_as_bfp8_b(tt::stl::Span<const bfloat16> input_data) {
+    constexpr uint32_t tile_height = tt::constants::TILE_HEIGHT;
+    constexpr uint32_t tile_width = tt::constants::TILE_WIDTH;
+    constexpr uint32_t face_height = tt::constants::FACE_HEIGHT;
+    constexpr uint32_t face_width = tt::constants::FACE_WIDTH;
+    constexpr uint32_t tile_elements = tile_height * tile_width;
+    constexpr uint32_t rows_per_tile = (tile_height / face_height) * (tile_width / face_width) * face_height;
+    constexpr uint32_t exponent_words_per_tile = rows_per_tile / 4;
+    constexpr uint32_t data_words_per_tile = tile_elements / 4;
+    constexpr uint32_t words_per_tile = exponent_words_per_tile + data_words_per_tile;
+
+    TT_ASSERT(input_data.size() % tile_elements == 0);
+    const uint32_t num_tiles = input_data.size() / tile_elements;
+    std::vector<uint32_t> packed_result(num_tiles * words_per_tile);
+
+    for (uint32_t tile_index = 0; tile_index < num_tiles; ++tile_index) {
+        uint32_t* const tile_output = packed_result.data() + tile_index * words_per_tile;
+        uint32_t* const data_output = tile_output + exponent_words_per_tile;
+        const bfloat16* const tile_input = input_data.data() + tile_index * tile_elements;
+
+        for (uint32_t row = 0; row < rows_per_tile; ++row) {
+            const bfloat16* const row_input = tile_input + row * face_width;
+            uint32_t shared_exp = 0;
+            for (uint32_t col = 0; col < face_width; ++col) {
+                const uint16_t bits = std::bit_cast<uint16_t>(row_input[col]);
+                shared_exp = std::max(shared_exp, static_cast<uint32_t>((bits & 0x7f80) >> 7));
+            }
+
+            tile_output[row / 4] |= shared_exp << ((row % 4) * 8);
+            for (uint32_t group = 0; group < face_width / 4; ++group) {
+                uint32_t packed_word = 0;
+                for (uint32_t i = 0; i < 4; ++i) {
+                    const uint16_t bits = std::bit_cast<uint16_t>(row_input[group * 4 + i]);
+                    packed_word |= static_cast<uint32_t>(pack_bfloat16_as_bfp8_b(bits, shared_exp)) << (i * 8);
+                }
+                data_output[row * (face_width / 4) + group] = packed_word;
+            }
+        }
+    }
+    return packed_result;
+}

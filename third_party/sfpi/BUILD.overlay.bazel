load("@rules_cc//cc/toolchains:cc_toolchain.bzl", "cc_toolchain")
load("@//third_party/sfpi:sfpi_cc_toolchain_config.bzl", "sfpi_cc_toolchain_config")

package(default_visibility = ["//visibility:public"])

constraint_setting(name = "sfpi_target")

constraint_value(
    name = "blackhole_firmware",
    constraint_setting = ":sfpi_target",
)

platform(
    name = "blackhole_firmware_platform",
    constraint_values = [":blackhole_firmware"],
)

filegroup(
    name = "all_files",
    srcs = glob(["**"]),
)

filegroup(
    name = "empty",
    srcs = [],
)

filegroup(
    name = "riscv_gpp",
    srcs = ["compiler/bin/riscv-tt-elf-g++"],
)

sfpi_cc_toolchain_config(name = "sfpi_cc_toolchain_config")

cc_toolchain(
    name = "sfpi_cc_toolchain",
    all_files = ":all_files",
    ar_files = ":all_files",
    as_files = ":all_files",
    compiler_files = ":all_files",
    dwp_files = ":empty",
    linker_files = ":all_files",
    objcopy_files = ":all_files",
    strip_files = ":all_files",
    supports_param_files = 1,
    toolchain_config = ":sfpi_cc_toolchain_config",
    toolchain_identifier = "sfpi-riscv-tt-elf",
)

toolchain(
    name = "sfpi_cc_toolchain_for_blackhole",
    toolchain = ":sfpi_cc_toolchain",
    toolchain_type = "@bazel_tools//tools/cpp:toolchain_type",
    target_compatible_with = [":blackhole_firmware"],
)

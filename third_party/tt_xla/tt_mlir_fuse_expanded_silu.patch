 class SiluFusionPattern : public mlir::OpRewritePattern<MultiplyOp> {
   using mlir::OpRewritePattern<MultiplyOp>::OpRewritePattern;
 
+  static mlir::Value lookThroughSplatViewOps(mlir::Value value) {
+    while (Operation *op = value.getDefiningOp()) {
+      if (auto typecastOp = mlir::dyn_cast<TypecastOp>(op)) {
+        value = typecastOp.getInput();
+        continue;
+      }
+      if (auto reshapeOp = mlir::dyn_cast<ReshapeOp>(op)) {
+        value = reshapeOp.getInput();
+        continue;
+      }
+      if (auto broadcastOp = mlir::dyn_cast<BroadcastOp>(op)) {
+        value = broadcastOp.getInput();
+        continue;
+      }
+      break;
+    }
+    return value;
+  }
+
+  static bool isOneLike(mlir::Value value) {
+    value = lookThroughSplatViewOps(value);
+    return isFullOpWithValue(value, 1.0f) ||
+           mlir::isa_and_nonnull<OnesOp>(value.getDefiningOp()) ||
+           mlir::matchPattern(value, mlir::m_OneFloat()) ||
+           mlir::matchPattern(value, mlir::m_One());
+  }
+
+  static mlir::Value matchExpandedSigmoidInput(mlir::Value value) {
+    auto divOp = lookThroughSplatViewOps(value).getDefiningOp<DivOp>();
+    if (!divOp || !isOneLike(divOp.getLhs())) {
+      return {};
+    }
+    auto addOp = lookThroughSplatViewOps(divOp.getRhs()).getDefiningOp<AddOp>();
+    if (!addOp) {
+      return {};
+    }
+    mlir::Value expValue;
+    if (isOneLike(addOp.getLhs())) {
+      expValue = addOp.getRhs();
+    } else if (isOneLike(addOp.getRhs())) {
+      expValue = addOp.getLhs();
+    } else {
+      return {};
+    }
+    auto expOp = lookThroughSplatViewOps(expValue).getDefiningOp<ExpOp>();
+    auto negOp = expOp ? lookThroughSplatViewOps(expOp.getInput())
+                             .getDefiningOp<NegOp>()
+                       : nullptr;
+    return negOp ? ttmlir::utils::lookThrough<TypecastOp>(negOp.getInput())
+                 : mlir::Value();
+  }
+
 public:
   mlir::LogicalResult
   matchAndRewrite(MultiplyOp multiplyOp,

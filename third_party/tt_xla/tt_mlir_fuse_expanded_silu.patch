+  static bool isOneValue(mlir::Value value) {
+    value = ttmlir::utils::lookThrough<TypecastOp, ReshapeOp, BroadcastOp>(value);
+    if (value.getDefiningOp<OnesOp>() || isFullOpWithValue(value, 1.0f)) {
+      return true;
+    }
+
+    auto constantOp = value.getDefiningOp<ConstantOp>();
+    auto denseAttr = constantOp ? mlir::dyn_cast<DenseElementsAttr>(constantOp.getValue()) : DenseElementsAttr();
+    return denseAttr && denseAttr.isSplat() && std::abs(denseAttr.getSplatValue<APFloat>().convertToFloat() - 1.0f) < 1e-6f;
+  }

+  std::optional<mlir::Value> matchSigmoidInput(mlir::Value value) const {
+    value = ttmlir::utils::lookThrough<TypecastOp>(value);
+    if (auto sigmoidOp = value.getDefiningOp<SigmoidOp>()) {
+      if (!sigmoidOp->hasOneUse()) {
+        return std::nullopt;
+      }
+      return ttmlir::utils::lookThrough<TypecastOp>(sigmoidOp.getInput());
+    }
+
+    return matchExpandedSigmoidInput(value);

+  std::optional<mlir::Value> matchExpandedSigmoidInput(mlir::Value value) const {
+    auto divOp = ttmlir::utils::lookThrough<TypecastOp>(value).getDefiningOp<DivOp>();
+    if (!divOp || !divOp->hasOneUse()) {
+      return std::nullopt;
+    }

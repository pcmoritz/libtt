+
+enum class QKVProjectionRole {
+  Unknown = -1,
+  Query = 0,
+  Key = 1,
+  Value = 2,
+};
+
+inline QKVProjectionRole getQKVProjectionRole(mlir::Operation *op) {
+  auto checkName = [](mlir::NameLoc nameLoc) {
+    llvm::StringRef name = nameLoc.getName().strref();
+    if (name.contains("/q_proj/")) {
+      return QKVProjectionRole::Query;
+    }
+    if (name.contains("/k_proj/")) {
+      return QKVProjectionRole::Key;
+    }
+    if (name.contains("/v_proj/")) {
+      return QKVProjectionRole::Value;
+    }
+    return QKVProjectionRole::Unknown;
+  };
+
+  mlir::Location loc = op->getLoc();
+  if (auto nameLoc = mlir::dyn_cast<mlir::NameLoc>(loc)) {
+    return checkName(nameLoc);
+  }
+  if (auto fusedLoc = mlir::dyn_cast<mlir::FusedLoc>(loc)) {
+    for (mlir::Location childLoc : fusedLoc.getLocations()) {
+      if (auto nameLoc = mlir::dyn_cast<mlir::NameLoc>(childLoc)) {
+        QKVProjectionRole role = checkName(nameLoc);
+        if (role != QKVProjectionRole::Unknown) {
+          return role;
+        }
+      }
+    }
+  }
+  return QKVProjectionRole::Unknown;
+}

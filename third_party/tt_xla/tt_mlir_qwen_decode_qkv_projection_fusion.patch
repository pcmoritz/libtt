 // Step 7: Create fused op
 // ============================================================================
@@ -821,6 +1022,63 @@ template class SplitQueryKeyValueAndSplitHeadsFusing<LinearOp>;
 // ============================================================================
 // NLPCreateQKVHeadsDecodeFusing
 // ============================================================================
+
+mlir::LogicalResult NLPDecodeQKVProjectionFusing::matchAndRewrite(
+    MatmulOp matmulOp, mlir::PatternRewriter &rewriter) const {
+  SmallVector<DecodeQKVHead> heads = matchDecodeQKVHeads(matmulOp);
+  if (heads.empty()) {
+    return mlir::failure();
+  }
+
+  DecodeQKVHead &q = heads[0];
+  DecodeQKVHead &k = heads[1];
+  DecodeQKVHead &v = heads[2];
+
+  ArrayRef<int64_t> matmulShape = matmulOp.getType().getShape();
+  int64_t batchSize = matmulShape[0];
+  int64_t hiddenSize = matmulShape[1];
+
+  SmallVector<int64_t> inputShape = {1, 1, batchSize, hiddenSize};
+  rewriter.setInsertionPointAfter(matmulOp);
+  auto inputReshape = ttir_to_ttnn::utils::generateReshape(
+      matmulOp.getResult(), inputShape, rewriter, matmulOp.getLoc());
+
+  auto numHeadsAttr =
+      rewriter.getUI32IntegerAttr(static_cast<uint32_t>(decodeNumHeads(q)));
+  auto numKVHeadsAttr =
+      rewriter.getUI32IntegerAttr(static_cast<uint32_t>(decodeNumHeads(k)));
+  SmallVector<Type> resultTypes{q.decodeReshapeOp.getType(),
+                                k.decodeReshapeOp.getType(),
+                                v.decodeReshapeOp.getType()};
+
+  IsolatedIRValidationWrapper validator(rewriter.getContext(),
+                                        validationConfig);
+  auto validationResult = validator.validateOp<NLPCreateQKVHeadsDecodeOp>(
+      matmulOp.getOperation(), matmulOp.getLoc(), resultTypes,
+      inputReshape.getResult(),
+      /*batch_offset=*/Value(), numHeadsAttr, numKVHeadsAttr,
+      /*overlap_qk_coregrid=*/BoolAttr(),
+      /*slice_size=*/IntegerAttr());
+  if (!validationResult.isSuccess()) {
+    rewriter.eraseOp(inputReshape);
+    return mlir::failure();
+  }
+
+  auto decodeOp = rewriter.create<NLPCreateQKVHeadsDecodeOp>(
+      matmulOp.getLoc(), resultTypes, inputReshape.getResult(),
+      /*batch_offset=*/Value(), numHeadsAttr, numKVHeadsAttr,
+      /*overlap_qk_coregrid=*/BoolAttr(),
+      /*slice_size=*/IntegerAttr());
+
+  auto qNorm = createRank4RMSNorm(rewriter, q.rmsNormOp, decodeOp.getQuery());
+  auto kNorm = createRank4RMSNorm(rewriter, k.rmsNormOp, decodeOp.getKey());
+
+  rewriter.replaceOp(q.decodeReshapeOp, qNorm.getResult());
+  rewriter.replaceOp(k.decodeReshapeOp, kNorm.getResult());
+  rewriter.replaceOp(v.decodeReshapeOp, decodeOp.getValue());
+
+  return mlir::success();
+}


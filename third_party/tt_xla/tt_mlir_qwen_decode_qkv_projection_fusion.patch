+// Fuses the decode QKV projection shape used by Qwen-style attention where
+// q/k RMSNorm sit between projection and attention:
+//
+//   matmul -> slice/reshape -> q_rms_norm -> reshape[1,B,H,D]
+//          -> slice/reshape -> k_rms_norm -> reshape[1,B,Hkv,D]
+//          -> slice/reshape ----------------> reshape[1,B,Hkv,D]
+//
+// Replaced with:
+//   matmul -> reshape[1,1,B,QKV] -> nlp_create_qkv_heads_decode
+//          -> q_rms_norm[1,B,H,D]
+//          -> k_rms_norm[1,B,Hkv,D]
+//
+// This keeps normalization on device and removes the per-layer projection
+// slices from the decode loop.
+class NLPDecodeQKVProjectionFusing
+    : public mlir::OpRewritePattern<MatmulOp> {
+public:
+  NLPDecodeQKVProjectionFusing(mlir::MLIRContext *context,
+                               const OpValidationConfig &validationConfig = {})
+      : OpRewritePattern<MatmulOp>(context), validationConfig(validationConfig) {}
+
+  mlir::LogicalResult
+  matchAndRewrite(MatmulOp matmulOp,
+                  mlir::PatternRewriter &rewriter) const override;
+
+private:
+  OpValidationConfig validationConfig;
+};

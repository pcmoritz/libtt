+  static int getQKVProjectionOrder(Operation *op) {
+    std::string loc;
+    llvm::raw_string_ostream(loc) << op->getLoc();
+    return loc.find("/q_proj/") != std::string::npos ? 0
+           : loc.find("/k_proj/") != std::string::npos ? 1
+           : loc.find("/v_proj/") != std::string::npos ? 2
+                                                        : -1;
+  }
+  static void sortQKVProjectionCandidates(FusionCandidates &candidates) {
+    if (candidates.ops.size() != 3) return;
+    SmallVector<int, 3> order;
+    for (OpType op : candidates.ops)
+      order.push_back(getQKVProjectionOrder(op.getOperation()));
+    if (!llvm::is_contained(order, 0) || !llvm::is_contained(order, 1) ||
+        !llvm::is_contained(order, 2))
+      return;
+    llvm::sort(candidates.ops, [](OpType lhs, OpType rhs) {
+      return getQKVProjectionOrder(lhs.getOperation()) <
+             getQKVProjectionOrder(rhs.getOperation());
+    });
+    candidates.firstTransposeB = candidates.ops.front().getTransposeB();
+  }


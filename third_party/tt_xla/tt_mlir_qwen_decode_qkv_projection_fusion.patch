+// ============================================================================
+// NLPDecodeQKVProjectionFusing helpers
+// ============================================================================
+
+struct DecodeQKVHead {
+  SliceStaticOp sliceOp;
+  ReshapeOp headReshapeOp;
+  RMSNormOp rmsNormOp; // nullptr for V
+  ReshapeOp decodeReshapeOp;
+};
+
+int64_t decodeNumHeads(const DecodeQKVHead &head) {
+  ReshapeOp decodeReshapeOp = head.decodeReshapeOp;
+  return decodeReshapeOp.getType().getShape()[2];
+}
+
+int64_t decodeHeadDim(const DecodeQKVHead &head) {
+  ReshapeOp decodeReshapeOp = head.decodeReshapeOp;
+  return decodeReshapeOp.getType().getShape()[3];
+}
+
+std::optional<DecodeQKVHead> matchDecodeQKVHead(SliceStaticOp sliceOp) {
+  auto firstReshapeOp =
+      dyn_cast_or_null<ReshapeOp>(lookThroughTypecasts(sliceOp.getResult()));
+  if (!firstReshapeOp) {
+    return std::nullopt;
+  }
+
+  // V has no per-head RMSNorm in Qwen decode, so it goes straight from the
+  // projection slice to the rank-4 attention shape.
+  if (firstReshapeOp.getType().getRank() == 4) {
+    ArrayRef<int64_t> sliceShape = sliceOp.getType().getShape();
+    ArrayRef<int64_t> decodeShape = firstReshapeOp.getType().getShape();
+    if (sliceShape.size() != 2 || decodeShape[0] != 1 ||
+        sliceShape[0] != decodeShape[1] ||
+        sliceShape[1] != decodeShape[2] * decodeShape[3]) {
+      return std::nullopt;
+    }
+    return DecodeQKVHead{sliceOp, ReshapeOp(), nullptr, firstReshapeOp};
+  }
+
+  if (firstReshapeOp.getType().getRank() != 3) {
+    return std::nullopt;
+  }
+  ReshapeOp headReshapeOp = firstReshapeOp;
+
+  RMSNormOp rmsNormOp = nullptr;
+  Operation *next = lookThroughTypecasts(headReshapeOp.getResult());
+  if (auto candidate = dyn_cast_or_null<RMSNormOp>(next)) {
+    rmsNormOp = candidate;
+    next = lookThroughTypecasts(rmsNormOp.getResult());
+  }
+
+  auto decodeReshapeOp = dyn_cast_or_null<ReshapeOp>(next);
+  if (!decodeReshapeOp || decodeReshapeOp.getType().getRank() != 4) {
+    return std::nullopt;
+  }
+
+  ArrayRef<int64_t> sliceShape = sliceOp.getType().getShape();
+  ArrayRef<int64_t> headShape = headReshapeOp.getType().getShape();
+  ArrayRef<int64_t> decodeShape = decodeReshapeOp.getType().getShape();
+  if (sliceShape.size() != 2 || sliceShape[0] != headShape[0] ||
+      sliceShape[1] != headShape[1] * headShape[2] ||
+      decodeShape[0] != 1 || headShape[0] != decodeShape[1] ||
+      headShape[1] != decodeShape[2] || headShape[2] != decodeShape[3]) {
+    return std::nullopt;
+  }
+
+  return DecodeQKVHead{sliceOp, headReshapeOp, rmsNormOp, decodeReshapeOp};
+}
+
+SmallVector<DecodeQKVHead> matchDecodeQKVHeads(MatmulOp matmulOp) {
+  SmallVector<DecodeQKVHead> heads;
+  auto matmulShape = matmulOp.getType().getShape();
+  if (matmulShape.size() != 2) {
+    return {};
+  }
+
+  for (Operation *user : matmulOp.getResult().getUsers()) {
+    auto sliceOp = dyn_cast<SliceStaticOp>(user);
+    if (!sliceOp) {
+      continue;
+    }
+    std::optional<DecodeQKVHead> head = matchDecodeQKVHead(sliceOp);
+    if (head) {
+      heads.push_back(*head);
+    }
+  }
+  if (heads.size() != 3) {
+    return {};
+  }
+
+  struct HeadWithBounds {
+    DecodeQKVHead head;
+    int64_t start;
+    int64_t end;
+  };
+
+  SmallVector<std::optional<HeadWithBounds>, 3> ordered(3);
+  std::optional<size_t> sliceDim;
+  using ttmlir::utils::QKVProjectionRole;
+  using ttmlir::utils::getQKVProjectionRole;
+  for (DecodeQKVHead head : heads) {
+    auto dimAndBounds =
+        findSlicedDimensionWithBounds(head.sliceOp, matmulShape);
+    if (!dimAndBounds) {
+      return {};
+    }
+    auto [dim, start, end] = *dimAndBounds;
+    if (!sliceDim) {
+      sliceDim = dim;
+    } else if (*sliceDim != dim) {
+      return {};
+    }
+    int role = static_cast<int>(getQKVProjectionRole(head.sliceOp));
+    if (role < 0 || role >= static_cast<int>(ordered.size()) ||
+        ordered[role]) {
+      return {};
+    }
+    ordered[role] = HeadWithBounds{head, start, end};
+  }
+  if (!sliceDim || *sliceDim != matmulShape.size() - 1 || !ordered[0] ||
+      !ordered[1] || !ordered[2]) {
+    return {};
+  }
+
+  HeadWithBounds &q = *ordered[static_cast<int>(QKVProjectionRole::Query)];
+  HeadWithBounds &k = *ordered[static_cast<int>(QKVProjectionRole::Key)];
+  HeadWithBounds &v = *ordered[static_cast<int>(QKVProjectionRole::Value)];
+  if (q.start != 0 || k.start != q.end || v.start != k.end ||
+      v.end != matmulShape.back()) {
+    return {};
+  }
+  if (!q.head.rmsNormOp || !k.head.rmsNormOp || v.head.rmsNormOp) {
+    return {};
+  }
+  if (decodeHeadDim(q.head) != decodeHeadDim(k.head) ||
+      decodeHeadDim(q.head) != decodeHeadDim(v.head) ||
+      decodeNumHeads(k.head) != decodeNumHeads(v.head)) {
+    return {};
+  }
+
+  SmallVector<DecodeQKVHead> result;
+  result.reserve(ordered.size());
+  result.push_back(q.head);
+  result.push_back(k.head);
+  result.push_back(v.head);
+  return result;
+}
+
+RMSNormOp createRank4RMSNorm(PatternRewriter &rewriter, RMSNormOp oldOp,
+                             Value input) {
+  return rewriter.create<RMSNormOp>(
+      oldOp.getLoc(), input.getType(), input, oldOp.getWeight(),
+      oldOp.getBias(), oldOp.getEpsilonAttr(), oldOp.getComputeConfigAttr());
+}

   return true;
 }

+struct DecodeQKVHead {
+  SliceStaticOp sliceOp;
+  ReshapeOp headReshapeOp;
+  RMSNormOp rmsNormOp; // nullptr for V
+  ReshapeOp decodeReshapeOp;
+};
+
+ArrayRef<int64_t> decodeShape(DecodeQKVHead &head) {
+  return mlir::cast<RankedTensorType>(
+             head.decodeReshapeOp.getResult().getType())
+      .getShape();
+}
+
+std::optional<DecodeQKVHead> matchDecodeQKVHead(SliceStaticOp sliceOp) {
+  auto firstReshapeOp =
+      dyn_cast_or_null<ReshapeOp>(lookThroughTypecasts(sliceOp.getResult()));
+  if (!firstReshapeOp) {
+    return std::nullopt;
+  }
+
+  if (firstReshapeOp.getType().getRank() == 4) {
+    ArrayRef<int64_t> sliceShape = sliceOp.getType().getShape();
+    ArrayRef<int64_t> decodeShape = firstReshapeOp.getType().getShape();
+    if (sliceShape.size() != 2 || decodeShape[0] != 1 ||
+        sliceShape[0] != decodeShape[1] ||
+        sliceShape[1] != decodeShape[2] * decodeShape[3]) {
+      return std::nullopt;
+    }
+    return DecodeQKVHead{sliceOp, ReshapeOp(), nullptr, firstReshapeOp};
+  }
+
+  if (firstReshapeOp.getType().getRank() != 3) {
+    return std::nullopt;
+  }
+  ReshapeOp headReshapeOp = firstReshapeOp;
+
+  RMSNormOp rmsNormOp = nullptr;
+  Operation *next = lookThroughTypecasts(headReshapeOp.getResult());
+  if (auto candidate = dyn_cast_or_null<RMSNormOp>(next)) {
+    rmsNormOp = candidate;
+    next = lookThroughTypecasts(rmsNormOp.getResult());
+  }
+
+  auto decodeReshapeOp = dyn_cast_or_null<ReshapeOp>(next);
+  if (!decodeReshapeOp || decodeReshapeOp.getType().getRank() != 4) {
+    return std::nullopt;
+  }
+
+  ArrayRef<int64_t> headShape = headReshapeOp.getType().getShape();
+  ArrayRef<int64_t> decodeShape = decodeReshapeOp.getType().getShape();
+  if (decodeShape[0] != 1 || headShape[0] != decodeShape[1] ||
+      headShape[1] != decodeShape[2] || headShape[2] != decodeShape[3]) {
+    return std::nullopt;
+  }
+
+  return DecodeQKVHead{sliceOp, headReshapeOp, rmsNormOp, decodeReshapeOp};
+}
+
+std::optional<SmallVector<DecodeQKVHead>>
+matchDecodeQKVHeads(MatmulOp matmulOp) {
+  SmallVector<DecodeQKVHead> heads;
+  auto matmulShape = matmulOp.getType().getShape();
+  if (matmulShape.size() != 2) {
+    return std::nullopt;
+  }
+
+  for (Operation *user : matmulOp.getResult().getUsers()) {
+    auto sliceOp = dyn_cast<SliceStaticOp>(user);
+    if (!sliceOp) {
+      continue;
+    }
+    std::optional<DecodeQKVHead> head = matchDecodeQKVHead(sliceOp);
+    if (head) {
+      heads.push_back(*head);
+    }
+  }
+  if (heads.size() != 3) {
+    return std::nullopt;
+  }
+
+  SmallVector<std::pair<int64_t, int64_t>> bounds;
+  std::optional<size_t> sliceDim;
+  for (auto &head : heads) {
+    auto dimAndBounds =
+        findSlicedDimensionWithBounds(head.sliceOp, matmulShape);
+    if (!dimAndBounds) {
+      return std::nullopt;
+    }
+    auto [dim, start, end] = *dimAndBounds;
+    if (!sliceDim) {
+      sliceDim = dim;
+    } else if (*sliceDim != dim) {
+      return std::nullopt;
+    }
+    bounds.push_back({start, end});
+  }
+  if (!sliceDim || *sliceDim != matmulShape.size() - 1) {
+    return std::nullopt;
+  }
+
+  SmallVector<size_t> indices(heads.size());
+  std::iota(indices.begin(), indices.end(), 0);
+  llvm::sort(indices, [&](size_t a, size_t b) {
+    return bounds[a].first < bounds[b].first;
+  });
+
+  SmallVector<DecodeQKVHead> sorted;
+  sorted.reserve(heads.size());
+  int64_t previousEnd = 0;
+  for (size_t index : indices) {
+    if (bounds[index].first != previousEnd) {
+      return std::nullopt;
+    }
+    previousEnd = bounds[index].second;
+    sorted.push_back(heads[index]);
+  }
+  if (previousEnd != matmulShape.back()) {
+    return std::nullopt;
+  }
+
+  DecodeQKVHead &q = sorted[0];
+  DecodeQKVHead &k = sorted[1];
+  DecodeQKVHead &v = sorted[2];
+  if (!q.rmsNormOp || !k.rmsNormOp || v.rmsNormOp) {
+    return std::nullopt;
+  }
+  if (decodeShape(q)[3] != decodeShape(k)[3] ||
+      decodeShape(q)[3] != decodeShape(v)[3] ||
+      decodeShape(k)[2] != decodeShape(v)[2]) {
+    return std::nullopt;
+  }
+
+  return sorted;
+}
+
+RMSNormOp createRank4RMSNorm(PatternRewriter &rewriter, RMSNormOp oldOp,
+                             Value input) {
+  return rewriter.create<RMSNormOp>(
+      oldOp.getLoc(), input.getType(), input, oldOp.getWeight(),
+      oldOp.getBias(), oldOp.getEpsilonAttr(), oldOp.getComputeConfigAttr());
+}
+
+void eraseUnusedDecodeQKVHead(PatternRewriter &rewriter,
+                              DecodeQKVHead &head) {
+  if (head.rmsNormOp && head.rmsNormOp->use_empty()) {
+    rewriter.eraseOp(head.rmsNormOp);
+  }
+  if (head.headReshapeOp && head.headReshapeOp->use_empty()) {
+    rewriter.eraseOp(head.headReshapeOp);
+  }
+  if (head.sliceOp && head.sliceOp->use_empty()) {
+    rewriter.eraseOp(head.sliceOp);
+  }
+}

+PJRT_TopologyDescription *ClientInstance::getTopologyDescription() {
+  if (!m_topology_description) {
+    m_topology_description = std::make_unique<PJRT_TopologyDescription>();
+    m_topology_description->client = this;
+    m_topology_description->serialized =
+        platformName() + ":" + platformVersion() + ":devices=" +
+        std::to_string(m_devices_raw.size());
+    for (DeviceInstance *device : m_devices_raw) {
+      m_topology_description->device_descriptions.push_back(
+          reinterpret_cast<PJRT_DeviceDescription *>(
+              &device->getDeviceDescription()));
+      m_topology_description->serialized +=
+          ":" + std::to_string(device->getGlobalDeviceId());
+    }
+  }
+  return m_topology_description.get();
+}

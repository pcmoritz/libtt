+static bool hasStaticDim(mlir::RankedTensorType type, int64_t dim,
+                         int64_t expected) {
+  int64_t value = type.getShape()[dim < 0 ? type.getRank() + dim : dim];
+  return !mlir::ShapedType::isDynamic(value) && value == expected;
+}
+
+static bool dimIsDynamicOrAtLeast(mlir::RankedTensorType type, int64_t dim,
+                                  int64_t minimum) {
+  int64_t value = type.getShape()[dim < 0 ? type.getRank() + dim : dim];
+  return mlir::ShapedType::isDynamic(value) || value >= minimum;
+}
+
+static bool rotaryCacheShapeCanUseTypedOp(ttcore::CompositeOp compositeOp) {
+  auto inputType =
+      dyn_cast<mlir::RankedTensorType>(compositeOp.getInputs()[0].getType());
+  auto cosCacheType =
+      dyn_cast<mlir::RankedTensorType>(compositeOp.getInputs()[1].getType());
+  auto sinCacheType =
+      dyn_cast<mlir::RankedTensorType>(compositeOp.getInputs()[2].getType());
+
+  if (!inputType || !cosCacheType || !sinCacheType) {
+    return true;
+  }
+
+  if (inputType.getRank() != 4 || cosCacheType.getRank() != 4 ||
+      sinCacheType.getRank() != 4) {
+    return false;
+  }
+
+  int64_t headDim = inputType.getShape().back();
+  int64_t inputSeqLen = inputType.getShape()[inputType.getRank() - 2];
+  if (mlir::ShapedType::isDynamic(headDim) ||
+      mlir::ShapedType::isDynamic(inputSeqLen)) {
+    return true;
+  }
+
+  auto cacheShapeCanUseTypedOp = [headDim,
+                                  inputSeqLen](mlir::RankedTensorType type) {
+    return hasStaticDim(type, 0, 1) && hasStaticDim(type, 1, 1) &&
+           hasStaticDim(type, -1, headDim) &&
+           dimIsDynamicOrAtLeast(type, -2, inputSeqLen);
+  };
+
+  // The TTNN rotary_embedding op only accepts cache tensors shaped
+  // [1, 1, cache_seq_len, head_dim] with cache_seq_len covering the input
+  // sequence. Other cache layouts should inline the composite decomposition
+  // directly instead of paying for expensive OpModel validation that is
+  // guaranteed to fail.
+  return cacheShapeCanUseTypedOp(cosCacheType) &&
+         cacheShapeCanUseTypedOp(sinCacheType);
+}

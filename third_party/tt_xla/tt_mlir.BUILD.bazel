    "debug_info.fbs",
    "system_desc.fbs",
    "types.fbs",
    "version.fbs",
]

_TTMETAL_FBS = [
    "binary.fbs",
    "command.fbs",
    "program.fbs",
    "types.fbs",
]

_TTNN_FBS = [
    "binary.fbs",
    "operations/ccl.fbs",
    "operations/configs.fbs",
    "operations/conv.fbs",
    "operations/cpu.fbs",
    "operations/creation.fbs",
    "operations/cumprod.fbs",
    "operations/cumsum.fbs",
    "operations/data_movement.fbs",
    "operations/deallocate.fbs",
    "operations/debug.fbs",
    "operations/eltwise.fbs",
    "operations/embedding.fbs",
    "operations/generic_op.fbs",
    "operations/get_device.fbs",
    "operations/global_semaphore.fbs",
    "operations/kv_cache.fbs",
    "operations/layout.fbs",
    "operations/load_cached.fbs",
    "operations/matmul.fbs",
    "operations/mlir_native.fbs",
    "operations/normalization.fbs",
    "operations/pool.fbs",
    "operations/rand.fbs",
    "operations/reduction.fbs",
    "operations/tensor_serialization.fbs",
    "operations/trace.fbs",
    "operations/transformer.fbs",
    "program.fbs",
    "types.fbs",
]

_RUNTIME_FBS = ["types.fbs"]

_DISTRIBUTED_FBS = [
    "command.fbs",
    "response.fbs",
]

_FBS_GROUPS = [
    (
        "common",
        "include/ttmlir/Target/Common",
        "flatbuffers/ttmlir/Target/Common",
        _COMMON_FBS,
    ),
    (
        "ttmetal",
        "include/ttmlir/Target/TTMetal",
        "flatbuffers/ttmlir/Target/TTMetal",
        _TTMETAL_FBS,
    ),
    (
        "ttnn",
        "include/ttmlir/Target/TTNN",
        "flatbuffers/ttmlir/Target/TTNN",
        _TTNN_FBS,
    ),
    (
        "runtime",
        "runtime/include/tt/runtime/flatbuffer",
        "flatbuffers/tt/runtime/flatbuffer",
        _RUNTIME_FBS,
    ),
    (
        "distributed",
        "runtime/include/tt/runtime/detail/distributed/flatbuffer",
        "flatbuffers/tt/runtime/detail/distributed/flatbuffer",
        _DISTRIBUTED_FBS,
    ),
]

_FBS_SRCS = [
    src_dir + "/" + schema
    for _, src_dir, _, schemas in _FBS_GROUPS
    for schema in schemas
]

_FBS_OUTS = [
    out_dir + "/" + schema[:-4] + suffix
    for _, _, out_dir, schemas in _FBS_GROUPS
    for schema in schemas
    for suffix in [
        "_generated.h",
        "_bfbs_generated.h",
        "_bfbs_hash_generated.h",
    ]
]

_FLATBUFFER_CMDS = "\n".join([
    """
mkdir -p "$(@D)/{gen_dir}"
"$$flatc" \
  -I "$$ttmlir_include" \
  -I "$$runtime_include" \
  --bfbs-gen-embed \
  --cpp --cpp-std c++17 \
  --scoped-enums --warnings-as-errors \
  --keep-prefix \
  --gen-name-strings \
  --gen-object-api \
  -o "$(@D)/{gen_dir}" \
  "$(location {src_dir}/{schema})"
python3 "$$sha_script" \
  tt::target::{namespace} \
  {base}_bfbs_schema_hash \
  "$(@D)/{gen_dir}/{base}_bfbs_generated.h" \
  "$(@D)/{gen_dir}/{base}_bfbs_hash_generated.h"
""".format(
        base = schema.split("/")[-1][:-4],
        gen_dir = out_dir + ("/" + "/".join(schema.split("/")[:-1]) if "/" in schema else ""),
        namespace = namespace,
        schema = schema,
        src_dir = src_dir,
    )
    for namespace, src_dir, out_dir, schemas in _FBS_GROUPS
    for schema in schemas
])

genrule(
    name = "flatbuffer_headers",
    srcs = _FBS_SRCS + ["tools/scripts/sha256-include-gen.py"],
    outs = _FBS_OUTS,
    cmd = """
set -euo pipefail
flatc="$(location @com_github_google_flatbuffers//:flatc)"
sha_script="$(location tools/scripts/sha256-include-gen.py)"
common_types="$(location include/ttmlir/Target/Common/types.fbs)"
runtime_types="$(location runtime/include/tt/runtime/flatbuffer/types.fbs)"
ttmlir_include="$$(dirname "$$(dirname "$$(dirname "$$(dirname "$$common_types")")")")"
runtime_include="$$(dirname "$$(dirname "$$(dirname "$$(dirname "$$runtime_types")")")")"
""" + _FLATBUFFER_CMDS,
    tools = ["@com_github_google_flatbuffers//:flatc"],
)

cc_library(
    name = "flatbuffer_generated_headers",
    hdrs = [":flatbuffer_headers"],
    includes = [
        "flatbuffers",

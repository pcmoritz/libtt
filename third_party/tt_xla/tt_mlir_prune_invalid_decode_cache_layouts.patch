diff --git a/include/ttmlir/Dialect/TTNN/Analysis/OpRules/TransformerRules.h b/include/ttmlir/Dialect/TTNN/Analysis/OpRules/TransformerRules.h
--- a/include/ttmlir/Dialect/TTNN/Analysis/OpRules/TransformerRules.h
+++ b/include/ttmlir/Dialect/TTNN/Analysis/OpRules/TransformerRules.h
@@ -55,6 +55,8 @@ struct SDPADecodeRuleBook : SDPARuleBook {
   LayoutFilterFn getInputLayoutFilter(unsigned operandIdx) const override;
 };

+struct NLPCreateQKVHeadsDecodeRuleBook : SDPARuleBook { LayoutFilterFn getInputLayoutFilter(unsigned operandIdx) const override; };
+
 /// RotaryEmbedding / RotaryEmbeddingLlama:
 /// NULL hint only, no reshards. Rejects width-sharded and block-sharded
 /// inputs (only height-sharded or interleaved accepted).
@@ -91,6 +95,8 @@ struct PagedFillCacheRuleBook : OpRuleBook {
   LayoutFilterFn getInputLayoutFilter(unsigned operandIdx) const override;
 };

+struct PagedUpdateCacheRuleBook : OpRuleBook { LayoutFilterFn getInputLayoutFilter(unsigned operandIdx) const override; };
+
 } // namespace mlir::tt::ttnn

 #endif // TTMLIR_DIALECT_TTNN_ANALYSIS_OPRULES_TRANSFORMERRULES_H
diff --git a/lib/Dialect/TTNN/Analysis/OpRules/TransformerRules.cpp b/lib/Dialect/TTNN/Analysis/OpRules/TransformerRules.cpp
--- a/lib/Dialect/TTNN/Analysis/OpRules/TransformerRules.cpp
+++ b/lib/Dialect/TTNN/Analysis/OpRules/TransformerRules.cpp
@@ -59,6 +59,8 @@ SDPADecodeRuleBook::getInputLayoutFilter(unsigned operandIdx) const {
   return layout_filter_utils::requireDRAMInterleaved;
 }

+LayoutFilterFn NLPCreateQKVHeadsDecodeRuleBook::getInputLayoutFilter(unsigned operandIdx) const { if (operandIdx != 0) return layout_filter_utils::requireDRAMInterleaved; return [](TTNNLayoutAttr layout) -> bool { auto ml = layout.getMemLayout(); auto shardShape = layout.getScalarShardShape(); return ml && ml.getValue() == TensorMemoryLayout::WidthSharded && shardShape.size() >= 2 && shardShape[1] > 0 && 128 % shardShape[1] == 0; }; }
+
 //===----------------------------------------------------------------------===//
 // RotaryEmbeddingRuleBook
 //===----------------------------------------------------------------------===//
@@ -128,4 +135,6 @@ PagedFillCacheRuleBook::getInputLayoutFilter(unsigned operandIdx) const {
   return nullptr;
 }

+LayoutFilterFn PagedUpdateCacheRuleBook::getInputLayoutFilter(unsigned operandIdx) const { if (operandIdx == 0) return cacheBufferDramOnlyFilter(); if (operandIdx == 1) return [](TTNNLayoutAttr layout) -> bool { auto ml = layout.getMemLayout(); return layout.hasL1BufferType() && ml && ml.getValue() == TensorMemoryLayout::HeightSharded; }; return nullptr; }
+
 } // namespace mlir::tt::ttnn

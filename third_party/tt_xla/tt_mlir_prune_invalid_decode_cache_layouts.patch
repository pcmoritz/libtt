diff --git a/lib/Dialect/TTNN/Analysis/OpRules/TransformerRules.cpp b/lib/Dialect/TTNN/Analysis/OpRules/TransformerRules.cpp
--- a/lib/Dialect/TTNN/Analysis/OpRules/TransformerRules.cpp
+++ b/lib/Dialect/TTNN/Analysis/OpRules/TransformerRules.cpp
@@ -59,6 +59,28 @@ SDPADecodeRuleBook::getInputLayoutFilter(unsigned operandIdx) const {
   return layout_filter_utils::requireDRAMInterleaved;
 }

+// NLPCreateQKVHeadsDecodeRuleBook
+
+LayoutFilterFn
+NLPCreateQKVHeadsDecodeRuleBook::getInputLayoutFilter(
+    unsigned operandIdx) const {
+  if (operandIdx != 0) {
+    return layout_filter_utils::requireDRAMInterleaved;
+  }
+  return [](TTNNLayoutAttr layout) -> bool {
+    auto ml = layout.getMemLayout();
+    if (!ml || ml.getValue() != TensorMemoryLayout::WidthSharded) {
+      return false;
+    }
+    auto shardShape = layout.getScalarShardShape();
+    if (shardShape.size() < 2 || shardShape[1] <= 0) {
+      return false;
+    }
+    constexpr int64_t qwenHeadDim = 128;
+    return qwenHeadDim % shardShape[1] == 0;
+  };
+}
+
 //===----------------------------------------------------------------------===//
 // RotaryEmbeddingRuleBook
 //===----------------------------------------------------------------------===//
@@ -128,4 +149,19 @@ PagedFillCacheRuleBook::getInputLayoutFilter(unsigned operandIdx) const {
   return nullptr;
 }

+LayoutFilterFn
+PagedUpdateCacheRuleBook::getInputLayoutFilter(unsigned operandIdx) const {
+  if (operandIdx == 0) {
+    return cacheBufferDramOnlyFilter();
+  }
+  if (operandIdx == 1) {
+    return [](TTNNLayoutAttr layout) -> bool {
+      auto ml = layout.getMemLayout();
+      return layout.hasL1BufferType() && ml &&
+             ml.getValue() == TensorMemoryLayout::HeightSharded;
+    };
+  }
+  return nullptr;
+}
+
 } // namespace mlir::tt::ttnn

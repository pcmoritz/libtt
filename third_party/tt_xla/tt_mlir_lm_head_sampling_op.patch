+::tt::tt_metal::KernelDescriptor makeSamplingKernel(
+    const ::tt::tt_metal::CoreCoord &core, const NamedArgs &namedArgs,
+    ::tt::tt_metal::KernelDescriptor::ConfigDescriptor config,
+    const ::tt::tt_metal::KernelDescriptor::RTArgList &commonArgs) {
+  ::tt::tt_metal::KernelDescriptor kernel;
+  kernel.kernel_source =
+      "models/demos/deepseek_v3_b1/micro_ops/sampling/kernels/"
+      "sampling_kernel.cpp";
+  kernel.source_type =
+      ::tt::tt_metal::KernelDescriptor::SourceType::FILE_PATH;
+  kernel.core_ranges = singleCoreSet(core);
+  kernel.named_compile_time_args = namedArgs;
+  kernel.defines = {{"SAMPLING_PROGRAM_SEMAPHORES", "1"}};
+  kernel.config = std::move(config);
+  kernel.emplace_common_runtime_args(commonArgs);
+  return kernel;
+}

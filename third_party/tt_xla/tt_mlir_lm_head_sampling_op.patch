+class LMHeadSamplingFusing : public mlir::OpRewritePattern<ArgMaxOp> {
+  using OpRewritePattern::OpRewritePattern;
+
+  static bool hasOnlyExpectedUsers(Value value, Operation *expectedUser) {
+    return value.hasOneUse() && *value.user_begin() == expectedUser;
+  }
+
+  static bool isDecodeLMHeadTail(ArgMaxOp argMaxOp, MatmulOp matmulOp,
+                                 RMSNormOp rmsNormOp) {
+    if (!argMaxOp.getDim() ||
+        (*argMaxOp.getDim() != 1 && *argMaxOp.getDim() != -1) ||
+        argMaxOp.getKeepDim()) {
+      return false;
+    }
+    if (matmulOp.getTransposeA() || !matmulOp.getTransposeB() ||
+        matmulOp.getActivation()) {
+      return false;
+    }
+    if (!rmsNormOp.getWeight() || rmsNormOp.getBias()) {
+      return false;
+    }
+    auto inputType =
+        mlir::dyn_cast<RankedTensorType>(rmsNormOp.getInput().getType());
+    auto logitsType =
+        mlir::dyn_cast<RankedTensorType>(matmulOp.getResult().getType());
+    if (!inputType || !logitsType || inputType.getRank() < 2 ||
+        logitsType.getRank() != 2) {
+      return false;
+    }
+    constexpr int64_t kDecodeSequenceLength = 1;
+    constexpr int64_t kMinShardWidth = 2048;
+    constexpr int64_t kShardCores = 16;
+    constexpr int64_t kTileWidth = 32;
+    const ArrayRef<int64_t> inputShape = inputType.getShape();
+    const ArrayRef<int64_t> logitsShape = logitsType.getShape();
+    const int64_t sequenceLength = inputShape[inputType.getRank() - 2];
+    const int64_t hidden = inputShape.back();
+    const int64_t batch = logitsShape[0];
+    const int64_t vocab = logitsShape[1];
+    if (ShapedType::isDynamic(sequenceLength) ||
+        ShapedType::isDynamic(hidden) || ShapedType::isDynamic(batch) ||
+        ShapedType::isDynamic(vocab)) {
+      return false;
+    }
+    return sequenceLength == kDecodeSequenceLength && batch == 1 &&
+           hidden >= kMinShardWidth &&
+           hidden % (kShardCores * kTileWidth) == 0 && vocab > 0;
+  }
+
+public:
+  mlir::LogicalResult
+  matchAndRewrite(ArgMaxOp argMaxOp,
+                  mlir::PatternRewriter &rewriter) const override {
+    auto matmulOp = argMaxOp.getInput().getDefiningOp<MatmulOp>();
+    if (!matmulOp) {
+      return failure();
+    }
+
+    auto rmsNormOp = matmulOp.getA().getDefiningOp<RMSNormOp>();
+    if (!rmsNormOp ||
+        !isDecodeLMHeadTail(argMaxOp, matmulOp, rmsNormOp) ||
+        !hasOnlyExpectedUsers(matmulOp.getResult(), argMaxOp) ||
+        !hasOnlyExpectedUsers(rmsNormOp.getResult(), matmulOp)) {
+      return failure();
+    }
+
+    rewriter.setInsertionPoint(rmsNormOp);
+    auto fusedOp = rewriter.create<LMHeadSamplingOp>(
+        argMaxOp.getLoc(), argMaxOp.getResult().getType(), rmsNormOp.getInput(),
+        rmsNormOp.getWeight(), matmulOp.getB(), rmsNormOp.getEpsilon());
+    if (auto weightDtype =
+            matmulOp->getAttrOfType<mlir::StringAttr>("ttcore.weight_dtype")) {
+      fusedOp->setAttr("ttcore.weight_dtype", weightDtype);
+    }
+
+    rewriter.replaceOp(argMaxOp, fusedOp.getResult());
+    rewriter.eraseOp(matmulOp);
+    rewriter.eraseOp(rmsNormOp);
+
+    return success();
+  }
+};

+::tt::tt_metal::CoreRangeSet rowWiseCorePrefix(
+    ::tt::tt_metal::CoreCoord gridSize, uint32_t numCores) {
+  std::vector<::tt::tt_metal::CoreRange> ranges;
+  const uint32_t fullRows = numCores / gridSize.x;
+  const uint32_t tail = numCores % gridSize.x;
+  if (fullRows > 0) {
+    ranges.emplace_back(::tt::tt_metal::CoreCoord{0, 0},
+                        ::tt::tt_metal::CoreCoord{gridSize.x - 1,
+                                                  fullRows - 1});
+  }
+  if (tail > 0) {
+    ranges.emplace_back(::tt::tt_metal::CoreCoord{0, fullRows},
+                        ::tt::tt_metal::CoreCoord{tail - 1, fullRows});
+  }
+  return ::tt::tt_metal::CoreRangeSet(std::move(ranges));
+}
+
+uint32_t paddedShardWidth(uint32_t width, uint32_t cores) {
+  return roundUp((width + cores - 1) / cores, tt::constants::TILE_WIDTH);
+}

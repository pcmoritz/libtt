+::tt::tt_metal::CBDescriptor makeScratchCb(
+    uint32_t cb, ::ttnn::DataType dtype, uint32_t pageSize,
+    uint32_t totalSize, const ::tt::tt_metal::CoreRangeSet &cores,
+    std::optional<::tt::tt_metal::TileDescriptor> tile = std::nullopt) {
+  ::tt::tt_metal::CBDescriptor desc;
+  desc.total_size = totalSize;
+  desc.core_ranges = cores;
+  desc.format_descriptors.push_back(
+      ::tt::tt_metal::CBFormatDescriptor{
+          static_cast<uint8_t>(cb),
+          ::tt::tt_metal::datatype_to_dataformat_converter(dtype), pageSize,
+          tile});
+  return desc;

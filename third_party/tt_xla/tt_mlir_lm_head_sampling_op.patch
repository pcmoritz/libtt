+::ttnn::MemoryConfig createDecodeRMSNormShardConfig(
+    const ::ttnn::Tensor &input) {
+  const ::ttnn::Shape &shape = input.logical_shape();
+  constexpr uint32_t kShardGridWidth = 8;
+  constexpr uint32_t kShardGridHeight = 2;
+  constexpr uint32_t kShardCores = kShardGridWidth * kShardGridHeight;
+  const uint32_t width = static_cast<uint32_t>(shape[-1]);
+  const uint32_t shardWidth = width / kShardCores;
+
+  const auto grid = ::tt::tt_metal::CoreRangeSet(
+      {::tt::tt_metal::CoreRange({0, 0},
+                                  {kShardGridWidth - 1,
+                                   kShardGridHeight - 1})});
+  return ::ttnn::operations::data_movement::create_sharded_memory_config(
+      shape, grid, ::ttnn::operations::data_movement::ShardStrategy::WIDTH,
+      ::tt::tt_metal::ShardOrientation::ROW_MAJOR,
+      std::array<uint32_t, 2>{tt::constants::TILE_HEIGHT, shardWidth},
+      ::ttnn::Layout::TILE);
+}

+::tt::tt_metal::CoreRangeSet singleCoreSet(::tt::tt_metal::CoreCoord core) {
+  return ::tt::tt_metal::CoreRangeSet(
+      ::tt::tt_metal::CoreRange(core, core));
+}
+
+::tt::tt_metal::CoreRangeSet
+coreSetFromCores(const std::vector<::tt::tt_metal::CoreCoord> &cores) {
+  std::vector<::tt::tt_metal::CoreRange> ranges;
+  ranges.reserve(cores.size());
+  for (const auto &core : cores) {
+    ranges.emplace_back(core, core);
+  }
+  return ::tt::tt_metal::CoreRangeSet(std::move(ranges));
+}

+  add(args, "sampling_topk_out_indices_cb", kSamplingTopkOutIndicesCb);
+  add(args, "sampling_phase2_scores_byte_offset", phase2ScoresByteOffset);
+  add(args, "sampling_phase2_indices_byte_offset", phase2IndicesByteOffset);
+  add(args, "sampling_mesh_stage_scores_cb", 0xFFFFFFFFu);
+  add(args, "sampling_mesh_stage_indices_cb", 0xFFFFFFFFu);
+  add(args, "sampling_scores_scratch_stage2_offset", 0);
+  add(args, "sampling_indices_scratch_stage2_offset", 0);
+  add(args, "sampling_scores_scratch_addr", 0);
+  add(args, "sampling_indices_scratch_addr", 0);
+  add(args, "sampling_scores_cb", scoresCb);
+  add(args, "sampling_scores_num_pages", scoresNumPages);
+  add(args, "sampling_scores_tile_width", scoresTileWidth);
+  add(args, "sampling_scores_tile_hw", scoresTileHW);
+  add(args, "sampling_implicit_indices", 1);
+  add(args, "sampling_loop_mcast_start_x", 0);
+  add(args, "sampling_loop_mcast_start_y", 0);
+  add(args, "sampling_loop_mcast_end_x", 0);
+  add(args, "sampling_loop_mcast_end_y", 0);
+  add(args, "sampling_loop_num_dests", 0);
+  add(args, "sampling_num_internal_iterations", 1);
+  add(args, "sampling_output_addr", 0);
+  add(args, "sampling_rand_output_addr", 0);
+  add(args, "sampling_enable_metadata", 0);
+  add(args, "sampling_copy_probabilities", 0);
+  add(args, "sampling_metadata_address", 0);
+  add(args, "sampling_copy_probabilities_to_q", 0);
+  add(args, "sampling_p_bcast_cb", kSamplingSoftmaxSubCb);
+  add(args, "sampling_rand_bcast_cb", kSamplingSumCb);
+  add(args, "sampling_mask_cb", kSamplingMaskCb);
+  add(args, "sampling_stage1_row_elements", 0);
+  add(args, "sampling_stage1_num_input_tiles", 0);
+  add(args, "sampling_stage2_row_elements", 0);
+  add(args, "sampling_stage2_num_input_tiles", 0);
+}
+
+::ttnn::Tensor runShardedArgmaxSampling(
+    const ::ttnn::Tensor &scores, uint32_t vocab, uint32_t nPerCore,
+    const std::optional<::ttnn::MemoryConfig> &outputMemoryConfig) {
+  const auto &scoreShard = *scores.shard_spec();
+  auto device = scores.device();
+  const std::vector<::tt::tt_metal::CoreCoord> samplingCores =
+      ::tt::tt_metal::corerange_to_cores(scoreShard.grid, std::nullopt,
+                                         /*row_wise=*/true);
+  const ::tt::tt_metal::CoreCoord finalCore = samplingCores.front();
+  const auto samplingGrid = coreSetFromCores(samplingCores);
+  const auto finalCoreSet = singleCoreSet(finalCore);
+
+  const auto outputIndexMemConfig = heightShardL1(finalCore, {1, 1});
+  ::ttnn::Tensor outputIndex = createDeviceTensor(
+      ::ttnn::Shape({1, 1}), ::ttnn::DataType::UINT32,
+      ::ttnn::Layout::ROW_MAJOR, std::nullopt, outputIndexMemConfig, device);
+
+  const uint32_t samplingMinAlignment = 32;
+  const uint32_t samplingL1Alignment = 16;
+  const uint32_t bf16TileSize = 2 * 32 * 32;
+  const uint32_t uint32TileSize = 4 * 32 * 32;
+  const uint32_t topkScoresSlotBytes =
+      roundUp(samplingMinAlignment * 2, samplingL1Alignment);
+  const uint32_t topkIndicesSlotBytes =
+      roundUp(samplingMinAlignment * 4, samplingL1Alignment);
+  const uint32_t winnerPageBytes =
+      topkScoresSlotBytes + topkIndicesSlotBytes;
+  const uint32_t phase1Tiles = (nPerCore + 1023) / 1024;
+  const uint32_t phase2Tiles =
+      (samplingMinAlignment * samplingCores.size() + 1023) / 1024;
+  const uint32_t totalInputTiles = phase1Tiles + phase2Tiles;
+  const uint32_t phase2ScoresByteOffset = phase1Tiles * bf16TileSize;
+  const uint32_t phase2IndicesByteOffset = phase1Tiles * uint32TileSize;
+  const auto scoreTile = scores.tensor_spec().tile();
+  const uint32_t scoreTileWidth = scoreTile.get_width();
+  const uint32_t scoreTileHW = scoreTile.get_height() * scoreTileWidth;
+  const uint32_t scoresNumPages =
+      (nPerCore + scoreTileWidth - 1) / scoreTileWidth;
+
+  ::tt::tt_metal::ProgramDescriptor program;
+  program.semaphores.push_back({
+      .id = kSamplingReceiverSemaphore,
+      .core_type = ::tt::CoreType::WORKER,
+      .core_ranges = samplingGrid,
+      .initial_value = 0,
+  });
+  program.semaphores.push_back({
+      .id = kSamplingLocalReadySemaphore,
+      .core_type = ::tt::CoreType::WORKER,
+      .core_ranges = samplingGrid,
+      .initial_value = 0,
+  });
+  program.semaphores.push_back({
+      .id = kSamplingGlobalSemaphore,
+      .core_type = ::tt::CoreType::WORKER,
+      .core_ranges = samplingGrid,
+      .initial_value = 0,
+  });
+  program.semaphores.push_back({
+      .id = kSamplingGlobalStage2Semaphore,
+      .core_type = ::tt::CoreType::WORKER,
+      .core_ranges = samplingGrid,
+      .initial_value = 0,
+  });
+  program.cbs.push_back(::tt::tt_metal::cb_descriptor_from_sharded_tensor(
+      kMatmulOutCb, scores));
+  program.cbs.push_back(makeScratchCb(
+      kSamplingWinnerCb, ::ttnn::DataType::UINT32, winnerPageBytes,
+      winnerPageBytes, samplingGrid));
+  for (uint32_t cb :
+       {kSamplingSoftmaxInCb, kSamplingSoftmaxOutCb, kSamplingSoftmaxExpCb,
+        kSamplingSoftmaxSubCb, kSamplingMaxCb, kSamplingSumCb,
+        kSamplingScalerCb, kSamplingProbsOutCb, kSamplingRandCb,
+        kSamplingMaskCb}) {
+    program.cbs.push_back(makeScratchCb(cb, ::ttnn::DataType::BFLOAT16,
+                                        bf16TileSize, bf16TileSize,
+                                        finalCoreSet));
+  }
+  program.cbs.push_back(makeScratchCb(
+      kSamplingTopkInScoresCb, ::ttnn::DataType::BFLOAT16, bf16TileSize,
+      totalInputTiles * bf16TileSize, samplingGrid));
+  program.cbs.push_back(makeScratchCb(
+      kSamplingTopkInIndicesCb, ::ttnn::DataType::UINT32, uint32TileSize,
+      totalInputTiles * uint32TileSize, samplingGrid));
+  program.cbs.push_back(makeScratchCb(
+      kSamplingTopkOutScoresCb, ::ttnn::DataType::BFLOAT16, bf16TileSize,
+      bf16TileSize, samplingGrid));
+  program.cbs.push_back(makeScratchCb(
+      kSamplingTopkOutIndicesCb, ::ttnn::DataType::UINT32, uint32TileSize,
+      uint32TileSize, samplingGrid));
+
+  const auto finalCorePhys = device->worker_core_from_logical_core(finalCore);
+  NamedArgs baseArgs;
+  addSamplingCommonNamedArgs(
+      baseArgs, samplingCores.size(), topkScoresSlotBytes,
+      winnerPageBytes, phase2ScoresByteOffset, phase2IndicesByteOffset,
+      kSamplingReceiverSemaphore, kSamplingLocalReadySemaphore,
+      kMatmulOutCb, scoresNumPages, scoreTileWidth, scoreTileHW);
+
+  ::tt::tt_metal::KernelDescriptor::RTArgList ncriscArgs;
+  ncriscArgs.push_back(scores.mesh_tensor());
+  ncriscArgs.push_back(0u);
+  ncriscArgs.push_back(outputIndex.mesh_tensor());
+  ncriscArgs.push_back(finalCorePhys.x);
+  ncriscArgs.push_back(finalCorePhys.y);
+  ncriscArgs.push_back(kSamplingGlobalSemaphore);
+  ncriscArgs.push_back(kSamplingGlobalStage2Semaphore);
+
+  ::tt::tt_metal::KernelDescriptor::RTArgList briscArgs;
+  briscArgs.push_back(finalCorePhys.x);
+  briscArgs.push_back(finalCorePhys.y);
+  briscArgs.push_back(outputIndex.mesh_tensor());
+
+  for (uint32_t i = 0; i < samplingCores.size(); ++i) {
+    const auto &core = samplingCores[i];
+    const uint32_t start = i * nPerCore;
+    const uint32_t valid = start < vocab ? std::min(nPerCore, vocab - start) : 0;
+    NamedArgs coreArgs = baseArgs;
+    add(coreArgs, "sampling_is_active_core", valid > 0 ? 1 : 0);
+    add(coreArgs, "sampling_is_final_core", core == finalCore ? 1 : 0);
+    add(coreArgs, "sampling_mesh_sender_core", 0);
+    add(coreArgs, "sampling_sender_idx", i);
+    add(coreArgs, "sampling_index_base", start);
+    add(coreArgs, "sampling_num_values", std::max<uint32_t>(valid, 1));
+
+    program.kernels.push_back(makeSamplingKernel(
+        core, coreArgs,
+        ::tt::tt_metal::DataMovementConfigDescriptor{
+            ::tt::tt_metal::DataMovementProcessor::RISCV_1,
+            ::tt::tt_metal::NOC::RISCV_0_default,
+            ::tt::tt_metal::NOC_MODE::DM_DYNAMIC_NOC},
+        ncriscArgs));
+    program.kernels.push_back(makeSamplingKernel(
+        core, coreArgs,
+        ::tt::tt_metal::DataMovementConfigDescriptor{
+            ::tt::tt_metal::DataMovementProcessor::RISCV_0,
+            ::tt::tt_metal::NOC::RISCV_1_default,
+            ::tt::tt_metal::NOC_MODE::DM_DYNAMIC_NOC},
+        briscArgs));
+    program.kernels.push_back(makeSamplingKernel(
+        core, coreArgs,
+        ::tt::tt_metal::ComputeConfigDescriptor{
+            ::tt::tt_metal::MathFidelity::LoFi,
+            /*fp32_dest_acc_en=*/true, /*dst_full_sync_en=*/false, {},
+            /*bfp8_pack_precise=*/false, /*math_approx_mode=*/false},
+        {}));
+  }
+
+  ::ttnn::Tensor result = ::ttnn::generic_op({scores, outputIndex}, program);
+  if (outputMemoryConfig && result.memory_config() != *outputMemoryConfig) {
+    result = ::ttnn::to_memory_config(result, *outputMemoryConfig);
+  }
+  return result;
+}
+
+::ttnn::Tensor runShardedSampling(
+    const ::ttnn::Tensor &normalized, const ::ttnn::Tensor &lmHeadWeight,
+    const std::optional<::ttnn::MemoryConfig> &outputMemoryConfig) {
+  const ::ttnn::Shape &weightShape = lmHeadWeight.logical_shape();
+  const uint32_t vocab = static_cast<uint32_t>(weightShape[-2]);
+  auto device = normalized.device();
+  const auto fullGrid = device->compute_with_storage_grid_size();
+  const uint32_t maxCores = fullGrid.x * fullGrid.y;
+  const uint32_t nPerCore = paddedShardWidth(vocab, maxCores);
+  const uint32_t usedCores =
+      std::min(maxCores, (vocab + nPerCore - 1) / nPerCore);
+  const auto grid = rowWiseCorePrefix(fullGrid, usedCores);
+  const auto logitsMemoryConfig =
+      widthShardL1(grid, {tt::constants::TILE_HEIGHT, nPerCore});
+  const ::ttnn::Shape &inputShape = normalized.logical_shape();
+  const uint32_t hidden = static_cast<uint32_t>(inputShape[-1]);
+  const uint32_t hiddenPerCore = paddedShardWidth(hidden, usedCores);
+  const auto inputMemoryConfig =
+      widthShardL1(grid, {tt::constants::TILE_HEIGHT, hiddenPerCore});
+  ::ttnn::Tensor shardedNormalized =
+      ::ttnn::to_memory_config(normalized, inputMemoryConfig);
+  ::ttnn::Tensor logits = ::ttnn::matmul(
+      shardedNormalized, lmHeadWeight,
+      /*transpose_a=*/false, /*transpose_b=*/true,
+      /*memory_config=*/logitsMemoryConfig,
+      /*dtype=*/::ttnn::DataType::BFLOAT16,
+      /*program_config=*/std::nullopt, /*activation=*/std::nullopt,
+      /*compute_kernel_config=*/std::nullopt, /*core_grid=*/std::nullopt,
+      /*output_tile=*/std::nullopt, /*optional_output_tensor=*/std::nullopt);
+  return runShardedArgmaxSampling(logits, vocab, nPerCore, outputMemoryConfig);
+}
+
+} // namespace
+
+void run(const ::tt::target::ttnn::LMHeadSamplingOp *op,
+         ProgramContext &context) {
+  ProgramTensorPool &tensorPool = context.getTensorPool();
+
+  const ::ttnn::Tensor &input =
+      tensorPool.getTTNNTensorAndValidate(op->input());
+  const ::ttnn::Tensor &normWeight =
+      tensorPool.getTTNNTensorAndValidate(op->norm_weight());
+  const ::ttnn::Tensor &lmHeadWeight =
+      tensorPool.getTTNNTensorAndValidate(op->lm_head_weight());
+
+  std::optional<::ttnn::MemoryConfig> outputMemoryConfig =
+      ::tt::runtime::ttnn::utils::createMemoryConfigIfNeeded(op->memcfg());
+
+  const ::ttnn::MemoryConfig shardConfig =
+      createDecodeRMSNormShardConfig(input);
+  ::ttnn::Tensor rmsInput = ::ttnn::to_memory_config(input, shardConfig);
+  std::optional<::ttnn::prim::LayerNormProgramConfig> programConfig =
+      ::ttnn::prim::create_layernorm_program_config(
+          rmsInput.shard_spec(), rmsInput.tensor_spec().tile().get_height(),
+          rmsInput.tensor_spec().tile().get_width());
+
+  ::ttnn::Tensor normalized = ::ttnn::rms_norm(
+      rmsInput, op->epsilon(), std::optional<::ttnn::Tensor>(normWeight),
+      /*bias=*/std::nullopt, /*residual_input_tensor=*/std::nullopt,
+      shardConfig, programConfig,
+      /*compute_kernel_config=*/std::nullopt);
+
+  ::ttnn::Tensor output =
+      runShardedSampling(normalized, lmHeadWeight, outputMemoryConfig);
+
+  tensorPool.insertTTNNTensorAndValidate(op->out(), output);
+}

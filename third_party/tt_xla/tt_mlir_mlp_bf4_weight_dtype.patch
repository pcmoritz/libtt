+// Transformer MLP projections are substantially rectangular: their expanded
+// dimension is typically 2-8x the hidden width. Attention projections are
+// square or at most 2x, while vocabulary projections are much wider.
+static bool isMLPProjectionWeight(RankedTensorType weightType) {
+  if (weightType.getRank() < 2) {
+    return false;
+  }
+
+  ArrayRef<int64_t> shape = weightType.getShape();
+  int64_t dim0 = shape[shape.size() - 2];
+  int64_t dim1 = shape.back();
+  if (ShapedType::isDynamic(dim0) || ShapedType::isDynamic(dim1)) {
+    return false;
+  }
+
+  int64_t narrow = dim0 < dim1 ? dim0 : dim1;
+  int64_t wide = dim0 < dim1 ? dim1 : dim0;
+  constexpr int64_t kMinHiddenWidth = 2048;
+  return narrow >= kMinHiddenWidth && wide >= 2 * narrow &&
+         wide <= 8 * narrow;
+}

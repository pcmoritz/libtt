+// Return the allocation shared by every piece of a composite view.  Generic
+// results alias their destination operands, and view_layout preserves that
+// backing allocation.
+Value getSharedBackingStorage(CompositeViewOp compositeView) {
+  Value shared;
+  for (Value input : compositeView.getInputs()) {
+    Value current = input;
+    if (auto generic = current.getDefiningOp<GenericOp>()) {
+      auto result = mlir::cast<OpResult>(current);
+      if (result.getResultNumber() >= generic.getOutputs().size()) {
+        return {};
+      }
+      current = generic.getOutputs()[result.getResultNumber()];
+    }
+    while (auto view = current.getDefiningOp<ViewLayoutOp>()) {
+      current = view.getInput();
+    }
+    if (shared && shared != current) {
+      return {};
+    }
+    shared = current;
+  }
+
+  auto sharedType = mlir::dyn_cast_if_present<ShapedType>(shared.getType());
+  auto resultType =
+      mlir::cast<ShapedType>(compositeView.getResult().getType());
+  return sharedType && sharedType.getShape() == resultType.getShape() ? shared
+                                                                     : Value{};
+}

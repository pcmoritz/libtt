+void run(const ::tt::target::ttnn::CausalConv1dUpdateOp *op,
+         ProgramContext &context) {
+  ProgramTensorPool &tensorPool = context.getTensorPool();
+  const ::ttnn::Tensor &input =
+      tensorPool.getTTNNTensorAndValidate(op->input());
+  const ::ttnn::Tensor &statePool =
+      tensorPool.getTTNNTensorAndValidate(op->state_pool());
+  const ::ttnn::Tensor &weight =
+      tensorPool.getTTNNTensorAndValidate(op->weight());
+  const ::ttnn::Tensor &stateIndices =
+      tensorPool.getTTNNTensorAndValidate(op->state_indices());
+  const ::ttnn::Tensor &hasInitialState =
+      tensorPool.getTTNNTensorAndValidate(op->has_initial_state());
+
+  ::ttnn::Tensor output = ::ttnn::transformer::causal_conv1d_update(
+      input, statePool, weight, stateIndices, hasInitialState);
+
+  tensorPool.insertTTNNTensorAndValidate(op->final_state_pool(), statePool);
+  tensorPool.insertTTNNTensorAndValidate(op->output(), output);
+}

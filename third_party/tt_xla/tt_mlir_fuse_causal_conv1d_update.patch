+class CausalConv1dUpdateOpConversionPattern
+    : public OpConversionPattern<ttir::CausalConv1dUpdateOp> {
+public:
+  using OpConversionPattern<ttir::CausalConv1dUpdateOp>::OpConversionPattern;
+
+  LogicalResult
+  matchAndRewrite(ttir::CausalConv1dUpdateOp op, OpAdaptor adaptor,
+                  ConversionPatternRewriter &rewriter) const override {
+    SmallVector<Type> resultTypes;
+    for (Type type : op.getResultTypes()) {
+      Type converted = getTypeConverter()->convertType(type);
+      if (!converted) {
+        return rewriter.notifyMatchFailure(
+            op, "failed to convert causal conv update result type");
+      }
+      resultTypes.push_back(converted);
+    }
+    rewriter.replaceOpWithNewOp<ttnn::CausalConv1dUpdateOp>(
+        op, resultTypes, adaptor.getInput(), adaptor.getStatePool(),
+        adaptor.getWeight(), adaptor.getStateIndices(),
+        adaptor.getHasInitialState());
+    return success();
+  }
+};

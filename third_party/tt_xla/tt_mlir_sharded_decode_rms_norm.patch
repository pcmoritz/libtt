-  );
+  std::optional<::ttnn::MemoryConfig> shardConfig =
+      createDecodeRMSNormShardConfig(input);
+  ::ttnn::Tensor rmsInput = input;
+  std::optional<::ttnn::MemoryConfig> rmsMemoryConfig = memoryConfig;
+  std::optional<::ttnn::prim::LayerNormProgramConfig> programConfig =
+      std::nullopt;
+
+  if (shardConfig) {
+    rmsInput = ::ttnn::to_memory_config(input, *shardConfig);
+    rmsMemoryConfig = *shardConfig;
+    programConfig = ::ttnn::prim::create_layernorm_program_config(
+        rmsInput.shard_spec(), rmsInput.tensor_spec().tile().get_height(),
+        rmsInput.tensor_spec().tile().get_width());
+  }
+
+  ::ttnn::Tensor output = ::ttnn::rms_norm(
+      rmsInput, epsilon, weight, bias,
+      /*residual_input_tensor=*/std::nullopt, rmsMemoryConfig, programConfig,
+      computeConfig);
+  if (shardConfig) {
+    output = ::ttnn::to_memory_config(
+        output, memoryConfig.value_or(input.memory_config()));
+  }
 
   tensorPool.insertTTNNTensorAndValidate(op->out(), output);

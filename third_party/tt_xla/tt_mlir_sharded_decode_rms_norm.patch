 namespace tt::runtime::ttnn::operations::rms_norm {
+namespace {
+
+std::optional<::ttnn::MemoryConfig>
+createDecodeRMSNormShardConfig(const ::ttnn::Tensor &input) {
+  if (input.is_sharded() || input.layout() != ::ttnn::Layout::TILE ||
+      input.storage_type() != ::ttnn::StorageType::DEVICE) {
+    return std::nullopt;
+  }
+
+  const ::ttnn::Shape &shape = input.logical_shape();
+  if (shape.rank() < 2 || shape[-2] != 1 || shape[-1] < 2048) {
+    return std::nullopt;
+  }
+
+  constexpr uint32_t kShardCores = 8;
+  const uint32_t width = static_cast<uint32_t>(shape[-1]);
+  const uint32_t shardWidth = width / kShardCores;
+  if (width % kShardCores != 0 ||
+      shardWidth % tt::constants::TILE_WIDTH != 0) {
+    return std::nullopt;
+  }
+
+  const auto grid = ::tt::tt_metal::CoreRangeSet(
+      {::tt::tt_metal::CoreRange({0, 0}, {kShardCores - 1, 0})});
+  return ::ttnn::operations::data_movement::create_sharded_memory_config(
+      shape, grid, ::ttnn::operations::data_movement::ShardStrategy::WIDTH,
+      ::tt::tt_metal::ShardOrientation::ROW_MAJOR,
+      std::array<uint32_t, 2>{tt::constants::TILE_HEIGHT, shardWidth},
+      ::ttnn::Layout::TILE);
+}
+
+} // namespace

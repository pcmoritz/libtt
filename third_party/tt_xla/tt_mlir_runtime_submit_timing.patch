+bool submitTimingEnabled() {
+  static const bool enabled = [] {
+    const char *env = std::getenv("TT_XLA_COMPILE_TIMING");
+    return env && env[0] != '\0' && env[0] != '0';
+  }();
+  return enabled;
+}
+
+class SubmitPhaseTimer {
+public:
+  explicit SubmitPhaseTimer(std::string label)
+      : label(std::move(label)), start(std::chrono::steady_clock::now()),
+        enabled(submitTimingEnabled()) {
+    if (enabled) {
+      LOG_INFO("[tt-mlir submit timing] start ", this->label);
+    }
+  }
+
+  ~SubmitPhaseTimer() {
+    if (!enabled) {
+      return;
+    }
+    auto end = std::chrono::steady_clock::now();
+    double elapsedMs =
+        std::chrono::duration<double, std::milli>(end - start).count();
+    LOG_INFO("[tt-mlir submit timing] done ", label, ": ", elapsedMs, " ms");
+  }
+
+private:
+  std::string label;
+  std::chrono::steady_clock::time_point start;
+  bool enabled;
+};
+
+std::string programLabel(const ::tt::target::ttnn::Program *program,
+                         const char *phase) {
+  std::string label = "program ";
+  label += program->name()->c_str();
+  label += " ";
+  label += phase;
+  return label;
+}
+
+std::string opLabel(const ::tt::target::ttnn::Program *program,
+                    const ::tt::target::ttnn::Operation *op, size_t index) {
+  std::string label = "program ";
+  label += program->name()->c_str();
+  label += " op#";
+  label += std::to_string(index);
+  label += " ";
+  label += ::tt::target::ttnn::EnumNameOpType(op->type_type());
+  if (op->loc_info() && op->loc_info()->size() > 0) {
+    label += " loc=";
+    label += op->loc_info()->c_str();
+  }
+  if (op->debug_info() && op->debug_info()->size() > 0) {
+    label += " debug=";
+    label += op->debug_info()->c_str();
+  }
+  return label;
+}
+

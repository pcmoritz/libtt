+OutputHints RmsNormRuleBook::getOutputHints(Operation *op, const std::vector<OpConfig> &legalConfigs) const {
+  OutputHints result = OpRuleBook::getOutputHints(op, legalConfigs);
+  if (op->getNumResults() == 0) return result;
+  auto resultType = mlir::dyn_cast<RankedTensorType>(op->getResult(0).getType());
+  if (!resultType || resultType.getRank() != 4) return result;
+  ArrayRef<int64_t> shape = resultType.getShape();
+  if (shape[0] != 1 || shape[1] != 1 || shape[3] != 128 || (shape[2] != 8 && shape[2] != 32)) return result;
+  auto seed = mlir::dyn_cast_or_null<TTNNLayoutAttr>(resultType.getEncoding()); if (!seed) return result;
+  TTNNLayoutAttr layout = TTNNLayoutAttr::Builder(seed, shape).setBufferType(BufferType::L1).setMemoryLayout(TensorMemoryLayout::HeightSharded).setGridShape({1, 1}).buildWithCanonicalCorePlacement(ttcore::lookupDevice(op));
+  auto hasOutputLayout = [&](const OpConfig &config) { return config.outputLayout == layout; };
+  if (llvm::none_of(result.hints, hasOutputLayout)) result.hints.insert(result.hints.begin(), OpConfig(layout));
+  llvm::erase_if(result.fallbackHints, hasOutputLayout);
+  return result;
+}
+bool RmsNormRuleBook::isValidOutputHintForInputs(const OpConfig &hint, llvm::ArrayRef<TTNNLayoutAttr> inputLayouts) const {
+  if (inputLayouts.empty() || !inputLayouts[0]) return true;
+  auto inputMem = inputLayouts[0].getMemLayout();
+  if (!inputMem || !isShardedMemoryLayout(inputMem.getValue())) return true;
+  if (!hint.outputLayout) return false;
+  auto outputMem = hint.outputLayout.getMemLayout();
+  if (!outputMem || !isShardedMemoryLayout(outputMem.getValue())) return false;
+  if (inputMem.getValue() == TensorMemoryLayout::HeightSharded) return outputMem.getValue() == TensorMemoryLayout::HeightSharded && hint.outputLayout.getGridShape() == inputLayouts[0].getGridShape();
+  return outputMem.getValue() != TensorMemoryLayout::HeightSharded;
+}

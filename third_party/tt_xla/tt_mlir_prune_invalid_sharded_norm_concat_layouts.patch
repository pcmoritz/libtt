+bool RmsNormRuleBook::isValidOutputHintForInputs(
+    const OpConfig &hint, llvm::ArrayRef<TTNNLayoutAttr> inputLayouts) const {
+  if (inputLayouts.empty() || !inputLayouts[0]) {
+    return true;
+  }
+
+  auto inputMem = inputLayouts[0].getMemLayout();
+  if (!inputMem || !isShardedMemoryLayout(inputMem.getValue())) {
+    return true;
+  }
+
+  if (!hint.outputLayout) {
+    return false;
+  }
+  auto outputMem = hint.outputLayout.getMemLayout();
+  if (!outputMem || !isShardedMemoryLayout(outputMem.getValue())) {
+    return false;
+  }
+
+  return inputMem.getValue() == TensorMemoryLayout::HeightSharded ||
+         outputMem.getValue() != TensorMemoryLayout::HeightSharded;
+}

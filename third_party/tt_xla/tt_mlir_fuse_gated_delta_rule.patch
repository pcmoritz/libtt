+
+namespace tt::runtime::ttnn::operations::transformer {
+
+namespace {
+
+constexpr int64_t kChunkSize = 128;
+constexpr int64_t kTileSize = 32;
+
+const ::ttnn::MemoryConfig kDram = ::ttnn::DRAM_MEMORY_CONFIG;
+const ::ttnn::MemoryConfig kL1 = ::ttnn::L1_MEMORY_CONFIG;
+
+::ttnn::DeviceComputeKernelConfig getComputeConfig() {
+  return {
+      .math_fidelity = ::tt::tt_metal::MathFidelity::HiFi2,
+      .math_approx_mode = false,
+      .fp32_dest_acc_en = true,
+      .packer_l1_acc = false,
+  };
+}
+
+::ttnn::Tensor reshape(const ::ttnn::Tensor &input,
+                       std::initializer_list<uint32_t> shape,
+                       const std::optional<::ttnn::MemoryConfig> &memoryConfig =
+                           std::nullopt) {
+  return ::ttnn::reshape(input, ::ttnn::Shape(shape), memoryConfig);
+}
+
+::ttnn::Tensor toF32TileDram(const ::ttnn::Tensor &input) {
+  ::ttnn::Tensor result = input;
+  if (result.layout() != ::ttnn::Layout::TILE) {
+    result = ::ttnn::to_layout(result, ::ttnn::Layout::TILE,
+                               ::ttnn::DataType::FLOAT32, kDram);
+  } else if (result.dtype() != ::ttnn::DataType::FLOAT32) {
+    result = ::ttnn::typecast(result, ::ttnn::DataType::FLOAT32, kDram);
+  }
+  if (result.memory_config() != kDram) {
+    result = ::ttnn::to_memory_config(result, kDram);
+  }
+  return result;
+}
+
+::ttnn::Tensor multiply(
+    const ::ttnn::Tensor &lhs, const ::ttnn::Tensor &rhs,
+    const std::optional<::ttnn::MemoryConfig> &memoryConfig = kDram) {
+  return ::ttnn::multiply(lhs, rhs, std::nullopt, memoryConfig);
+}
+
+::ttnn::Tensor multiply(
+    const ::ttnn::Tensor &lhs, float rhs,
+    const std::optional<::ttnn::MemoryConfig> &memoryConfig = kDram) {
+  return ::ttnn::multiply(lhs, rhs, std::nullopt, memoryConfig);
+}
+
+::ttnn::Tensor add(
+    const ::ttnn::Tensor &lhs, const ::ttnn::Tensor &rhs,
+    const std::optional<::ttnn::MemoryConfig> &memoryConfig = kDram) {
+  return ::ttnn::add(lhs, rhs, std::nullopt, memoryConfig);
+}
+
+::ttnn::Tensor add(
+    const ::ttnn::Tensor &lhs, float rhs,
+    const std::optional<::ttnn::MemoryConfig> &memoryConfig = kDram) {
+  return ::ttnn::add(lhs, rhs, std::nullopt, memoryConfig);
+}
+
+::ttnn::Tensor subtract(
+    const ::ttnn::Tensor &lhs, const ::ttnn::Tensor &rhs,
+    const std::optional<::ttnn::MemoryConfig> &memoryConfig = kDram) {
+  return ::ttnn::subtract(lhs, rhs, std::nullopt, memoryConfig);
+}
+
+::ttnn::Tensor matmul(
+    const ::ttnn::Tensor &lhs, const ::ttnn::Tensor &rhs,
+    const std::optional<::ttnn::MemoryConfig> &memoryConfig = kDram) {
+  return ::ttnn::matmul(lhs, rhs, false, false, memoryConfig,
+                        ::ttnn::DataType::FLOAT32, std::nullopt, std::nullopt,
+                        getComputeConfig());
+}
+
+::ttnn::Tensor expClamped(const ::ttnn::Tensor &input,
+                          const std::optional<::ttnn::MemoryConfig>
+                              &memoryConfig = kDram) {
+  ::ttnn::Tensor clipped =
+      ::ttnn::clip(input, -20.0f, 0.0f, memoryConfig);
+  return ::ttnn::exp(clipped, false, memoryConfig);
+}
+
+::ttnn::Tensor slice(const ::ttnn::Tensor &input,
+                     std::initializer_list<int32_t> begin,
+                     std::initializer_list<int32_t> end,
+                     const std::optional<::ttnn::MemoryConfig> &memoryConfig =
+                         kDram) {
+  ::ttsl::SmallVector<int32_t> begins(begin);
+  ::ttsl::SmallVector<int32_t> ends(end);
+  ::ttsl::SmallVector<int32_t> steps(begins.size(), 1);
+  return ::ttnn::slice(input, begins, ends, steps, memoryConfig);
+}
+
+::ttnn::Tensor padSequence(const ::ttnn::Tensor &input,
+                           uint32_t sequenceLength) {
+  if (sequenceLength == kChunkSize) {
+    return input;
+  }
+  ::ttsl::SmallVector<::ttnn::operations::data_movement::PadSpecDim> padding = {
+      {0, 0}, {0, static_cast<uint32_t>(kChunkSize) - sequenceLength}, {0, 0}};
+  return ::ttnn::pad(input, padding, 0.0f, true, kDram);
+}
+
+::ttnn::Tensor toHeadMajor3D(const ::ttnn::Tensor &input) {
+  ::ttnn::Tensor rowMajor = ::ttnn::to_layout(
+      input, ::ttnn::Layout::ROW_MAJOR, std::nullopt, kDram);
+  ::ttnn::Tensor permuted =
+      ::ttnn::permute(rowMajor, ::ttsl::SmallVector<int64_t>{1, 0, 2}, kDram);
+  return toF32TileDram(permuted);
+}
+
+::ttnn::Tensor toHeadMajor2D(const ::ttnn::Tensor &input) {
+  ::ttnn::Tensor rowMajor = ::ttnn::to_layout(
+      input, ::ttnn::Layout::ROW_MAJOR, std::nullopt, kDram);
+  ::ttnn::Tensor permuted =
+      ::ttnn::permute(rowMajor, ::ttsl::SmallVector<int64_t>{1, 0}, kDram);
+  return toF32TileDram(permuted);
+}
+
+::ttnn::Tensor l2Normalize(const ::ttnn::Tensor &input) {
+  ::ttnn::Tensor squared = ::ttnn::square(input, kDram);
+  ::ttnn::Tensor normSquared = ::ttnn::sum(
+      squared, int64_t{-1}, true, kDram, getComputeConfig());
+  ::ttnn::Tensor inverseNorm =
+      ::ttnn::rsqrt(add(normSquared, 1.0e-6f), false, kDram);
+  return multiply(input, inverseNorm);
+}
+
+::ttnn::Tensor solveLowerTriangular(const ::ttnn::Tensor &matrix,
+                                    const ::ttnn::Tensor &identity32,
+                                    uint32_t batch) {
+  ::ttnn::Tensor diagonalMatrix = multiply(matrix, identity32, kL1);
+  ::ttnn::Tensor diagonal = ::ttnn::sum(
+      diagonalMatrix, int64_t{-1}, false, kL1, getComputeConfig());
+  ::ttnn::Tensor diagonalInverse = ::ttnn::reciprocal(diagonal, kL1);
+  ::ttnn::Tensor inverseRows =
+      reshape(diagonalInverse, {batch, kTileSize, 1}, kL1);
+  ::ttnn::Tensor inverseColumns =
+      reshape(diagonalInverse, {batch, 1, kTileSize}, kL1);
+
+  ::ttnn::Tensor strictLower = subtract(matrix, diagonalMatrix, kL1);
+  ::ttnn::Tensor normalized = multiply(inverseRows, strictLower, kL1);
+  ::ttnn::Tensor power = ::ttnn::neg(normalized, kL1);
+  ::ttnn::Tensor result = add(identity32, power, kL1);
+  power = matmul(power, power, kL1);
+
+  for (int step = 0; step < 4; ++step) {
+    result = matmul(result, add(identity32, power, kL1), kL1);
+    power = matmul(power, power, kL1);
+  }
+  result = multiply(result, inverseColumns, kL1);
+
+  for (int step = 0; step < 2; ++step) {
+    ::ttnn::Tensor residual = subtract(
+        add(identity32, identity32, kL1), matmul(matrix, result, kL1), kL1);
+    result = matmul(result, residual, kL1);
+  }
+  return result;
+}
+
+::ttnn::Tensor computeBlockInverses(const ::ttnn::Tensor &lowerTriangular,
+                                    const ::ttnn::Tensor &identity32,
+                                    uint32_t numHeads) {
+  ::ttnn::Tensor flat =
+      reshape(lowerTriangular, {numHeads, kChunkSize, kChunkSize}, kDram);
+  std::vector<::ttnn::Tensor> inverseBlocks;
+  inverseBlocks.reserve(kChunkSize / kTileSize);
+  for (int32_t block = 0; block < kChunkSize / kTileSize; ++block) {
+    int32_t offset = block * kTileSize;
+    int32_t end = offset + static_cast<int32_t>(kTileSize);
+    ::ttnn::Tensor diagonalBlock =
+        slice(flat, {0, offset, offset},
+              {static_cast<int32_t>(numHeads), end, end},
+              kL1);
+    inverseBlocks.push_back(
+        solveLowerTriangular(diagonalBlock, identity32, numHeads));
+  }
+  ::ttnn::Tensor concatenated = ::ttnn::concat(inverseBlocks, 1, kDram);
+  return reshape(concatenated,
+                 {numHeads, 1, kChunkSize, kTileSize}, kDram);
+}
+
+struct SequenceResult {
+  ::ttnn::Tensor output;
+  ::ttnn::Tensor state;
+};
+
+SequenceResult runSequence(
+    ::ttnn::Tensor query, ::ttnn::Tensor key, ::ttnn::Tensor value,
+    ::ttnn::Tensor beta, ::ttnn::Tensor gate,
+    const ::ttnn::Tensor &initialState,
+    const ::ttnn::Tensor &upperTriangular,
+    const ::ttnn::Tensor &lowerTriangular,
+    const ::ttnn::Tensor &identity, const ::ttnn::Tensor &identity32,
+    uint32_t sequenceLength, uint32_t numHeads) {
+  query = multiply(query, 1.0f / std::sqrt(static_cast<float>(kChunkSize)));
+  query = padSequence(query, sequenceLength);
+  key = padSequence(key, sequenceLength);
+  value = padSequence(value, sequenceLength);
+  beta = padSequence(beta, sequenceLength);
+  gate = padSequence(gate, sequenceLength);
+  ::ttnn::Tensor gate2D = reshape(gate, {numHeads, kChunkSize});
+
+  ::ttnn::Tensor valueBeta = multiply(value, beta);
+  ::ttnn::Tensor keyBeta = multiply(key, beta);
+
+  ::ttnn::Tensor gateRow = reshape(gate2D, {numHeads, 1, kChunkSize});
+  ::ttnn::Tensor decayRaw =
+      reshape(matmul(gateRow, upperTriangular), {numHeads, kChunkSize});
+  ::ttnn::Tensor decayOffset =
+      slice(decayRaw, {0, 0}, {static_cast<int32_t>(numHeads), 1});
+  ::ttnn::Tensor decayNormalized = subtract(decayRaw, decayOffset);
+  ::ttnn::Tensor decayExp =
+      reshape(expClamped(decayRaw), {numHeads, kChunkSize, 1});
+
+  ::ttnn::Tensor decayColumn =
+      reshape(decayNormalized, {numHeads, kChunkSize, 1});
+  ::ttnn::Tensor decayRow =
+      reshape(decayNormalized, {numHeads, 1, kChunkSize});
+  ::ttnn::Tensor decayDifference = subtract(decayColumn, decayRow);
+  ::ttnn::Tensor lowerDifference =
+      multiply(decayDifference, lowerTriangular);
+  ::ttnn::Tensor lowerMask =
+      multiply(expClamped(lowerDifference), lowerTriangular);
+
+  ::ttnn::Tensor keyTranspose = ::ttnn::transpose(key, 1, 2, kDram);
+  ::ttnn::Tensor keyGram = matmul(keyBeta, keyTranspose);
+  ::ttnn::Tensor lowerSystem =
+      add(identity, multiply(keyGram, lowerMask));
+
+  ::ttnn::Tensor diagonalMatrix = multiply(lowerSystem, identity);
+  ::ttnn::Tensor diagonal = ::ttnn::sum(
+      diagonalMatrix, int64_t{-1}, false, kDram, getComputeConfig());
+  ::ttnn::Tensor diagonalInverse = ::ttnn::reciprocal(diagonal, kDram);
+  ::ttnn::Tensor inverseRows =
+      reshape(diagonalInverse, {numHeads, kChunkSize, 1});
+  ::ttnn::Tensor normalizedStrictLower = multiply(
+      inverseRows, subtract(lowerSystem, diagonalMatrix));
+  ::ttnn::Tensor lowerUnit = add(identity, normalizedStrictLower);
+
+  ::ttnn::Tensor valueBetaScaled = multiply(inverseRows, valueBeta);
+  ::ttnn::Tensor keyBetaDecay = multiply(keyBeta, decayExp);
+  ::ttnn::Tensor keyBetaDecayScaled = multiply(inverseRows, keyBetaDecay);
+
+  ::ttnn::Tensor decay3D =
+      reshape(decayNormalized, {numHeads, 1, kChunkSize});
+  ::ttnn::Tensor decayRaw3D = reshape(decayRaw, {numHeads, 1, kChunkSize});
+  ::ttnn::Tensor decayLastRaw = reshape(
+      ::ttnn::sum(gate2D, int64_t{-1}, false, kDram, getComputeConfig()),
+      {numHeads, 1, 1});
+  ::ttnn::Tensor decayLastNormalized =
+      slice(decay3D, {0, 0, kChunkSize - 1},
+            {static_cast<int32_t>(numHeads), 1, kChunkSize});
+
+  ::ttnn::Tensor query4D =
+      reshape(query, {numHeads, 1, kChunkSize, kChunkSize});
+  ::ttnn::Tensor queryDecay = multiply(
+      query4D,
+      reshape(expClamped(decayRaw3D), {numHeads, 1, kChunkSize, 1}));
+
+  ::ttnn::Tensor decayToChunkEnd =
+      subtract(decayLastNormalized, decay3D);
+  ::ttnn::Tensor key4D =
+      reshape(key, {numHeads, 1, kChunkSize, kChunkSize});
+  ::ttnn::Tensor keyDecay = multiply(
+      key4D, reshape(expClamped(decayToChunkEnd),
+                     {numHeads, 1, kChunkSize, 1}));
+  ::ttnn::Tensor keyDecayTranspose =
+      ::ttnn::transpose(keyDecay, 2, 3, kDram);
+  ::ttnn::Tensor chunkDecay =
+      reshape(expClamped(decayLastRaw), {numHeads, 1, 1, 1});
+
+  ::ttnn::Tensor lowerMask4D =
+      reshape(lowerMask, {numHeads, 1, kChunkSize, kChunkSize});
+  ::ttnn::Tensor key4DTranspose = ::ttnn::transpose(key4D, 2, 3, kDram);
+  ::ttnn::Tensor intraAttention =
+      multiply(matmul(query4D, key4DTranspose), lowerMask4D);
+
+  ::ttnn::Tensor lowerUnit4D =
+      reshape(lowerUnit, {numHeads, 1, kChunkSize, kChunkSize});
+  ::ttnn::Tensor valueBetaScaled4D =
+      reshape(valueBetaScaled, {numHeads, 1, kChunkSize, kChunkSize});
+  ::ttnn::Tensor keyBetaDecayScaled4D =
+      reshape(keyBetaDecayScaled,
+              {numHeads, 1, kChunkSize, kChunkSize});
+  ::ttnn::Tensor inverseBlocks =
+      computeBlockInverses(lowerUnit4D, identity32, numHeads);
+
+  auto [output, finalState] = ::ttnn::transformer::gated_delta_attn_seq(
+      lowerUnit4D, valueBetaScaled4D, keyBetaDecayScaled4D, intraAttention,
+      queryDecay, keyDecayTranspose, chunkDecay, inverseBlocks, initialState,
+      kDram, getComputeConfig());
+  return {reshape(output, {numHeads, kChunkSize, kChunkSize}), finalState};
+}
+
+} // namespace
+
+void run(const ::tt::target::ttnn::GatedDeltaRuleOp *op,
+         ProgramContext &context) {
+  ProgramTensorPool &tensorPool = context.getTensorPool();
+  const ::ttnn::Tensor &queryInput =
+      tensorPool.getTTNNTensorAndValidate(op->query());
+  const ::ttnn::Tensor &keyInput =
+      tensorPool.getTTNNTensorAndValidate(op->key());
+  const ::ttnn::Tensor &valueInput =
+      tensorPool.getTTNNTensorAndValidate(op->value());
+  const ::ttnn::Tensor &betaInput =
+      tensorPool.getTTNNTensorAndValidate(op->beta_logits());
+  const ::ttnn::Tensor &gateInput =
+      tensorPool.getTTNNTensorAndValidate(op->gate_logits());
+  const ::ttnn::Tensor &validInput =
+      tensorPool.getTTNNTensorAndValidate(op->valid_mask());
+  const ::ttnn::Tensor &requestIndicesInput =
+      tensorPool.getTTNNTensorAndValidate(op->request_indices());
+  const ::ttnn::Tensor &decayInput =
+      tensorPool.getTTNNTensorAndValidate(op->decay());
+  const ::ttnn::Tensor &dtBiasInput =
+      tensorPool.getTTNNTensorAndValidate(op->dt_bias());
+  const ::ttnn::Tensor &initialStateInput =
+      tensorPool.getTTNNTensorAndValidate(op->initial_state());
+
+  const auto &inputShape = queryInput.logical_shape();
+  LOG_ASSERT(inputShape.rank() == 3 && inputShape[2] == kChunkSize,
+             "Gated delta rule requires [T, H, 128] inputs");
+  uint32_t sequenceLength = inputShape[0];
+  uint32_t numHeads = inputShape[1];
+  const auto &stateShape = initialStateInput.logical_shape();
+  LOG_ASSERT(stateShape.rank() == 4 && stateShape[1] == numHeads &&
+                 stateShape[2] == kChunkSize && stateShape[3] == kChunkSize,
+             "Gated delta rule initial state must be [B, H, 128, 128]");
+  uint32_t batchSize = stateShape[0];
+  LOG_ASSERT(sequenceLength > 0 && sequenceLength <= kChunkSize,
+             "Gated delta rule sequence length must be in [1, 128]");
+  LOG_ASSERT(batchSize > 0, "Gated delta rule batch size must be positive");
+
+  ::ttnn::Tensor upperTriangular = toF32TileDram(
+      tensorPool.getTTNNTensorAndValidate(op->upper_triangular()));
+  ::ttnn::Tensor lowerTriangular = toF32TileDram(
+      tensorPool.getTTNNTensorAndValidate(op->lower_triangular()));
+  ::ttnn::Tensor identity =
+      toF32TileDram(tensorPool.getTTNNTensorAndValidate(op->identity()));
+  ::ttnn::Tensor identity32 =
+      toF32TileDram(tensorPool.getTTNNTensorAndValidate(op->identity_32()));
+
+  ::ttnn::Tensor query = l2Normalize(toHeadMajor3D(queryInput));
+  ::ttnn::Tensor key = l2Normalize(toHeadMajor3D(keyInput));
+  ::ttnn::Tensor value = toHeadMajor3D(valueInput);
+  ::ttnn::Tensor beta = ::ttnn::sigmoid(
+      toHeadMajor2D(betaInput),
+      static_cast<int>(::ttnn::operations::unary::VecMode::RC),
+      ::ttnn::operations::unary::SigmoidMode::ACCURATE, kDram);
+
+  ::ttnn::Tensor gate = toHeadMajor2D(gateInput);
+  ::ttnn::Tensor decay = reshape(toF32TileDram(decayInput), {numHeads, 1});
+  ::ttnn::Tensor dtBias = reshape(toF32TileDram(dtBiasInput), {numHeads, 1});
+  gate = multiply(::ttnn::neg(decay, kDram),
+                  ::ttnn::softplus(add(gate, dtBias), 1.0f, 20.0f, kDram));
+
+  ::ttnn::Tensor valid = toF32TileDram(validInput);
+  std::vector<::ttnn::Tensor> requestMasks;
+  requestMasks.reserve(batchSize);
+  if (batchSize == 1) {
+    requestMasks.push_back(reshape(valid, {1, sequenceLength, 1}));
+  } else {
+    ::ttnn::Tensor requestIndices = toF32TileDram(requestIndicesInput);
+    for (uint32_t request = 0; request < batchSize; ++request) {
+      ::ttnn::Tensor mask = multiply(
+          ::ttnn::eq(requestIndices, static_cast<float>(request),
+                     ::ttnn::DataType::FLOAT32, kDram),
+          valid);
+      requestMasks.push_back(reshape(mask, {1, sequenceLength, 1}));
+    }
+  }
+
+  ::ttnn::Tensor statePool = toF32TileDram(initialStateInput);
+  std::vector<::ttnn::Tensor> outputs;
+  std::vector<::ttnn::Tensor> states;
+  outputs.reserve(batchSize);
+  states.reserve(batchSize);
+  for (uint32_t request = 0; request < batchSize; ++request) {
+    const ::ttnn::Tensor &mask = requestMasks[request];
+    ::ttnn::Tensor requestState = slice(
+        statePool, {static_cast<int32_t>(request), 0, 0, 0},
+        {static_cast<int32_t>(request + 1), static_cast<int32_t>(numHeads),
+         kChunkSize, kChunkSize});
+    requestState = reshape(requestState,
+                           {numHeads, kChunkSize, kChunkSize});
+    SequenceResult result = runSequence(
+        multiply(query, mask), multiply(key, mask), multiply(value, mask),
+        multiply(reshape(beta, {numHeads, sequenceLength, 1}), mask),
+        multiply(reshape(gate, {numHeads, sequenceLength, 1}), mask),
+        requestState, upperTriangular, lowerTriangular, identity, identity32,
+        sequenceLength, numHeads);
+    outputs.push_back(result.output);
+    states.push_back(reshape(
+        result.state, {1, numHeads, kChunkSize, kChunkSize}));
+  }
+
+  ::ttnn::Tensor outputHeadMajor = outputs[0];
+  for (uint32_t request = 1; request < batchSize; ++request) {
+    outputHeadMajor = add(outputHeadMajor, outputs[request]);
+  }
+  ::ttnn::Tensor finalState =
+      batchSize == 1 ? states[0] : ::ttnn::concat(states, 0, kDram);
+  if (sequenceLength < kChunkSize) {
+    outputHeadMajor = slice(
+        outputHeadMajor, {0, 0, 0},
+        {static_cast<int32_t>(numHeads),
+         static_cast<int32_t>(sequenceLength), kChunkSize});
+  }
+  outputHeadMajor = ::ttnn::to_layout(
+      outputHeadMajor, ::ttnn::Layout::ROW_MAJOR, std::nullopt, kDram);
+  ::ttnn::Tensor output = ::ttnn::permute(
+      outputHeadMajor, ::ttsl::SmallVector<int64_t>{1, 0, 2}, kDram);
+
+  auto outputMemoryConfig =
+      ::tt::runtime::ttnn::utils::createMemoryConfigIfNeeded(
+          ::tt::runtime::ttnn::utils::getTensorRefMemoryConfig(op->output()));
+  auto stateMemoryConfig =
+      ::tt::runtime::ttnn::utils::createMemoryConfigIfNeeded(
+          ::tt::runtime::ttnn::utils::getTensorRefMemoryConfig(
+              op->final_state()));
+  output = ::ttnn::to_layout(
+      output, ::ttnn::Layout::TILE, utils::getDataType(op->output()),
+      outputMemoryConfig);
+  finalState = reshape(
+      finalState, {batchSize, numHeads, kChunkSize, kChunkSize}, kDram);
+  finalState = ::ttnn::typecast(finalState,
+                                utils::getDataType(op->final_state()),
+                                stateMemoryConfig);
+
+  tensorPool.insertTTNNTensorAndValidate(op->final_state(), finalState);
+  tensorPool.insertTTNNTensorAndValidate(op->output(), output);
+}
+
+} // namespace tt::runtime::ttnn::operations::transformer

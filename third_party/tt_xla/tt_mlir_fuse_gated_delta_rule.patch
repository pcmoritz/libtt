+constexpr int64_t kGatedDeltaChunkSize = 128;
+constexpr int64_t kMaxSearchsortedIterations = 16;
+
+std::optional<int64_t> getScalarInt(Value value) {
+  auto constant = value.getDefiningOp<::mlir::stablehlo::ConstantOp>();
+  if (!constant) {
+    return std::nullopt;
+  }
+  auto elements = dyn_cast<DenseIntElementsAttr>(constant.getValue());
+  if (!elements || elements.getNumElements() != 1) {
+    return std::nullopt;
+  }
+  return (*elements.value_begin<llvm::APInt>()).getSExtValue();
+}
+
+LogicalResult unrollSearchsorted(::mlir::stablehlo::WhileOp loop) {
+  if (loop.getNumOperands() != 3) {
+    return failure();
+  }
+  auto counterType = dyn_cast<RankedTensorType>(loop.getOperand()[0].getType());
+  auto rangeType = dyn_cast<RankedTensorType>(loop.getOperand()[1].getType());
+  if (!counterType || !rangeType || counterType.getRank() != 0 ||
+      rangeType.getRank() != 1 || !counterType.getElementType().isInteger(32) ||
+      rangeType.getElementType() != counterType.getElementType() ||
+      loop.getOperand()[2].getType() != rangeType) {
+    return failure();
+  }
+
+  Block &condition = loop.getCond().front();
+  auto conditionReturn =
+      dyn_cast<::mlir::stablehlo::ReturnOp>(condition.getTerminator());
+  auto compare = conditionReturn && conditionReturn.getNumOperands() == 1
+                     ? conditionReturn.getOperand(0)
+                           .getDefiningOp<::mlir::stablehlo::CompareOp>()
+                     : nullptr;
+  auto counter = compare ? dyn_cast<BlockArgument>(compare.getLhs())
+                         : BlockArgument();
+  std::optional<int64_t> initial = getScalarInt(loop.getOperand()[0]);
+  std::optional<int64_t> bound = compare ? getScalarInt(compare.getRhs())
+                                         : std::nullopt;
+  if (!counter || counter.getOwner() != &condition ||
+      counter.getArgNumber() != 0 ||
+      compare.getComparisonDirection() !=
+          ::mlir::stablehlo::ComparisonDirection::LT ||
+      !initial || !bound || *initial > *bound) {
+    return failure();
+  }
+
+  Block &body = loop.getBody().front();
+  auto bodyReturn =
+      dyn_cast<::mlir::stablehlo::ReturnOp>(body.getTerminator());
+  auto increment = bodyReturn
+                       ? bodyReturn.getOperand(0)
+                             .getDefiningOp<::mlir::stablehlo::AddOp>()
+                       : nullptr;
+  std::optional<int64_t> step =
+      increment && increment.getLhs() == body.getArgument(0)
+          ? getScalarInt(increment.getRhs())
+          : std::nullopt;
+  int64_t iterations = *bound - *initial;
+  if (!bodyReturn || step != 1 || iterations == 0 ||
+      iterations > kMaxSearchsortedIterations) {
+    return failure();
+  }
+
+  OpBuilder builder(loop);
+  SmallVector<Value> carried(loop.getOperands());
+  for (int64_t iteration = 0; iteration < iterations; ++iteration) {
+    IRMapping mapping;
+    for (auto [argument, value] : llvm::zip(body.getArguments(), carried)) {
+      mapping.map(argument, value);
+    }
+    for (Operation &operation : body.without_terminator()) {
+      builder.clone(operation, mapping);
+    }
+    for (auto [result, value] : llvm::zip(carried, bodyReturn.getOperands())) {
+      result = mapping.lookupOrDefault(value);
+    }
+  }
+  loop.replaceAllUsesWith(carried);
+  loop.erase();
+  return success();
+}
+
+struct UnrollSearchsortedPass
+    : public PassWrapper<UnrollSearchsortedPass,
+                         OperationPass<ModuleOp>> {
+  MLIR_DEFINE_EXPLICIT_INTERNAL_INLINE_TYPE_ID(UnrollSearchsortedPass)
+
+  StringRef getArgument() const final {
+    return "stablehlo-unroll-searchsorted";
+  }
+  StringRef getDescription() const final {
+    return "Unroll small statically bounded JAX searchsorted loops";
+  }
+
+  void runOnOperation() final {
+    SmallVector<::mlir::stablehlo::WhileOp> loops;
+    getOperation().walk<WalkOrder::PostOrder>(
+        [&](::mlir::stablehlo::WhileOp loop) { loops.push_back(loop); });
+    for (::mlir::stablehlo::WhileOp loop : loops) {
+      (void)unrollSearchsorted(loop);

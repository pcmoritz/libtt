+Value findStatePoolIndices(Value value, int64_t batch) {
+  for (int depth = 0; depth < 6; ++depth) {
+    auto type = dyn_cast<RankedTensorType>(value.getType());
+    if (!type || !type.hasStaticShape()) {
+      return {};
+    }
+    if (type.getRank() == 1 && type.getDimSize(0) == batch &&
+        type.getElementType().isInteger(32)) {
+      return value;
+    }
+    Operation *definition = value.getDefiningOp();
+    if (!definition || definition->getNumOperands() != 1) {
+      return {};
+    }
+    value = definition->getOperand(0);
+  }
+  return {};
+}
+
+LogicalResult fuseStatePoolUpdate(::mlir::stablehlo::ScatterOp scatter) {
+  if (scatter.getInputs().size() != 1 || scatter.getUpdates().size() != 1) {
+    return failure();
+  }
+  ArrayRef<int64_t> scatterDims =
+      scatter.getScatterDimensionNumbers().getScatterDimsToOperandDims();
+  if (scatterDims.size() != 1 || scatterDims[0] != 0) {
+    return failure();
+  }
+
+  Value statePool = scatter.getInputs()[0];
+  Value updates = scatter.getUpdates()[0];
+  auto poolType = dyn_cast<RankedTensorType>(statePool.getType());
+  auto updateType = dyn_cast<RankedTensorType>(updates.getType());
+  if (!poolType || !updateType || !poolType.hasStaticShape() ||
+      !updateType.hasStaticShape() || poolType.getRank() < 2 ||
+      poolType.getRank() != updateType.getRank() ||
+      poolType.getElementType() != updateType.getElementType()) {
+    return failure();
+  }
+  int64_t batch = updateType.getDimSize(0);
+  if (batch <= 0 || batch > 32 || poolType.getDimSize(0) < 2 ||
+      poolType.getDimSize(0) > batch + 1) {
+    return failure();
+  }
+  for (int64_t dim = 1; dim < poolType.getRank(); ++dim) {
+    if (poolType.getDimSize(dim) != updateType.getDimSize(dim)) {
+      return failure();
+    }
+  }
+
+  Value stateIndices =
+      findStatePoolIndices(scatter.getScatterIndices(), batch);
+  if (!stateIndices) {
+    return failure();
+  }
+
+  OpBuilder builder(scatter);
+  auto fused = builder.create<StatePoolUpdateOp>(
+      scatter.getLoc(), scatter.getResult(0).getType(), statePool,
+      stateIndices, updates);
+  scatter.getResult(0).replaceAllUsesWith(fused.getFinalStatePool());
+  scatter.erase();
+  return success();
+}
+
+struct FuseStatePoolUpdatesPass
+    : public PassWrapper<FuseStatePoolUpdatesPass, OperationPass<ModuleOp>> {
+  MLIR_DEFINE_EXPLICIT_INTERNAL_INLINE_TYPE_ID(FuseStatePoolUpdatesPass)
+
+  StringRef getArgument() const final {
+    return "stablehlo-fuse-state-pool-updates";
+  }
+  StringRef getDescription() const final {
+    return "Keep recurrent state pool updates in the input buffers";
+  }
+  void runOnOperation() final {
+    SmallVector<::mlir::stablehlo::ScatterOp> scatters;
+    getOperation().walk<WalkOrder::PostOrder>(
+        [&](::mlir::stablehlo::ScatterOp scatter) {
+          scatters.push_back(scatter);
+        });
+    for (::mlir::stablehlo::ScatterOp scatter : scatters) {
+      (void)fuseStatePoolUpdate(scatter);
+    }
+  }
+};

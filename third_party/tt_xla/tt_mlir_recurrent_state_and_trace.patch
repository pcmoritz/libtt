+
+bool ProgramTensorPool::inputAliases(
+    const ::tt::target::ttnn::TensorRef *tensorRef) const {
+  const ::ttnn::Tensor &tensor = getTTNNTensorAndValidate(tensorRef);
+  const auto *buffer = tensor.buffer();
+  for (std::uint32_t inputId : programInputIds) {
+    if (inputId == tensorRef->global_id() ||
+        !liveTensors.contains(inputId)) {
+      continue;
+    }
+    const ::tt::runtime::Tensor &otherRuntimeTensor =
+        getRuntimeTensor(inputId);
+    const ::ttnn::Tensor &other =
+        utils::getTTNNTensorFromRuntimeTensor(otherRuntimeTensor);
+    if (other.buffer() == buffer) {
+      return true;
+    }
+  }
+  return false;
+}

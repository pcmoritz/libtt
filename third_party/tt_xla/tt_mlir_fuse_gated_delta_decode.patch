+void run(const ::tt::target::ttnn::GatedDeltaDecodeOp *op,
+         ProgramContext &context) {
+  ProgramTensorPool &tensorPool = context.getTensorPool();
+  const ::ttnn::Tensor &query =
+      tensorPool.getTTNNTensorAndValidate(op->query());
+  const ::ttnn::Tensor &key =
+      tensorPool.getTTNNTensorAndValidate(op->key());
+  const ::ttnn::Tensor &value =
+      tensorPool.getTTNNTensorAndValidate(op->value());
+  const ::ttnn::Tensor &beta =
+      tensorPool.getTTNNTensorAndValidate(op->beta());
+  const ::ttnn::Tensor &decay =
+      tensorPool.getTTNNTensorAndValidate(op->decay());
+  const ::ttnn::Tensor &statePool =
+      tensorPool.getTTNNTensorAndValidate(op->state_pool());
+  const ::ttnn::Tensor &stateIndices =
+      tensorPool.getTTNNTensorAndValidate(op->state_indices());
+  const ::ttnn::Tensor &hasInitialState =
+      tensorPool.getTTNNTensorAndValidate(op->has_initial_state());
+
+  const auto &shape = query.logical_shape();
+  const uint32_t batchSize = shape[0];
+  const uint32_t numHeads = shape[1];
+  const auto active4d = [numHeads](const ::ttnn::Tensor &input) {
+    return slice(
+        reshape(toF32TileDram(input),
+                {static_cast<uint32_t>(input.logical_shape()[0]), numHeads, 1,
+                 kChunkSize}),
+        {0, 0, 0, 0},
+        {1, static_cast<int32_t>(numHeads), 1, kChunkSize});
+  };
+
+  ::ttnn::Tensor queryActive = active4d(query);
+  ::ttnn::Tensor keyActive = active4d(key);
+  ::ttnn::Tensor valueActive = active4d(value);
+  ::ttnn::Tensor betaActive = slice(
+      toF32TileDram(beta), {0, 0},
+      {1, static_cast<int32_t>(numHeads)});
+  ::ttnn::Tensor decayActive = slice(
+      toF32TileDram(decay), {0, 0},
+      {1, static_cast<int32_t>(numHeads)});
+  ::ttnn::Tensor activeIndices = slice(stateIndices, {0}, {1});
+  ::ttnn::Tensor activeStateFlag = slice(
+      ::ttnn::to_layout(hasInitialState, ::ttnn::Layout::TILE,
+                        ::ttnn::DataType::BFLOAT16, kDram),
+      {0}, {1});
+  ::ttnn::Tensor tiledStatePool = toF32TileDram(statePool);
+  ::ttnn::Tensor outputBuffer = ::ttnn::empty(
+      ::ttnn::Shape{1, numHeads, 1, kChunkSize},
+      ::ttnn::DataType::BFLOAT16, ::ttnn::Layout::TILE,
+      query.device(), kDram);
+  std::vector<::ttnn::Tensor> results =
+      ::ttnn::transformer::gated_delta_decode(
+          queryActive, keyActive, valueActive, betaActive, decayActive,
+          tiledStatePool, outputBuffer, activeIndices, activeStateFlag);
+  ::ttnn::Tensor updatedStatePool = ::ttnn::to_layout(
+      results[1], statePool.layout(), statePool.dtype(), kDram);
+  ::ttnn::Tensor activeOutput = results[0];
+
+  auto outputMemoryConfig =
+      ::tt::runtime::ttnn::utils::createMemoryConfigIfNeeded(
+          ::tt::runtime::ttnn::utils::getTensorRefMemoryConfig(op->output()));
+  activeOutput = ::ttnn::typecast(
+      activeOutput, utils::getDataType(op->output()), kDram);
+  ::ttsl::SmallVector<::ttnn::operations::data_movement::PadSpecDim>
+      outputPadding = {{0, batchSize - 1}, {0, 0}, {0, 0}, {0, 0}};
+  ::ttnn::Tensor output = ::ttnn::pad(
+      activeOutput, outputPadding, 0.0f, true, outputMemoryConfig);
+  output = reshape(output, {batchSize, numHeads, kChunkSize});
+
+  tensorPool.insertTTNNTensorAndValidate(op->final_state_pool(),
+                                         updatedStatePool);
+  tensorPool.insertTTNNTensorAndValidate(op->output(), output);
+}
+

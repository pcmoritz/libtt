+class GatedDeltaDecodeOpConversionPattern
+    : public OpConversionPattern<ttir::GatedDeltaDecodeOp> {
+public:
+  using OpConversionPattern<ttir::GatedDeltaDecodeOp>::OpConversionPattern;
+
+  LogicalResult
+  matchAndRewrite(ttir::GatedDeltaDecodeOp op, OpAdaptor adaptor,
+                  ConversionPatternRewriter &rewriter) const override {
+    SmallVector<Type> resultTypes;
+    for (Type type : op.getResultTypes()) {
+      Type converted = getTypeConverter()->convertType(type);
+      if (!converted) {
+        return rewriter.notifyMatchFailure(
+            op, "failed to convert gated delta decode result type");
+      }
+      resultTypes.push_back(converted);
+    }
+    rewriter.replaceOpWithNewOp<ttnn::GatedDeltaDecodeOp>(
+        op, resultTypes, adaptor.getQuery(), adaptor.getKey(),
+        adaptor.getValue(), adaptor.getBeta(), adaptor.getDecay(),
+        adaptor.getStatePool(), adaptor.getStateIndices(),
+        adaptor.getHasInitialState());
+    return success();
+  }
+};

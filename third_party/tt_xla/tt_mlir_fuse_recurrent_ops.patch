+  let description = [{
+    Computes the Qwen3.5 Gated DeltaNet recurrence as a chunked operation. The
+    inputs use the logical JAX layout and the implementation performs the
+    sequence-independent preprocessing before dispatching the TT-Metal
+    inter-chunk scan kernel.

+  let summary = "Chunked gated delta rule operation.";
+  let description = [{
+    Computes the Qwen3.5 Gated DeltaNet recurrence as a chunked operation. The
+    inputs use the logical JAX layout and the implementation performs the
+    sequence-independent preprocessing before dispatching the TT-Metal
+    inter-chunk scan kernel.
+
+    This operation supports packed ragged request batches, sequence lengths up
+    to 128, 128-wide key and value heads, and a recurrent state shaped
+    `[B, H, 128, 128]`.
+  }];
+
+  let arguments = (ins AnyRankedTensor:$query,
+                       AnyRankedTensor:$key,
+                       AnyRankedTensor:$value,
+                       AnyRankedTensor:$beta_logits,
+                       AnyRankedTensor:$gate_logits,
+                       AnyRankedTensor:$valid_mask,
+                       AnyRankedTensor:$request_indices,
+                       AnyRankedTensor:$decay,
+                       AnyRankedTensor:$dt_bias,
+                       AnyRankedTensor:$initial_state,
+                       AnyRankedTensor:$upper_triangular,
+                       AnyRankedTensor:$lower_triangular,
+                       AnyRankedTensor:$identity,
+                       AnyRankedTensor:$identity_32);
+
+  let results = (outs AnyRankedTensor:$final_state,
+                      AnyRankedTensor:$output);
+}

+std::optional<QwenGatedDeltaDecodeMatch>
+matchQwenGatedDeltaDecode(StatePoolUpdateOp stateUpdate) {
+  Value finalState = matchUpdatedState(stateUpdate);
+  if (!finalState) {
+    return std::nullopt;
+  }
+  auto outputDot =
+      findRecurrentUser<::mlir::stablehlo::DotGeneralOp>(finalState);
+  if (!outputDot || (outputDot.getLhs() != finalState &&
+                     outputDot.getRhs() != finalState)) {
+    return std::nullopt;
+  }
+  Value query = outputDot.getLhs() == finalState ? outputDot.getRhs()
+                                                  : outputDot.getLhs();
+  auto outputType = dyn_cast<RankedTensorType>(outputDot.getType());
+  auto stateType = dyn_cast<RankedTensorType>(finalState.getType());
+  if (!outputType || !stateType || !outputType.hasStaticShape() ||
+      !stateType.hasStaticShape() || outputType.getRank() != 3 ||
+      stateType.getRank() != 4) {
+    return std::nullopt;
+  }
+
+  int64_t batch = outputType.getDimSize(0);
+  int64_t numHeads = outputType.getDimSize(1);
+  SmallVector<int64_t> vectorShape = {batch, numHeads, kGatedDeltaChunkSize};
+  SmallVector<int64_t> scalarShape = {batch, numHeads};
+  SmallVector<int64_t> stateShape = {
+      batch, numHeads, kGatedDeltaChunkSize, kGatedDeltaChunkSize};
+  if (batch <= 0 || numHeads <= 0 ||
+      outputType.getShape() != ArrayRef<int64_t>(vectorShape) ||
+      stateType.getShape() != ArrayRef<int64_t>(stateShape) ||
+      !hasShape(query, vectorShape) ||
+      !hasShape(stateUpdate.getStateIndices(), {batch})) {
+    return std::nullopt;
+  }
+  auto add = finalState.getDefiningOp<::mlir::stablehlo::AddOp>();
+  if (!add) {
+    return std::nullopt;
+  }
+
+  for (auto [stateMid, outerValue] :
+       {std::pair{add.getLhs(), add.getRhs()},
+        std::pair{add.getRhs(), add.getLhs()}}) {
+    auto stateMatch = matchDecodeStateMid(stateMid, stateShape, scalarShape);
+    auto outer = outerValue.getDefiningOp<::mlir::stablehlo::MulOp>();
+    if (!stateMatch || !outer) {
+      continue;
+    }
+
+    for (auto [keyValue, scaledDeltaValue] :
+         {std::pair{outer.getLhs(), outer.getRhs()},
+          std::pair{outer.getRhs(), outer.getLhs()}}) {
+      Value key = stripRecurrentViews(keyValue);
+      Value scaledDelta = stripRecurrentViews(scaledDeltaValue);
+      if (!hasShape(key, vectorShape) ||
+          !hasShape(scaledDelta, vectorShape)) {
+        continue;
+      }
+      auto deltaMatch = matchDecodeScaledDelta(
+          scaledDelta, stateMid, key, vectorShape, scalarShape);
+      if (deltaMatch) {
+        Value statePool = stateUpdate.getStatePool();
+        Value hasInitialState =
+            matchStatePoolRead(stateMatch->first, statePool, batch);
+        if (!hasInitialState) {
+          continue;
+        }
+        return QwenGatedDeltaDecodeMatch{
+            query, key, deltaMatch->first, deltaMatch->second,
+            stateMatch->second, statePool, stateUpdate.getStateIndices(),
+            hasInitialState, outputDot.getResult()};
+      }
+    }
+  }
+  return std::nullopt;
+}
+
+LogicalResult fuseQwenGatedDeltaDecode(StatePoolUpdateOp stateUpdate) {
+  auto match = matchQwenGatedDeltaDecode(stateUpdate);
+  auto barrier =
+      match ? matchRecurrentBarrier(stateUpdate.getFinalStatePool(),
+                                    match->output)
+            : ::mlir::stablehlo::OptimizationBarrierOp();
+  if (!match || !barrier || !barrier->getResult(1).hasOneUse()) {
+    return failure();
+  }
+  auto outputConvert = dyn_cast<::mlir::stablehlo::ConvertOp>(
+      *barrier->getResult(1).user_begin());
+  if (!outputConvert ||
+      !cast<RankedTensorType>(outputConvert.getType())
+           .getElementType()
+           .isBF16()) {
+    return failure();
+  }
+
+  OpBuilder builder(stateUpdate);
+  SmallVector<Type> resultTypes = {barrier->getResult(0).getType(),
+                                   barrier->getResult(1).getType()};
+  SmallVector<Value> operands = {
+      match->query, match->key, match->value, match->beta, match->decay,
+      match->statePool, match->stateIndices, match->hasInitialState};
+  auto fused = builder.create<GatedDeltaDecodeOp>(
+      stateUpdate.getLoc(), resultTypes, operands);
+  barrier->setOperand(0, fused.getFinalStatePool());
+  barrier->setOperand(1, fused.getOutput());
+
+  return success();
+}
+
+bool isDefinedOutside(Operation *ancestor, Value value) {
+  if (auto argument = dyn_cast<BlockArgument>(value)) {
+    return !ancestor->isAncestor(argument.getOwner()->getParentOp());
+  }
+  Operation *definition = value.getDefiningOp();
+  return definition && !ancestor->isAncestor(definition);
+}
+
+std::optional<QwenGatedDeltaMatch>
+matchQwenGatedDeltaLoop(::mlir::stablehlo::WhileOp loop) {
+  if (loop.getNumOperands() != 3 || !loop.getCond().hasOneBlock() ||
+      !loop.getBody().hasOneBlock() || !hasShape(loop->getOperand(0), {})) {
+    return std::nullopt;
+  }
+
+  auto stateType = dyn_cast<RankedTensorType>(loop->getOperand(1).getType());
+  auto outputType = dyn_cast<RankedTensorType>(loop->getOperand(2).getType());
+  if (!stateType || !outputType || !stateType.hasStaticShape() ||
+      !outputType.hasStaticShape() || stateType.getRank() != 4 ||
+      outputType.getRank() != 3) {
+    return std::nullopt;
+  }
+  int64_t sequenceLength = outputType.getDimSize(0);
+  int64_t numHeads = outputType.getDimSize(1);
+  int64_t batchSize = stateType.getDimSize(0);
+  if (sequenceLength <= 0 || sequenceLength > kGatedDeltaChunkSize ||
+      batchSize <= 0 || numHeads <= 0 ||
+      outputType.getDimSize(2) != kGatedDeltaChunkSize ||
+      stateType.getShape() !=
+          ArrayRef<int64_t>({batchSize, numHeads, kGatedDeltaChunkSize,
+                             kGatedDeltaChunkSize})) {
+    return std::nullopt;
+  }
+
+  SmallVector<Value> qkv;
+  SmallVector<Value> gateInputs;
+  Value validMask;
+  Value requestIndices;
+  loop.getBody().walk([&](::mlir::stablehlo::DynamicSliceOp slice) {
+    Value input = slice->getOperand(0);
+    if (hasShape(input,
+                 {sequenceLength, numHeads, kGatedDeltaChunkSize})) {
+      qkv.push_back(input);
+    } else if (hasShape(input, {sequenceLength, numHeads})) {
+      gateInputs.push_back(input);
+    } else if (hasShape(input, {sequenceLength}) &&
+               cast<RankedTensorType>(input.getType())
+                   .getElementType()
+                   .isInteger(1)) {
+      validMask = input;
+    } else if (hasShape(input, {sequenceLength}) &&
+               cast<RankedTensorType>(input.getType())
+                   .getElementType()
+                   .isInteger(32)) {
+      requestIndices = input;
+    }
+  });
+  if (qkv.size() != 3 || gateInputs.size() != 2 || !validMask ||
+      !requestIndices) {
+    return std::nullopt;
+  }
+
+  SmallVector<Value> headVectors;
+  loop.getBody().walk([&](Operation *op) {
+    for (Value operand : op->getOperands()) {
+      auto type = dyn_cast<RankedTensorType>(operand.getType());
+      if (type && type.hasStaticShape() &&
+          type.getShape() == ArrayRef<int64_t>({numHeads}) &&
+          type.getElementType().isF32() && isDefinedOutside(loop, operand) &&
+          !llvm::is_contained(headVectors, operand)) {
+        headVectors.push_back(operand);
+      }
+    }
+  });
+  if (headVectors.size() != 2) {
+    return std::nullopt;
+  }
+
+  Value decay;
+  for (Value candidate : headVectors) {
+    if (llvm::any_of(candidate.getUsers(), [&](Operation *user) {
+          return loop->isAncestor(user) &&
+                 isa<::mlir::stablehlo::NegOp>(user);
+        })) {
+      decay = candidate;
+      break;
+    }
+  }
+  if (!decay) {
+    return std::nullopt;
+  }
+  Value dtBias = headVectors[headVectors[0] == decay ? 1 : 0];
+
+  unsigned dotCount = 0;
+  unsigned exponentialCount = 0;
+  loop.getBody().walk([&](Operation *op) {
+    StringRef name = op->getName().getStringRef();
+    dotCount += name == "stablehlo.dot_general";
+    exponentialCount += name == "stablehlo.exponential";
+  });
+  if (dotCount < 2 || exponentialCount < 1) {
+    return std::nullopt;
+  }
+
+  return QwenGatedDeltaMatch{sequenceLength, qkv[0], qkv[1], qkv[2],
+                             gateInputs[0], gateInputs[1], validMask,
+                             requestIndices, decay, dtBias};
+}
+
+Value createMaskConstant(OpBuilder &builder, Location loc, int64_t size,
+                         function_ref<float(int64_t, int64_t)> getValue) {
+  SmallVector<float> values;
+  values.reserve(size * size);
+  for (int64_t row = 0; row < size; ++row) {
+    for (int64_t column = 0; column < size; ++column) {
+      values.push_back(getValue(row, column));
+    }
+  }
+  auto type = RankedTensorType::get({1, size, size}, builder.getF32Type());
+  auto value = DenseElementsAttr::get(type, ArrayRef<float>(values));
+  return builder.create<::mlir::stablehlo::ConstantOp>(loc, value);
+}
+
+LogicalResult fuseQwenGatedDeltaLoop(::mlir::stablehlo::WhileOp loop) {
+  std::optional<QwenGatedDeltaMatch> match = matchQwenGatedDeltaLoop(loop);
+  if (!match) {
+    return failure();
+  }
+
+  OpBuilder builder(loop);
+  Location loc = loop.getLoc();
+  Value upperTriangular = createMaskConstant(
+      builder, loc, kGatedDeltaChunkSize,
+      [](int64_t row, int64_t column) { return column >= row ? 1.0f : 0.0f; });
+  Value lowerTriangular = createMaskConstant(
+      builder, loc, kGatedDeltaChunkSize,
+      [](int64_t row, int64_t column) { return column <= row ? 1.0f : 0.0f; });
+  Value identity = createMaskConstant(
+      builder, loc, kGatedDeltaChunkSize,
+      [](int64_t row, int64_t column) { return column == row ? 1.0f : 0.0f; });
+  Value identity32 = createMaskConstant(
+      builder, loc, 32,
+      [](int64_t row, int64_t column) { return column == row ? 1.0f : 0.0f; });
+
+  SmallVector<Value> operands = {
+      match->query,          match->key,
+      match->value,          match->betaLogits,
+      match->gateLogits,     match->validMask,
+      match->requestIndices, match->decay,
+      match->dtBias,
+      loop->getOperand(1),   upperTriangular,
+      lowerTriangular,       identity,
+      identity32};
+  SmallVector<Type> resultTypes = {loop.getResult(1).getType(),
+                                   loop.getResult(2).getType()};
+  auto fused = builder.create<GatedDeltaRuleOp>(loc, resultTypes, operands);
+
+  auto inductionType = cast<RankedTensorType>(loop->getOperand(0).getType());
+  auto finalInductionAttr = DenseElementsAttr::get(
+      inductionType,
+      builder.getIntegerAttr(inductionType.getElementType(),
+                             match->sequenceLength));
+  Value finalInduction = builder.create<::mlir::stablehlo::ConstantOp>(
+      loc, finalInductionAttr);
+  loop.getResult(0).replaceAllUsesWith(finalInduction);
+  loop.getResult(1).replaceAllUsesWith(fused.getResult(0));
+  loop.getResult(2).replaceAllUsesWith(fused.getResult(1));
+  loop.erase();
+  return success();
+}
+
+struct FuseQwenGatedDeltaLoopPass
+    : public PassWrapper<FuseQwenGatedDeltaLoopPass,
+                         OperationPass<ModuleOp>> {
+  MLIR_DEFINE_EXPLICIT_INTERNAL_INLINE_TYPE_ID(FuseQwenGatedDeltaLoopPass)
+
+  void runOnOperation() final {
+    SmallVector<::mlir::stablehlo::WhileOp> loops;
+    getOperation().walk<WalkOrder::PostOrder>(
+        [&](::mlir::stablehlo::WhileOp loop) { loops.push_back(loop); });
+    bool fusedGatedDelta = false;
+    for (::mlir::stablehlo::WhileOp loop : loops) {
+      if (succeeded(fuseQwenGatedDeltaLoop(loop))) {
+        fusedGatedDelta = true;
+      }
+    }
+
+    SmallVector<StatePoolUpdateOp> stateUpdates;
+    getOperation().walk<WalkOrder::PostOrder>(
+        [&](StatePoolUpdateOp update) { stateUpdates.push_back(update); });
+    for (StatePoolUpdateOp update : stateUpdates) {
+      if (succeeded(fuseQwenCausalConv1dUpdate(update))) {
+        fusedGatedDelta = true;
+        continue;
+      }
+      if (succeeded(fuseQwenGatedDeltaDecode(update))) {
+        fusedGatedDelta = true;
+      }
+    }
+    if (!fusedGatedDelta) {
+      return;
+    }
+
+    IRRewriter rewriter(&getContext());
+    (void)runRegionDCE(rewriter, getOperation()->getRegions());
+  }
+};

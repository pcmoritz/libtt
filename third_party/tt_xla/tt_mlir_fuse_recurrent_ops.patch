+                       AnyRankedTensor:$valid_mask,
+                       AnyRankedTensor:$request_indices,
+                       AnyRankedTensor:$decay,
+                       AnyRankedTensor:$dt_bias,
+                       AnyRankedTensor:$initial_state,
+                       AnyRankedTensor:$upper_triangular,
+                       AnyRankedTensor:$lower_triangular,
+                       AnyRankedTensor:$identity,
+                       AnyRankedTensor:$identity_32);
+
+  let results = (outs AnyRankedTensor:$final_state,
+                      AnyRankedTensor:$output);
+}

+std::optional<QwenCausalConv1dUpdateMatch>
+matchQwenCausalConv1dUpdate(StatePoolUpdateOp stateUpdate) {
+  Value statePool = stateUpdate.getStatePool();
+  auto poolType = dyn_cast<RankedTensorType>(statePool.getType());
+  if (!poolType || !poolType.hasStaticShape() || poolType.getRank() != 3 ||
+      !poolType.getElementType().isBF16() || poolType.getDimSize(0) < 2 ||
+      poolType.getDimSize(2) != 3) {
+    return std::nullopt;
+  }
+  int64_t batch =
+      cast<RankedTensorType>(stateUpdate.getUpdates().getType()).getDimSize(0);
+  int64_t channels = poolType.getDimSize(1);
+  if (batch <= 0 || batch > 32 || channels <= 0 || channels % 32 != 0 ||
+      !hasShape(stateUpdate.getStateIndices(), {batch})) {
+    return std::nullopt;
+  }
+  SmallVector<int64_t> inputShape = {batch, channels};
+  SmallVector<int64_t> weightShape = {channels, 4};
+  SmallVector<int64_t> windowShape = {batch, channels, 4};
+  SmallVector<int64_t> stateShape = {batch, channels, 3};
+
+  Value updatedState = matchUpdatedState(stateUpdate);
+  if (!updatedState) {
+    return std::nullopt;
+  }
+  auto slice =
+      updatedState.getDefiningOp<::mlir::stablehlo::SliceOp>();
+  if (!slice || !hasShape(updatedState, stateShape) ||
+      !hasShape(slice.getOperand(), windowShape)) {
+    return std::nullopt;
+  }
+  Value window = slice.getOperand();
+  auto concatenate =
+      window.getDefiningOp<::mlir::stablehlo::ConcatenateOp>();
+  if (!concatenate || concatenate.getDimension() != 2 ||
+      concatenate.getInputs().size() != 2 ||
+      !hasShape(concatenate.getInputs()[0], stateShape)) {
+    return std::nullopt;
+  }
+  Value input = stripRecurrentViews(concatenate.getInputs()[1]);
+  Value hasInitialState =
+      matchStatePoolRead(concatenate.getInputs()[0], statePool, batch);
+  if (!hasShape(input, inputShape) || !hasInitialState) {
+    return std::nullopt;
+  }
+
+  auto dot = findRecurrentUser<::mlir::stablehlo::DotGeneralOp>(window);
+  if (!dot) {
+    return std::nullopt;
+  }
+  Value weight = dot.getLhs() == window ? dot.getRhs() : dot.getLhs();
+  auto dotType = dyn_cast<RankedTensorType>(dot.getType());
+  if ((dot.getLhs() != window && dot.getRhs() != window) ||
+      !hasShape(weight, weightShape) || !dotType ||
+      !dotType.hasStaticShape() || dotType.getRank() != 2 ||
+      !dotType.getElementType().isBF16() ||
+      (dotType.getShape() != ArrayRef<int64_t>({batch, channels}) &&
+       dotType.getShape() != ArrayRef<int64_t>({channels, batch}))) {
+    return std::nullopt;
+  }
+
+  Value activationInput = dot.getResult();
+  if (dot->hasOneUse()) {
+    Operation *user = *dot->user_begin();
+    if (isa<::mlir::stablehlo::TransposeOp,
+            ::mlir::stablehlo::ReshapeOp>(user)) {
+      activationInput = user->getResult(0);
+    }
+  }
+  Value output = matchExpandedSilu(activationInput);
+  if (!output) {
+    return std::nullopt;
+  }
+  return QwenCausalConv1dUpdateMatch{
+      input, statePool, weight, stateUpdate.getStateIndices(),
+      hasInitialState, output};
+}
+
+LogicalResult fuseQwenCausalConv1dUpdate(StatePoolUpdateOp stateUpdate) {
+  auto match = matchQwenCausalConv1dUpdate(stateUpdate);
+  auto barrier =
+      match ? matchRecurrentBarrier(stateUpdate.getFinalStatePool(),
+                                    match->output)
+            : ::mlir::stablehlo::OptimizationBarrierOp();
+  if (!match || !barrier) {
+    return failure();
+  }
+
+  OpBuilder builder(stateUpdate);
+  SmallVector<Type> resultTypes = {barrier->getResult(0).getType(),
+                                   barrier->getResult(1).getType()};
+  SmallVector<Value> operands = {
+      match->input, match->statePool, match->weight, match->stateIndices,
+      match->hasInitialState};
+  auto fused = builder.create<CausalConv1dUpdateOp>(
+      stateUpdate.getLoc(), resultTypes, operands);
+  barrier->setOperand(0, fused.getFinalStatePool());
+  barrier->setOperand(1, fused.getOutput());
+  return success();
+}

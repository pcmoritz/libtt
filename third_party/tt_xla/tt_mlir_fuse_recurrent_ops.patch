+std::optional<QwenCausalConv1dUpdateMatch>
+matchQwenCausalConv1dUpdate(::mlir::stablehlo::DotGeneralOp dot) {
+  auto dotType = dyn_cast<RankedTensorType>(dot.getType());
+  if (!dotType || !dotType.hasStaticShape() || dotType.getRank() != 2 ||
+      !dotType.getElementType().isBF16()) {
+    return std::nullopt;
+  }
+  Value activationInput = dot.getResult();
+  if (dot->hasOneUse()) {
+    auto transpose = dyn_cast<::mlir::stablehlo::TransposeOp>(*dot->user_begin());
+    if (transpose) {
+      activationInput = transpose.getResult();
+    } else if (auto reshape =
+                   dyn_cast<::mlir::stablehlo::ReshapeOp>(*dot->user_begin())) {
+      activationInput = reshape.getResult();
+    }
+  }
+  Value output = matchExpandedSilu(activationInput);
+  if (!output || !output.hasOneUse()) {
+    return std::nullopt;
+  }
+
+  int64_t firstDim = dotType.getDimSize(0);
+  int64_t secondDim = dotType.getDimSize(1);
+  bool outputIsBatchMajor = firstDim <= 32 && secondDim % 32 == 0;
+  int64_t batch = outputIsBatchMajor ? firstDim : secondDim;
+  int64_t channels = outputIsBatchMajor ? secondDim : firstDim;
+  if (batch <= 0 || batch > 32 || channels <= 0 || channels % 32 != 0) {
+    return std::nullopt;
+  }
+  SmallVector<int64_t> inputShape = {batch, channels};
+  SmallVector<int64_t> weightShape = {channels, 4};
+  SmallVector<int64_t> windowShape = {batch, channels, 4};
+  SmallVector<int64_t> stateShape = {batch, channels, 3};
+
+  Value weight;
+  Value window;
+  for (auto [weightCandidate, windowCandidate] :
+       {std::pair{dot.getLhs(), dot.getRhs()},
+        std::pair{dot.getRhs(), dot.getLhs()}}) {
+    if (hasShape(weightCandidate, weightShape) &&
+        hasShape(windowCandidate, windowShape)) {
+      weight = weightCandidate;
+      window = windowCandidate;
+      break;
+    }
+  }
+  if (!window) {
+    return std::nullopt;
+  }
+  auto concatenate =
+      window.getDefiningOp<::mlir::stablehlo::ConcatenateOp>();
+  if (!concatenate || concatenate.getDimension() != 2 ||
+      concatenate.getInputs().size() != 2 ||
+      !hasShape(concatenate.getInputs()[0], stateShape)) {
+    return std::nullopt;
+  }
+  Value input = concatenate.getInputs()[1];
+  if (auto broadcast =
+          input.getDefiningOp<::mlir::stablehlo::BroadcastInDimOp>()) {
+    input = broadcast.getOperand();
+  } else if (auto reshape =
+                 input.getDefiningOp<::mlir::stablehlo::ReshapeOp>()) {
+    input = reshape.getOperand();
+  }
+  if (!hasShape(input, inputShape)) {
+    return std::nullopt;
+  }
+
+  auto stateSelect = concatenate.getInputs()[0]
+                         .getDefiningOp<::mlir::stablehlo::SelectOp>();
+  if (!stateSelect) {
+    return std::nullopt;
+  }
+  auto gather = stateSelect.getOnTrue()
+                    .getDefiningOp<::mlir::stablehlo::GatherOp>();
+  if (!gather) {
+    gather = stateSelect.getOnFalse()
+                 .getDefiningOp<::mlir::stablehlo::GatherOp>();
+  }
+  if (!gather) {
+    return std::nullopt;
+  }
+  Value statePool = gather.getOperand();
+  Value stateIndices = stripBroadcasts(gather.getStartIndices());
+  Value hasInitialState = stripBroadcasts(stateSelect.getPred());
+  auto poolType = dyn_cast<RankedTensorType>(statePool.getType());
+  if (!poolType || !poolType.hasStaticShape() || poolType.getRank() != 3 ||
+      poolType.getDimSize(0) < 2 || poolType.getDimSize(1) != channels ||
+      poolType.getDimSize(2) != 3 || !hasShape(stateIndices, {batch}) ||
+      !hasShape(hasInitialState, {batch})) {
+    return std::nullopt;
+  }
+
+  Value finalStatePool;
+  for (Operation *windowUser : window.getUsers()) {
+    auto slice = dyn_cast<::mlir::stablehlo::SliceOp>(windowUser);
+    if (!slice || !hasShape(slice.getResult(), stateShape)) {
+      continue;
+    }
+    for (Operation *sliceUser : slice.getResult().getUsers()) {
+      auto select = dyn_cast<::mlir::stablehlo::SelectOp>(sliceUser);
+      if (!select) {
+        continue;
+      }
+      for (Operation *selectUser : select.getResult().getUsers()) {
+        auto scatter = dyn_cast<::mlir::stablehlo::ScatterOp>(selectUser);
+        if (scatter && scatter.getInputs().size() == 1 &&
+            scatter.getUpdates().size() == 1 &&
+            scatter.getInputs()[0] == statePool &&
+            scatter.getUpdates()[0] == select.getResult()) {
+          finalStatePool = scatter.getResult(0);
+          break;
+        }
+      }
+    }
+  }
+  if (!finalStatePool) {
+    return std::nullopt;
+  }
+  return QwenCausalConv1dUpdateMatch{
+      input, statePool, weight, stateIndices, hasInitialState,
+      finalStatePool, output};
+}
+
+LogicalResult
+fuseQwenCausalConv1dUpdate(::mlir::stablehlo::DotGeneralOp dot) {
+  auto match = matchQwenCausalConv1dUpdate(dot);
+  if (!match) {
+    return failure();
+  }
+  auto outputBarrier = dyn_cast<::mlir::stablehlo::OptimizationBarrierOp>(
+      *match->output.user_begin());
+  if (!outputBarrier) {
+    return failure();
+  }
+  std::optional<unsigned> stateResultIndex;
+  std::optional<unsigned> outputResultIndex;
+  for (auto [index, operand] : llvm::enumerate(outputBarrier.getOperands())) {
+    if (operand == match->finalStatePool) {
+      stateResultIndex = index;
+    } else if (operand == match->output) {
+      outputResultIndex = index;
+    }
+  }
+  if (!stateResultIndex || !outputResultIndex) {
+    return failure();
+  }
+
+  OpBuilder builder(dot);
+  SmallVector<Type> resultTypes = {
+      outputBarrier->getResult(*stateResultIndex).getType(),
+      outputBarrier->getResult(*outputResultIndex).getType()};
+  SmallVector<Value> operands = {
+      match->input, match->statePool, match->weight, match->stateIndices,
+      match->hasInitialState};
+  auto fused = builder.create<CausalConv1dUpdateOp>(
+      dot.getLoc(), resultTypes, operands);
+  outputBarrier->setOperand(*stateResultIndex, fused.getFinalStatePool());
+  outputBarrier->setOperand(*outputResultIndex, fused.getOutput());
+  return success();
+}

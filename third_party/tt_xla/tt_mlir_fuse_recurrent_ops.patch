+
+Value findStatePoolIndices(Value value, int64_t batch) {
+  value = stripRecurrentViews(value);
+  auto type = dyn_cast<RankedTensorType>(value.getType());
+  return type && type.hasStaticShape() && type.getRank() == 1 &&
+                 type.getDimSize(0) == batch &&
+                 type.getElementType().isInteger(32)
+             ? value
+             : Value();
+}
+
+template <typename OpTy>
+OpTy findRecurrentUser(Value value) {
+  for (Operation *user : value.getUsers()) {
+    if (auto match = dyn_cast<OpTy>(user)) {
+      return match;
+    }
+  }
+  return {};
+}
+
+Value matchUpdatedState(StatePoolUpdateOp update) {
+  auto select =
+      update.getUpdates().getDefiningOp<::mlir::stablehlo::SelectOp>();
+  if (!select) {
+    return {};
+  }
+  auto readsPool = [&](Value value) {
+    auto gather = value.getDefiningOp<::mlir::stablehlo::GatherOp>();
+    return gather && gather.getOperand() == update.getStatePool();
+  };
+  if (readsPool(select.getOnTrue())) {
+    return select.getOnFalse();
+  }
+  return readsPool(select.getOnFalse()) ? select.getOnTrue() : Value();
+}
+
+Value matchStatePoolRead(Value state, Value statePool, int64_t batch) {
+  auto select = state.getDefiningOp<::mlir::stablehlo::SelectOp>();
+  if (!select) {
+    return {};
+  }
+  auto gather = select.getOnTrue()
+                    .getDefiningOp<::mlir::stablehlo::GatherOp>();
+  if (!gather) {
+    gather = select.getOnFalse()
+                 .getDefiningOp<::mlir::stablehlo::GatherOp>();
+  }
+  Value predicate = stripRecurrentViews(select.getPred());
+  return gather && gather.getOperand() == statePool &&
+                 hasShape(predicate, {batch})
+             ? predicate
+             : Value();
+}
+
+::mlir::stablehlo::OptimizationBarrierOp
+matchRecurrentBarrier(Value state, Value output) {
+  if (!state.hasOneUse() || !output.hasOneUse()) {
+    return {};
+  }
+  auto barrier = dyn_cast<::mlir::stablehlo::OptimizationBarrierOp>(
+      *state.user_begin());
+  return barrier && barrier->getNumOperands() == 2 &&
+                 barrier->getOperand(0) == state &&
+                 barrier->getOperand(1) == output
+             ? barrier
+             : ::mlir::stablehlo::OptimizationBarrierOp();
+}
+
+LogicalResult fuseStatePoolUpdate(::mlir::stablehlo::ScatterOp scatter) {
+  if (scatter.getInputs().size() != 1 || scatter.getUpdates().size() != 1) {
+    return failure();
+  }
+  ArrayRef<int64_t> scatterDims =
+      scatter.getScatterDimensionNumbers().getScatterDimsToOperandDims();
+  if (scatterDims.size() != 1 || scatterDims[0] != 0) {
+    return failure();
+  }
+
+  Value statePool = scatter.getInputs()[0];
+  Value updates = scatter.getUpdates()[0];
+  auto poolType = dyn_cast<RankedTensorType>(statePool.getType());
+  auto updateType = dyn_cast<RankedTensorType>(updates.getType());
+  if (!poolType || !updateType || !poolType.hasStaticShape() ||
+      !updateType.hasStaticShape() || poolType.getRank() < 2 ||
+      poolType.getRank() != updateType.getRank() ||
+      poolType.getElementType() != updateType.getElementType()) {
+    return failure();
+  }
+  int64_t batch = updateType.getDimSize(0);
+  if (batch <= 0 || batch > 32 || poolType.getDimSize(0) < 2 ||
+      poolType.getDimSize(0) > batch + 1) {
+    return failure();
+  }
+  for (int64_t dim = 1; dim < poolType.getRank(); ++dim) {
+    if (poolType.getDimSize(dim) != updateType.getDimSize(dim)) {
+      return failure();
+    }
+  }
+
+  Value stateIndices =
+      findStatePoolIndices(scatter.getScatterIndices(), batch);
+  if (!stateIndices) {
+    return failure();
+  }
+
+  OpBuilder builder(scatter);
+  auto fused = builder.create<StatePoolUpdateOp>(
+      scatter.getLoc(), scatter.getResult(0).getType(), statePool,
+      stateIndices, updates);
+  scatter.getResult(0).replaceAllUsesWith(fused.getFinalStatePool());
+  scatter.erase();
+  return success();
+}
+
+struct FuseStatePoolUpdatesPass
+    : public PassWrapper<FuseStatePoolUpdatesPass, OperationPass<ModuleOp>> {
+  MLIR_DEFINE_EXPLICIT_INTERNAL_INLINE_TYPE_ID(FuseStatePoolUpdatesPass)
+  void runOnOperation() final {
+    SmallVector<::mlir::stablehlo::ScatterOp> scatters;
+    getOperation().walk<WalkOrder::PostOrder>(
+        [&](::mlir::stablehlo::ScatterOp scatter) {
+          scatters.push_back(scatter);
+        });
+    for (::mlir::stablehlo::ScatterOp scatter : scatters) {
+      (void)fuseStatePoolUpdate(scatter);
+    }
+  }
+};
+
+bool isOneLike(Value value) {
+  return matchPattern(stripRecurrentViews(value), m_OneFloat());
+}
+
+Value matchExpandedSilu(Value input) {
+  for (Operation *user : input.getUsers()) {
+    auto multiply = dyn_cast<::mlir::stablehlo::MulOp>(user);
+    if (!multiply) {
+      continue;
+    }
+    Value sigmoid = multiply.getLhs() == input ? multiply.getRhs()
+                                               : multiply.getLhs();
+    auto logistic =
+        sigmoid.getDefiningOp<::mlir::stablehlo::LogisticOp>();
+    if (logistic && logistic.getOperand() == input) {
+      return multiply.getResult();
+    }
+    auto divide = sigmoid.getDefiningOp<::mlir::stablehlo::DivOp>();
+    if (!divide || !isOneLike(divide.getLhs())) {
+      continue;
+    }
+    auto denominator = divide.getRhs().getDefiningOp<::mlir::stablehlo::AddOp>();
+    if (!denominator) {
+      continue;
+    }
+    for (auto [one, candidate] :
+         {std::pair{denominator.getLhs(), denominator.getRhs()},
+          std::pair{denominator.getRhs(), denominator.getLhs()}}) {
+      auto exponential = candidate.getDefiningOp<::mlir::stablehlo::ExpOp>();
+      if (!isOneLike(one) || !exponential) {
+        continue;
+      }
+      auto negate = exponential.getOperand()
+                        .getDefiningOp<::mlir::stablehlo::NegOp>();
+      if (negate && negate.getOperand() == input) {
+        return multiply.getResult();
+      }
+    }
+  }
+  return {};
+}

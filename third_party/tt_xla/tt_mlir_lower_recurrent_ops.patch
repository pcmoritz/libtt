+::flatbuffers::Offset<::tt::target::ttnn::GatedDeltaRuleOp>
+createOp(FlatbufferObjectCache &cache, GatedDeltaRuleOp op) {
+  auto tensor = [&](Value value) {
+    return cache.at<::tt::target::ttnn::TensorRef>(
+        getOperandThroughDPSOps(value));
+  };
+  auto finalState = cache.getOrCreateNoSharding(
+      op.getFinalState(), tensorValueToFlatbuffer,
+      /*local_shape=*/std::nullopt);
+  auto output = cache.getOrCreateNoSharding(
+      op.getOutput(), tensorValueToFlatbuffer,
+      /*local_shape=*/std::nullopt);
+
+  return ::tt::target::ttnn::CreateGatedDeltaRuleOp(
+      *cache.fbb, tensor(op.getQuery()), tensor(op.getKey()),
+      tensor(op.getValue()), tensor(op.getBetaLogits()),
+      tensor(op.getGateLogits()), tensor(op.getValidMask()),
+      tensor(op.getRequestIndices()), tensor(op.getDecay()),
+      tensor(op.getDtBias()),
+      tensor(op.getInitialState()), tensor(op.getUpperTriangular()),
+      tensor(op.getLowerTriangular()), tensor(op.getIdentity()),
+      tensor(op.getIdentity_32()), finalState, output);
+}

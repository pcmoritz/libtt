+namespace {
+template <typename TTIROp, typename TTNNOp>
+class RecurrentOpConversionPattern : public OpConversionPattern<TTIROp> {
+public:
+  using OpConversionPattern<TTIROp>::OpConversionPattern;
+
+  LogicalResult matchAndRewrite(TTIROp op, typename TTIROp::Adaptor adaptor,
+                                ConversionPatternRewriter &rewriter) const override {
+    SmallVector<Type> resultTypes;
+    if (failed(this->getTypeConverter()->convertTypes(op->getResultTypes(),
+                                                      resultTypes))) {
+      return rewriter.notifyMatchFailure(op, "failed to convert result types");
+    }
+    rewriter.replaceOpWithNewOp<TTNNOp>(op, resultTypes,
+                                        adaptor.getOperands());
+    return success();
+  }
+};
+
+using GatedDeltaRuleOpConversionPattern = RecurrentOpConversionPattern<
+    ttir::GatedDeltaRuleOp, ttnn::GatedDeltaRuleOp>;
+using GatedDeltaDecodeOpConversionPattern = RecurrentOpConversionPattern<
+    ttir::GatedDeltaDecodeOp, ttnn::GatedDeltaDecodeOp>;
+using CausalConv1dUpdateOpConversionPattern = RecurrentOpConversionPattern<
+    ttir::CausalConv1dUpdateOp, ttnn::CausalConv1dUpdateOp>;
+} // namespace
+
+namespace {
+class StatePoolUpdateOpConversionPattern
+    : public OpConversionPattern<ttir::StatePoolUpdateOp> {
+public:
+  using OpConversionPattern<ttir::StatePoolUpdateOp>::OpConversionPattern;
+
+  LogicalResult
+  matchAndRewrite(ttir::StatePoolUpdateOp op, OpAdaptor adaptor,
+                  ConversionPatternRewriter &rewriter) const override {
+    rewriter.create<ttnn::StatePoolUpdateOp>(
+        op.getLoc(), adaptor.getStatePool(), adaptor.getStateIndices(),
+        adaptor.getUpdates());
+    rewriter.replaceOp(op, adaptor.getStatePool());
+    return success();
+  }
+};
+} // namespace

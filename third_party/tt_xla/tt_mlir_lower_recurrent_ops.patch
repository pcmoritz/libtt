+def TTNN_GatedDeltaRuleOp : TTNN_Op<"gated_delta_rule", [OpModelExempt]> {
+    let summary = "Chunked gated delta rule operation.";
+    let description = [{
+      Executes the Qwen3.5 Gated DeltaNet recurrence using TTNN preprocessing
+      and the TT-Metal gated_delta_attn_seq kernel.
+    }];
+
+    let arguments = (ins AnyRankedTensor:$query,
+                         AnyRankedTensor:$key,
+                         AnyRankedTensor:$value,
+                         AnyRankedTensor:$beta_logits,
+                         AnyRankedTensor:$gate_logits,
+                         AnyRankedTensor:$valid_mask,
+                         AnyRankedTensor:$request_indices,
+                         AnyRankedTensor:$decay,
+                         AnyRankedTensor:$dt_bias,
+                         AnyRankedTensor:$initial_state,
+                         AnyRankedTensor:$upper_triangular,
+                         AnyRankedTensor:$lower_triangular,
+                         AnyRankedTensor:$identity,
+                         AnyRankedTensor:$identity_32);
+
+    let results = (outs AnyRankedTensor:$final_state,
+                        AnyRankedTensor:$output);
+}
+
+def TTNN_GatedDeltaDecodeOp : TTNN_Op<"gated_delta_decode", [OpModelExempt]> {
+    let summary = "One preprocessed gated delta rule decode step.";
+
+    let arguments = (ins AnyRankedTensor:$query,
+                         AnyRankedTensor:$key,
+                         AnyRankedTensor:$value,
+                         AnyRankedTensor:$beta,
+                         AnyRankedTensor:$decay,
+                         Arg<AnyRankedTensor, "state pool", [MemWrite]>:$state_pool,
+                         AnyRankedTensor:$state_indices,
+                         AnyRankedTensor:$has_initial_state);
+
+    let results = (outs AnyRankedTensor:$final_state_pool,
+                        AnyRankedTensor:$output);
+}
+
+def TTNN_CausalConv1dUpdateOp : TTNN_Op<"causal_conv1d_update", [OpModelExempt]> {
+    let summary = "One fused depthwise causal convolution decode step.";
+
+    let arguments = (ins AnyRankedTensor:$input,
+                         Arg<AnyRankedTensor, "state pool", [MemWrite]>:$state_pool,
+                         AnyRankedTensor:$weight,
+                         AnyRankedTensor:$state_indices,
+                         AnyRankedTensor:$has_initial_state);
+
+    let results = (outs AnyRankedTensor:$final_state_pool,
+                        AnyRankedTensor:$output);
+}
+
+def TTNN_StatePoolUpdateOp : TTNN_InplaceOp<"state_pool_update", [OpModelExempt]> {
+    let summary = "Update leading slices of a recurrent state pool in place.";
+
+    let arguments = (ins
+        Arg<AnyRankedTensor, "state pool", [MemWrite]>:$state_pool,
+        AnyRankedTensor:$state_indices,
+        AnyRankedTensor:$updates);
+}

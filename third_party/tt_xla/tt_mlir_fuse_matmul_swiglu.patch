+// Fold the decode MLP's concatenated [up | gate] projection and SwiGLU into a
+// single half-width matmul.  The runtime implements this marker with a
+// two-weight matmul that keeps matching up/gate accumulators on the same core.
+class TTNNMatmulWithSwiGLUEpilogue
+    : public mlir::OpRewritePattern<MultiplyOp> {
+public:
+  TTNNMatmulWithSwiGLUEpilogue(mlir::MLIRContext *context)
+      : mlir::OpRewritePattern<MultiplyOp>(context, /*benefit=*/2) {}
+
+  mlir::LogicalResult
+  matchAndRewrite(MultiplyOp multiplyOp,
+                  mlir::PatternRewriter &rewriter) const final {
+    SiluOp lhsSilu = multiplyOp.getLhs().getDefiningOp<SiluOp>();
+    SiluOp rhsSilu = multiplyOp.getRhs().getDefiningOp<SiluOp>();
+    if ((!lhsSilu && !rhsSilu) || (lhsSilu && rhsSilu)) {
+      return failure();
+    }
+
+    SiluOp siluOp = lhsSilu ? lhsSilu : rhsSilu;
+    auto activatedSlice = siluOp.getInput().getDefiningOp<SliceStaticOp>();
+    auto otherSlice = (lhsSilu ? multiplyOp.getRhs() : multiplyOp.getLhs())
+                          .getDefiningOp<SliceStaticOp>();
+    if (!activatedSlice || !otherSlice || !siluOp.getResult().hasOneUse() ||
+        !activatedSlice.getResult().hasOneUse() ||
+        !otherSlice.getResult().hasOneUse()) {
+      return failure();
+    }
+
+    auto matmulOp = activatedSlice.getInput().getDefiningOp<MatmulOp>();
+    if (!matmulOp || otherSlice.getInput() != matmulOp.getResult() ||
+        !matmulOp.getResult().hasNUses(2) || matmulOp.getTransposeA() ||
+        matmulOp.getTransposeB() || matmulOp.getActivation()) {
+      return failure();
+    }
+
+    auto inputType = matmulOp.getType();
+    auto outputType = multiplyOp.getType();
+    ArrayRef<int64_t> inputShape = inputType.getShape();
+    ArrayRef<int64_t> outputShape = outputType.getShape();
+    if (inputShape.size() != 2 || outputShape.size() != 2 ||
+        inputShape[0] != 1 || inputShape[1] != 2 * outputShape[1] ||
+        outputShape[1] % 32 != 0) {
+      return failure();
+    }
+
+    auto beginsA = llvm::cantFail(ttmlir::utils::getIntegerVector<int64_t>(
+        activatedSlice.getBegins()));
+    auto endsA = llvm::cantFail(
+        ttmlir::utils::getIntegerVector<int64_t>(activatedSlice.getEnds()));
+    auto stepsA = llvm::cantFail(
+        ttmlir::utils::getIntegerVector<int64_t>(activatedSlice.getStep()));
+    auto beginsB = llvm::cantFail(
+        ttmlir::utils::getIntegerVector<int64_t>(otherSlice.getBegins()));
+    auto endsB = llvm::cantFail(
+        ttmlir::utils::getIntegerVector<int64_t>(otherSlice.getEnds()));
+    auto stepsB = llvm::cantFail(
+        ttmlir::utils::getIntegerVector<int64_t>(otherSlice.getStep()));
+    if (beginsA.size() != 2 || endsA.size() != 2 || stepsA.size() != 2 ||
+        beginsB.size() != 2 || endsB.size() != 2 || stepsB.size() != 2 ||
+        beginsA[0] != 0 || beginsB[0] != 0 || endsA[0] != 1 ||
+        endsB[0] != 1 || stepsA[0] != 1 || stepsA[1] != 1 ||
+        stepsB[0] != 1 || stepsB[1] != 1) {
+      return failure();
+    }
+
+    int64_t half = outputShape[1];
+    bool gateFirst = beginsA[1] == 0 && endsA[1] == half &&
+                     beginsB[1] == half && endsB[1] == 2 * half;
+    bool gateSecond = beginsB[1] == 0 && endsB[1] == half &&
+                      beginsA[1] == half && endsA[1] == 2 * half;
+    if (!gateFirst && !gateSecond) {
+      return failure();
+    }
+
+    mlir::OperationState state(matmulOp.getLoc(), MatmulOp::getOperationName());
+    state.addOperands(matmulOp->getOperands());
+    state.addTypes(outputType);
+    state.addAttributes(matmulOp->getAttrs());
+    mlir::Operation *fused = rewriter.create(state);
+    fused->setAttr("ttnn.fused_swiglu", rewriter.getUnitAttr());
+    if (gateFirst) {
+      fused->setAttr("ttnn.swiglu_gate_first", rewriter.getUnitAttr());
+    }
+
+    rewriter.replaceOp(multiplyOp, fused->getResult(0));
+    rewriter.eraseOp(siluOp);
+    rewriter.eraseOp(activatedSlice);
+    rewriter.eraseOp(otherSlice);
+    rewriter.eraseOp(matmulOp);
+    return success();
+  }
+};

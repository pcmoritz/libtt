+void *MemoryInstance::getUserData(const void *key) const {
+  auto it = m_user_data.find(key);
+  return it == m_user_data.end() ? nullptr : it->second.data;
+}
+
+void MemoryInstance::setUserData(const void *key, void *data,
+                                 void (*dtor)(void *)) {
+  auto it = m_user_data.find(key);
+  if (it != m_user_data.end() && it->second.dtor) {
+    it->second.dtor(it->second.data);
+  }
+  if (data == nullptr) {
+    m_user_data.erase(key);
+    return;
+  }
+  m_user_data[key] = UserData{data, dtor};
+}

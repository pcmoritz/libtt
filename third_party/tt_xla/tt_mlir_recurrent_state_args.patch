+      // Recurrent model state has the same lifetime requirements as KV cache:
+      // it remains on device and is updated in place across decode steps.
+      auto addRecurrentStateArg = [&](mlir::Value state) {
+        if (auto barrier =
+                state.getDefiningOp<ttcore::OptimizationBarrierOp>()) {
+          if (barrier->getNumOperands() != 1 ||
+              barrier->getNumResults() != 1) {
+            return;
+          }
+          state = barrier->getOperand(0);
+        }
+        if (auto blockArg = llvm::dyn_cast<BlockArgument>(state)) {
+          if (blockArg.getOwner()->getParentOp() == funcOp) {
+            cacheArgs.insert(blockArg);
+            funcOp.setArgAttr(blockArg.getArgNumber(), "tt.recurrent_state",
+                              mlir::UnitAttr::get(context));
+          }
+        }
+      };
+
+      funcOp.walk([&](GatedDeltaDecodeOp op) {
+        addRecurrentStateArg(op.getStatePool());
+      });

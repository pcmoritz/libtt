diff --git a/lib/Conversion/StableHLOToTTIR/StableHLOToTTIRPatterns.cpp b/lib/Conversion/StableHLOToTTIR/StableHLOToTTIRPatterns.cpp
--- a/lib/Conversion/StableHLOToTTIR/StableHLOToTTIRPatterns.cpp
+++ b/lib/Conversion/StableHLOToTTIR/StableHLOToTTIRPatterns.cpp
@@ -6824,15 +6824,37 @@ public:
     // Single-dimensional scatter.
     if (scatterDimsToOperandDims.size() == 1) {
       // Process indices to match update tensor shape.
       int32_t dim = scatterDimsToOperandDims[0];
       Value finalIndexTensor =
           extractElementWiseScatterIndices(srcOp, rewriter);
 
+      // StableHLO may omit the indexed operand dimension from a scalar-index
+      // update. TTIR requires input, indices, and update to have equal rank.
+      int64_t rankDifference = inputType.getRank() - updateType.getRank();
+      if (rankDifference > 0) {
+        auto insertedWindowDims =
+            adaptor.getScatterDimensionNumbers().getInsertedWindowDims();
+        if (rankDifference !=
+            static_cast<int64_t>(insertedWindowDims.size())) {
+          return rewriter.notifyMatchFailure(
+              srcOp, "cannot align scatter update rank with operand rank");
+        }
+
+        SmallVector<int64_t> promotedShape(updateShape);
+        for (int64_t insertedDim : insertedWindowDims) {
+          promotedShape.insert(promotedShape.begin() + insertedDim, 1);
+        }
+        updateTensor = ttir::utils::createReshapeOp(
+            rewriter, srcOp.getLoc(), updateTensor, promotedShape);
+        finalIndexTensor = ttir::utils::createReshapeOp(
+            rewriter, srcOp.getLoc(), finalIndexTensor, promotedShape);
+      }
+
       // Create ScatterOp.
       rewriter.replaceOpWithNewOp<ttir::ScatterOp>(
           srcOp, outputType, inputTensor, finalIndexTensor, updateTensor,
           rewriter.getI32IntegerAttr(dim),
           ttcore::ReduceTypeAttr::get(rewriter.getContext(),
                                       *scatterReduceType));
       return success();
     }
@@ -6942,10 +6964,11 @@ private:
               "support for rank promotion if needed.");
     }
 
-    if (!multiDimensionalScatter && indexVectorDim != 1u) {
+    if (!multiDimensionalScatter && indexVectorDim < indexShape.size() &&
+        indexShape[indexVectorDim] != 1) {
       return rewriter.notifyMatchFailure(
-          op,
-          "TTIR single dimensional scatter requires index_vector_dim to be 1");
+          op, "TTIR single-dimensional scatter requires an index vector with "
+              "one element");
     }
 
     return success();

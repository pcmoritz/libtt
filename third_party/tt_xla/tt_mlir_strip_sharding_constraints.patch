+void stripShardingMarkers(Operation *op) {
+  llvm::SmallVector<mlir::sdy::ShardingConstraintOp> constraints;
+  op->walk([&](mlir::sdy::ShardingConstraintOp constraint) {
+    constraints.push_back(constraint);
+  });
+
+  for (mlir::sdy::ShardingConstraintOp constraint : constraints) {
+    constraint.replaceAllUsesWith(constraint.getInput());
+    constraint.erase();
+  }
+
+  llvm::SmallVector<mlir::stablehlo::CustomCallOp> customCalls;
+  op->walk([&](mlir::stablehlo::CustomCallOp customCall) {
+    if (customCall.getCallTargetName() == "Sharding" &&
+        customCall->getNumOperands() == 1 && customCall->getNumResults() == 1) {
+      customCalls.push_back(customCall);
+    }
+  });
+
+  for (mlir::stablehlo::CustomCallOp customCall : customCalls) {
+    customCall.getResult(0).replaceAllUsesWith(customCall.getOperand(0));
+    customCall.erase();
+  }
+}

+ArrayAttr getI32ShapeAttr(OpBuilder &builder, ArrayRef<int64_t> shape) {
+  SmallVector<int32_t> i32Shape;
+  i32Shape.reserve(shape.size());
+  for (int64_t dim : shape) {
+    i32Shape.push_back(static_cast<int32_t>(dim));
+  }
+  return builder.getI32ArrayAttr(i32Shape);
+}
+
+Value reshapeTo(PatternRewriter &rewriter, Location loc, Value value,
+                RankedTensorType type) {
+  auto valueType = mlir::cast<RankedTensorType>(value.getType());
+  if (valueType == type) {
+    return value;
+  }
+  return rewriter.create<ReshapeOp>(loc, type, value,
+                                    getI32ShapeAttr(rewriter, type.getShape()));
+}
+
+// Qwen decode lowers RoPE over rank-3 [tokens, heads, dim] tensors and then
+// immediately reshapes the result to rank 4 for attention. The TTNN
+// rotary_embedding op requires rank 4, so fuse through that reshape.
+ReshapeOp getRank4DecodeReshapeUser(ConcatOp concatOp) {
+  auto inputType = mlir::cast<RankedTensorType>(concatOp.getType());
+  if (inputType.getRank() != 3 || inputType.getShape()[0] != 1 ||
+      !concatOp->hasOneUse()) {
+    return nullptr;
+  }
+
+  auto reshapeOp = dyn_cast<ReshapeOp>(*concatOp->getUsers().begin());
+  if (!reshapeOp) {
+    return nullptr;
+  }
+
+  auto outputType = mlir::cast<RankedTensorType>(reshapeOp.getType());
+  if (outputType.getRank() != 4 || !inputType.hasStaticShape() ||
+      !outputType.hasStaticShape() ||
+      inputType.getNumElements() != outputType.getNumElements() ||
+      inputType.getShape().back() != outputType.getShape().back()) {
+    return nullptr;
+  }
+
+  return reshapeOp;
+}
+
+RankedTensorType getCacheTypeFor(RankedTensorType cacheType,
+                                 RankedTensorType inputType) {
+  SmallVector<int64_t> shape(inputType.getRank(), 1);
+  shape.back() = cacheType.getShape().back();
+  return RankedTensorType::get(shape, cacheType.getElementType());
+}

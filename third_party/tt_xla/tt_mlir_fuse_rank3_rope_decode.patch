+Value reshapeTo(PatternRewriter &rewriter, Location loc, Value value, RankedTensorType type) {
+  if (mlir::cast<RankedTensorType>(value.getType()) == type) return value;
+  SmallVector<int32_t> shape(type.getShape().begin(), type.getShape().end());
+  return rewriter.create<ReshapeOp>(loc, type, value, rewriter.getI32ArrayAttr(shape));
+}
+
+ReshapeOp getRank4DecodeReshapeUser(ConcatOp concatOp) {
+  auto inputType = mlir::cast<RankedTensorType>(concatOp.getType());
+  if (inputType.getRank() != 3 || inputType.getShape()[0] != 1 || !concatOp->hasOneUse()) return nullptr;
+
+  auto reshapeOp = dyn_cast<ReshapeOp>(*concatOp->getUsers().begin());
+  if (!reshapeOp) return nullptr;
+
+  auto outputType = mlir::cast<RankedTensorType>(reshapeOp.getType());
+  if (outputType.getRank() != 4 || !inputType.hasStaticShape() ||
+      !outputType.hasStaticShape() ||
+      inputType.getNumElements() != outputType.getNumElements() ||
+      inputType.getShape().back() != outputType.getShape().back()) return nullptr;
+
+  return reshapeOp;
+}
+
+RankedTensorType getCacheTypeFor(RankedTensorType cacheType, RankedTensorType inputType) {
+  SmallVector<int64_t> shape(inputType.getRank(), 1);
+  shape.back() = cacheType.getShape().back();
+  return RankedTensorType::get(shape, cacheType.getElementType());
+}

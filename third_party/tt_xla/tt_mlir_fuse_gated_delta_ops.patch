+constexpr int64_t kGatedDeltaChunkSize = 128;
+constexpr int64_t kMaxSearchsortedIterations = 16;
+
+std::optional<int64_t> getScalarInt(Value value) {
+  auto constant = value.getDefiningOp<::mlir::stablehlo::ConstantOp>();
+  if (!constant) {
+    return std::nullopt;
+  }
+  auto elements = dyn_cast<DenseIntElementsAttr>(constant.getValue());
+  if (!elements || elements.getNumElements() != 1) {
+    return std::nullopt;
+  }
+  return (*elements.value_begin<llvm::APInt>()).getSExtValue();
+}
+
+LogicalResult unrollSearchsorted(::mlir::stablehlo::WhileOp loop) {
+  if (loop.getNumOperands() != 3) {
+    return failure();
+  }
+  auto counterType = dyn_cast<RankedTensorType>(loop.getOperand()[0].getType());
+  auto rangeType = dyn_cast<RankedTensorType>(loop.getOperand()[1].getType());
+  if (!counterType || !rangeType || counterType.getRank() != 0 ||
+      rangeType.getRank() != 1 || !counterType.getElementType().isInteger(32) ||
+      rangeType.getElementType() != counterType.getElementType() ||
+      loop.getOperand()[2].getType() != rangeType) {
+    return failure();
+  }
+
+  Block &condition = loop.getCond().front();
+  auto conditionReturn =
+      dyn_cast<::mlir::stablehlo::ReturnOp>(condition.getTerminator());
+  auto compare = conditionReturn && conditionReturn.getNumOperands() == 1
+                     ? conditionReturn.getOperand(0)
+                           .getDefiningOp<::mlir::stablehlo::CompareOp>()
+                     : nullptr;
+  auto counter = compare ? dyn_cast<BlockArgument>(compare.getLhs())
+                         : BlockArgument();
+  std::optional<int64_t> initial = getScalarInt(loop.getOperand()[0]);
+  std::optional<int64_t> bound = compare ? getScalarInt(compare.getRhs())
+                                         : std::nullopt;
+  if (!counter || counter.getOwner() != &condition ||
+      counter.getArgNumber() != 0 ||
+      compare.getComparisonDirection() !=
+          ::mlir::stablehlo::ComparisonDirection::LT ||
+      !initial || !bound || *initial > *bound) {
+    return failure();
+  }
+
+  Block &body = loop.getBody().front();
+  auto bodyReturn =
+      dyn_cast<::mlir::stablehlo::ReturnOp>(body.getTerminator());
+  auto increment = bodyReturn
+                       ? bodyReturn.getOperand(0)
+                             .getDefiningOp<::mlir::stablehlo::AddOp>()
+                       : nullptr;
+  std::optional<int64_t> step =
+      increment && increment.getLhs() == body.getArgument(0)
+          ? getScalarInt(increment.getRhs())
+          : std::nullopt;
+  int64_t iterations = *bound - *initial;
+  if (!bodyReturn || step != 1 || iterations == 0 ||
+      iterations > kMaxSearchsortedIterations) {
+    return failure();
+  }
+
+  OpBuilder builder(loop);
+  SmallVector<Value> carried(loop.getOperands());
+  for (int64_t iteration = 0; iteration < iterations; ++iteration) {
+    IRMapping mapping;
+    for (auto [argument, value] : llvm::zip(body.getArguments(), carried)) {
+      mapping.map(argument, value);
+    }
+    for (Operation &operation : body.without_terminator()) {
+      builder.clone(operation, mapping);
+    }
+    for (auto [result, value] : llvm::zip(carried, bodyReturn.getOperands())) {
+      result = mapping.lookupOrDefault(value);
+    }
+  }
+  loop.replaceAllUsesWith(carried);
+  loop.erase();
+  return success();
+}
+
+struct UnrollSearchsortedPass
+    : public PassWrapper<UnrollSearchsortedPass,
+                         OperationPass<ModuleOp>> {
+  MLIR_DEFINE_EXPLICIT_INTERNAL_INLINE_TYPE_ID(UnrollSearchsortedPass)
+
+  StringRef getArgument() const final {
+    return "stablehlo-unroll-searchsorted";
+  }
+  StringRef getDescription() const final {
+    return "Unroll small statically bounded JAX searchsorted loops";
+  }
+
+  void runOnOperation() final {
+    SmallVector<::mlir::stablehlo::WhileOp> loops;
+    getOperation().walk<WalkOrder::PostOrder>(
+        [&](::mlir::stablehlo::WhileOp loop) { loops.push_back(loop); });
+    for (::mlir::stablehlo::WhileOp loop : loops) {
+      (void)unrollSearchsorted(loop);
+    }
+  }
+};
+
+bool hasShape(Value value, ArrayRef<int64_t> shape) {
+  auto type = dyn_cast<RankedTensorType>(value.getType());
+  return type && type.hasStaticShape() && type.getShape() == shape;
+}
+
+struct QwenGatedDeltaMatch {
+  int64_t sequenceLength;
+  Value query;
+  Value key;
+  Value value;
+  Value betaLogits;
+  Value gateLogits;
+  Value validMask;
+  Value requestIndices;
+  Value decay;
+  Value dtBias;
+};
+
+struct QwenGatedDeltaDecodeMatch {
+  Value query;
+  Value key;
+  Value value;
+  Value beta;
+  Value decay;
+  Value statePool;
+  Value stateIndices;
+  Value hasInitialState;
+  Value finalStatePool;
+};
+
+Value stripBroadcasts(Value value) {
+  // JAX expands each recurrence broadcast through two rank-increasing ops.
+  // Follow that exact, narrow chain and stop before the source computation.
+  for (int i = 0; i < 2; ++i) {
+    Operation *definition = value.getDefiningOp();
+    if (!definition || definition->getNumOperands() != 1) {
+      break;
+    }
+    value = definition->getOperand(0);
+  }
+  return value;
+}
+
+std::optional<std::pair<Value, Value>>
+matchDecodeStateMid(Value value, ArrayRef<int64_t> stateShape,
+                    ArrayRef<int64_t> scalarShape) {
+  auto multiply = value.getDefiningOp<::mlir::stablehlo::MulOp>();
+  if (!multiply) {
+    return std::nullopt;
+  }
+  for (auto [state, decayValue] :
+       {std::pair{multiply.getLhs(), multiply.getRhs()},
+        std::pair{multiply.getRhs(), multiply.getLhs()}}) {
+    Value decay = stripBroadcasts(decayValue);
+    if (hasShape(state, stateShape) && hasShape(decay, scalarShape)) {
+      return std::pair{state, decay};
+    }
+  }
+  return std::nullopt;
+}
+
+std::optional<std::pair<Value, Value>>
+matchDecodeScaledDelta(Value value, Value stateMid, Value key,
+                       ArrayRef<int64_t> vectorShape,
+                       ArrayRef<int64_t> scalarShape) {
+  auto multiply = value.getDefiningOp<::mlir::stablehlo::MulOp>();
+  if (!multiply) {
+    return std::nullopt;
+  }
+  for (auto [deltaValue, betaValue] :
+       {std::pair{multiply.getLhs(), multiply.getRhs()},
+        std::pair{multiply.getRhs(), multiply.getLhs()}}) {
+    auto subtract =
+        deltaValue.getDefiningOp<::mlir::stablehlo::SubtractOp>();
+    Value beta = stripBroadcasts(betaValue);
+    if (!subtract || !hasShape(beta, scalarShape) ||
+        !hasShape(subtract.getLhs(), vectorShape)) {
+      continue;
+    }
+    auto stateRead =
+        subtract.getRhs().getDefiningOp<::mlir::stablehlo::DotGeneralOp>();
+    if (stateRead && stateRead.getLhs() == stateMid &&
+        stateRead.getRhs() == key) {
+      return std::pair{subtract.getLhs(), beta};
+    }
+  }
+  return std::nullopt;
+}
+
+struct DecodeStatePoolMatch {
+  Value statePool;
+  Value stateIndices;
+  Value hasInitialState;
+  Value finalStatePool;
+};
+
+std::optional<DecodeStatePoolMatch>
+matchDecodeStatePool(Value initialState, Value finalState, int64_t batch,
+                     int64_t numHeads) {
+  auto initialSelect = initialState.getDefiningOp<::mlir::stablehlo::SelectOp>();
+  if (!initialSelect) {
+    return std::nullopt;
+  }
+  auto gather = initialSelect.getOnTrue()
+                    .getDefiningOp<::mlir::stablehlo::GatherOp>();
+  if (!gather) {
+    gather = initialSelect.getOnFalse()
+                 .getDefiningOp<::mlir::stablehlo::GatherOp>();
+  }
+  if (!gather) {
+    return std::nullopt;
+  }
+
+  Value statePool = gather.getOperand();
+  Value stateIndices = stripBroadcasts(gather.getStartIndices());
+  Value hasInitialState = stripBroadcasts(initialSelect.getPred());
+  auto poolType = dyn_cast<RankedTensorType>(statePool.getType());
+  if (!poolType || !poolType.hasStaticShape() || poolType.getRank() != 4 ||
+      poolType.getDimSize(0) < 2 || poolType.getDimSize(1) != numHeads ||
+      !hasShape(stateIndices, {batch}) ||
+      !hasShape(hasInitialState, {batch})) {
+    return std::nullopt;
+  }
+
+  for (Operation *user : finalState.getUsers()) {
+    auto select = dyn_cast<::mlir::stablehlo::SelectOp>(user);
+    if (!select || (select.getOnTrue() != finalState &&
+                    select.getOnFalse() != finalState)) {
+      continue;
+    }
+    for (Operation *selectUser : select.getResult().getUsers()) {
+      auto scatter = dyn_cast<::mlir::stablehlo::ScatterOp>(selectUser);
+      if (scatter && scatter.getInputs().size() == 1 &&
+          scatter.getUpdates().size() == 1 &&
+          scatter.getInputs()[0] == statePool &&
+          scatter.getUpdates()[0] == select.getResult()) {
+        return DecodeStatePoolMatch{statePool, stateIndices,
+                                    hasInitialState, scatter.getResult(0)};
+      }
+    }
+  }
+  return std::nullopt;
+}
+
+std::optional<QwenGatedDeltaDecodeMatch>
+matchQwenGatedDeltaDecode(::mlir::stablehlo::DotGeneralOp outputDot) {
+  auto outputType = dyn_cast<RankedTensorType>(outputDot.getType());
+  auto stateType = dyn_cast<RankedTensorType>(outputDot.getLhs().getType());
+  if (!outputType || !stateType || !outputType.hasStaticShape() ||
+      !stateType.hasStaticShape() || outputType.getRank() != 3 ||
+      stateType.getRank() != 4) {
+    return std::nullopt;
+  }
+
+  int64_t batch = outputType.getDimSize(0);
+  int64_t numHeads = outputType.getDimSize(1);
+  SmallVector<int64_t> vectorShape = {batch, numHeads, kGatedDeltaChunkSize};
+  SmallVector<int64_t> scalarShape = {batch, numHeads};
+  SmallVector<int64_t> stateShape = {
+      batch, numHeads, kGatedDeltaChunkSize, kGatedDeltaChunkSize};
+  if (batch <= 0 || numHeads <= 0 ||
+      outputType.getShape() != ArrayRef<int64_t>(vectorShape) ||
+      stateType.getShape() != ArrayRef<int64_t>(stateShape) ||
+      !hasShape(outputDot.getRhs(), vectorShape)) {
+    return std::nullopt;
+  }
+  Value finalState = outputDot.getLhs();
+  auto add = finalState.getDefiningOp<::mlir::stablehlo::AddOp>();
+  if (!add) {
+    return std::nullopt;
+  }
+
+  for (auto [stateMid, outerValue] :
+       {std::pair{add.getLhs(), add.getRhs()},
+        std::pair{add.getRhs(), add.getLhs()}}) {
+    auto stateMatch = matchDecodeStateMid(stateMid, stateShape, scalarShape);
+    auto outer = outerValue.getDefiningOp<::mlir::stablehlo::MulOp>();
+    if (!stateMatch || !outer) {
+      continue;
+    }
+
+    for (auto [keyValue, scaledDeltaValue] :
+         {std::pair{outer.getLhs(), outer.getRhs()},
+          std::pair{outer.getRhs(), outer.getLhs()}}) {
+      Value key = stripBroadcasts(keyValue);
+      Value scaledDelta = stripBroadcasts(scaledDeltaValue);
+      if (!hasShape(key, vectorShape) ||
+          !hasShape(scaledDelta, vectorShape)) {
+        continue;
+      }
+      auto deltaMatch = matchDecodeScaledDelta(
+          scaledDelta, stateMid, key, vectorShape, scalarShape);
+      if (deltaMatch) {
+        auto poolMatch = matchDecodeStatePool(
+            stateMatch->first, finalState, batch, numHeads);
+        if (!poolMatch) {
+          continue;
+        }
+        return QwenGatedDeltaDecodeMatch{
+            outputDot.getRhs(), key, deltaMatch->first, deltaMatch->second,
+            stateMatch->second, poolMatch->statePool,
+            poolMatch->stateIndices, poolMatch->hasInitialState,
+            poolMatch->finalStatePool};
+      }
+    }
+  }
+  return std::nullopt;
+}
+
+LogicalResult
+fuseQwenGatedDeltaDecode(::mlir::stablehlo::DotGeneralOp outputDot) {
+  auto match = matchQwenGatedDeltaDecode(outputDot);
+  if (!match) {
+    return failure();
+  }
+  if (!outputDot->hasOneUse()) {
+    return failure();
+  }
+  auto outputBarrier = dyn_cast<::mlir::stablehlo::OptimizationBarrierOp>(
+      *outputDot->user_begin());
+  if (!outputBarrier) {
+    return failure();
+  }
+  std::optional<unsigned> stateResultIndex;
+  std::optional<unsigned> outputResultIndex;
+  for (auto [index, operand] : llvm::enumerate(outputBarrier.getOperands())) {
+    if (operand == match->finalStatePool) {
+      stateResultIndex = index;
+    } else if (operand == outputDot.getResult()) {
+      outputResultIndex = index;
+    }
+  }
+  if (!stateResultIndex || !outputResultIndex ||
+      !outputBarrier->getResult(*outputResultIndex).hasOneUse()) {
+    return failure();
+  }
+  auto outputConvert = dyn_cast<::mlir::stablehlo::ConvertOp>(
+      *outputBarrier->getResult(*outputResultIndex).user_begin());
+  if (!outputConvert ||
+      !cast<RankedTensorType>(outputConvert.getType())
+           .getElementType()
+           .isBF16()) {
+    return failure();
+  }
+
+  OpBuilder builder(outputDot);
+  SmallVector<Type> resultTypes = {
+      outputBarrier->getResult(*stateResultIndex).getType(),
+      outputBarrier->getResult(*outputResultIndex).getType()};
+  SmallVector<Value> operands = {
+      match->query, match->key, match->value, match->beta, match->decay,
+      match->statePool, match->stateIndices, match->hasInitialState};
+  auto fused = builder.create<GatedDeltaDecodeOp>(
+      outputDot.getLoc(), resultTypes, operands);
+  outputBarrier->setOperand(*stateResultIndex, fused.getFinalStatePool());
+  outputBarrier->setOperand(*outputResultIndex, fused.getOutput());
+
+  return success();
+}
+
+bool isDefinedOutside(Operation *ancestor, Value value) {
+  if (auto argument = dyn_cast<BlockArgument>(value)) {
+    return !ancestor->isAncestor(argument.getOwner()->getParentOp());
+  }
+  Operation *definition = value.getDefiningOp();
+  return definition && !ancestor->isAncestor(definition);
+}
+
+std::optional<QwenGatedDeltaMatch>
+matchQwenGatedDeltaLoop(::mlir::stablehlo::WhileOp loop) {
+  if (loop.getNumOperands() != 3 || !loop.getCond().hasOneBlock() ||
+      !loop.getBody().hasOneBlock() || !hasShape(loop->getOperand(0), {})) {
+    return std::nullopt;
+  }
+
+  auto stateType = dyn_cast<RankedTensorType>(loop->getOperand(1).getType());
+  auto outputType = dyn_cast<RankedTensorType>(loop->getOperand(2).getType());
+  if (!stateType || !outputType || !stateType.hasStaticShape() ||
+      !outputType.hasStaticShape() || stateType.getRank() != 4 ||
+      outputType.getRank() != 3) {
+    return std::nullopt;
+  }
+  int64_t sequenceLength = outputType.getDimSize(0);
+  int64_t numHeads = outputType.getDimSize(1);
+  int64_t batchSize = stateType.getDimSize(0);
+  if (sequenceLength <= 0 || sequenceLength > kGatedDeltaChunkSize ||
+      batchSize <= 0 || numHeads <= 0 ||
+      outputType.getDimSize(2) != kGatedDeltaChunkSize ||
+      stateType.getShape() !=
+          ArrayRef<int64_t>({batchSize, numHeads, kGatedDeltaChunkSize,
+                             kGatedDeltaChunkSize})) {
+    return std::nullopt;
+  }
+
+  SmallVector<Value> qkv;
+  SmallVector<Value> gateInputs;
+  Value validMask;
+  Value requestIndices;
+  loop.getBody().walk([&](::mlir::stablehlo::DynamicSliceOp slice) {
+    Value input = slice->getOperand(0);
+    if (hasShape(input,
+                 {sequenceLength, numHeads, kGatedDeltaChunkSize})) {
+      qkv.push_back(input);
+    } else if (hasShape(input, {sequenceLength, numHeads})) {
+      gateInputs.push_back(input);
+    } else if (hasShape(input, {sequenceLength}) &&
+               cast<RankedTensorType>(input.getType())
+                   .getElementType()
+                   .isInteger(1)) {
+      validMask = input;
+    } else if (hasShape(input, {sequenceLength}) &&
+               cast<RankedTensorType>(input.getType())
+                   .getElementType()
+                   .isInteger(32)) {
+      requestIndices = input;
+    }
+  });
+  if (qkv.size() != 3 || gateInputs.size() != 2 || !validMask ||
+      !requestIndices) {
+    return std::nullopt;
+  }
+
+  SmallVector<Value> headVectors;
+  loop.getBody().walk([&](Operation *op) {
+    for (Value operand : op->getOperands()) {
+      auto type = dyn_cast<RankedTensorType>(operand.getType());
+      if (type && type.hasStaticShape() &&
+          type.getShape() == ArrayRef<int64_t>({numHeads}) &&
+          type.getElementType().isF32() && isDefinedOutside(loop, operand) &&
+          !llvm::is_contained(headVectors, operand)) {
+        headVectors.push_back(operand);
+      }
+    }
+  });
+  if (headVectors.size() != 2) {
+    return std::nullopt;
+  }
+
+  Value decay;
+  for (Value candidate : headVectors) {
+    if (llvm::any_of(candidate.getUsers(), [&](Operation *user) {
+          return loop->isAncestor(user) &&
+                 isa<::mlir::stablehlo::NegOp>(user);
+        })) {
+      decay = candidate;
+      break;
+    }
+  }
+  if (!decay) {
+    return std::nullopt;
+  }
+  Value dtBias = headVectors[headVectors[0] == decay ? 1 : 0];
+
+  unsigned dotCount = 0;
+  unsigned exponentialCount = 0;
+  loop.getBody().walk([&](Operation *op) {
+    StringRef name = op->getName().getStringRef();
+    dotCount += name == "stablehlo.dot_general";
+    exponentialCount += name == "stablehlo.exponential";
+  });
+  if (dotCount < 2 || exponentialCount < 1) {
+    return std::nullopt;
+  }
+
+  return QwenGatedDeltaMatch{sequenceLength, qkv[0], qkv[1], qkv[2],
+                             gateInputs[0], gateInputs[1], validMask,
+                             requestIndices, decay, dtBias};
+}
+
+Value createMaskConstant(OpBuilder &builder, Location loc, int64_t size,
+                         function_ref<float(int64_t, int64_t)> getValue) {
+  SmallVector<float> values;
+  values.reserve(size * size);
+  for (int64_t row = 0; row < size; ++row) {
+    for (int64_t column = 0; column < size; ++column) {
+      values.push_back(getValue(row, column));
+    }
+  }
+  auto type = RankedTensorType::get({1, size, size}, builder.getF32Type());
+  auto value = DenseElementsAttr::get(type, ArrayRef<float>(values));
+  return builder.create<::mlir::stablehlo::ConstantOp>(loc, value);
+}
+
+LogicalResult fuseQwenGatedDeltaLoop(::mlir::stablehlo::WhileOp loop) {
+  std::optional<QwenGatedDeltaMatch> match = matchQwenGatedDeltaLoop(loop);
+  if (!match) {
+    return failure();
+  }
+
+  OpBuilder builder(loop);
+  Location loc = loop.getLoc();
+  Value upperTriangular = createMaskConstant(
+      builder, loc, kGatedDeltaChunkSize,
+      [](int64_t row, int64_t column) { return column >= row ? 1.0f : 0.0f; });
+  Value lowerTriangular = createMaskConstant(
+      builder, loc, kGatedDeltaChunkSize,
+      [](int64_t row, int64_t column) { return column <= row ? 1.0f : 0.0f; });
+  Value identity = createMaskConstant(
+      builder, loc, kGatedDeltaChunkSize,
+      [](int64_t row, int64_t column) { return column == row ? 1.0f : 0.0f; });
+  Value identity32 = createMaskConstant(
+      builder, loc, 32,
+      [](int64_t row, int64_t column) { return column == row ? 1.0f : 0.0f; });
+
+  SmallVector<Value> operands = {
+      match->query,          match->key,
+      match->value,          match->betaLogits,
+      match->gateLogits,     match->validMask,
+      match->requestIndices, match->decay,
+      match->dtBias,
+      loop->getOperand(1),   upperTriangular,
+      lowerTriangular,       identity,
+      identity32};
+  SmallVector<Type> resultTypes = {loop.getResult(1).getType(),
+                                   loop.getResult(2).getType()};
+  auto fused = builder.create<GatedDeltaRuleOp>(loc, resultTypes, operands);
+
+  auto inductionType = cast<RankedTensorType>(loop->getOperand(0).getType());
+  auto finalInductionAttr = DenseElementsAttr::get(
+      inductionType,
+      builder.getIntegerAttr(inductionType.getElementType(),
+                             match->sequenceLength));
+  Value finalInduction = builder.create<::mlir::stablehlo::ConstantOp>(
+      loc, finalInductionAttr);
+  loop.getResult(0).replaceAllUsesWith(finalInduction);
+  loop.getResult(1).replaceAllUsesWith(fused.getResult(0));
+  loop.getResult(2).replaceAllUsesWith(fused.getResult(1));
+  loop.erase();
+  return success();
+}
+
+struct FuseQwenGatedDeltaLoopPass
+    : public PassWrapper<FuseQwenGatedDeltaLoopPass,
+                         OperationPass<ModuleOp>> {
+  MLIR_DEFINE_EXPLICIT_INTERNAL_INLINE_TYPE_ID(FuseQwenGatedDeltaLoopPass)
+
+  StringRef getArgument() const final { return "stablehlo-fuse-qwen-gdn"; }
+  StringRef getDescription() const final {
+    return "Fuse the Qwen Gated DeltaNet recurrence before loop lowering";
+  }
+
+  void runOnOperation() final {
+    SmallVector<::mlir::stablehlo::WhileOp> loops;
+    getOperation().walk<WalkOrder::PostOrder>(
+        [&](::mlir::stablehlo::WhileOp loop) { loops.push_back(loop); });
+    bool fusedGatedDelta = false;
+    for (::mlir::stablehlo::WhileOp loop : loops) {
+      if (succeeded(fuseQwenGatedDeltaLoop(loop))) {
+        fusedGatedDelta = true;
+      }
+    }
+
+    SmallVector<::mlir::stablehlo::DotGeneralOp> dots;
+    getOperation().walk<WalkOrder::PostOrder>(
+        [&](::mlir::stablehlo::DotGeneralOp dot) { dots.push_back(dot); });
+    for (::mlir::stablehlo::DotGeneralOp dot : dots) {
+      if (succeeded(fuseQwenGatedDeltaDecode(dot))) {
+        fusedGatedDelta = true;
+      }
+    }
+    if (!fusedGatedDelta) {
+      return;
+    }
+
+    IRRewriter rewriter(&getContext());
+    (void)runRegionDCE(rewriter, getOperation()->getRegions());
+  }
+};

+// Fuse a single-use SiLU producer into BinaryNg's per-input activation. This
+// turns the SwiGLU activation from two device programs into one while keeping
+// the existing sliced gate/up tensors and output layout unchanged.
+class TTNNMultiplyWithSilu : public mlir::OpRewritePattern<MultiplyOp> {
+public:
+  using mlir::OpRewritePattern<MultiplyOp>::OpRewritePattern;
+
+  mlir::LogicalResult
+  matchAndRewrite(MultiplyOp multiplyOp,
+                  mlir::PatternRewriter &rewriter) const final {
+    SiluOp lhsSilu = multiplyOp.getLhs().getDefiningOp<SiluOp>();
+    SiluOp rhsSilu = multiplyOp.getRhs().getDefiningOp<SiluOp>();
+    if ((!lhsSilu && !rhsSilu) || (lhsSilu && rhsSilu)) {
+      return failure();
+    }
+
+    SiluOp siluOp = lhsSilu ? lhsSilu : rhsSilu;
+    if (!siluOp.getResult().hasOneUse()) {
+      return failure();
+    }
+
+    rewriter.modifyOpInPlace(multiplyOp, [&]() {
+      if (lhsSilu) {
+        multiplyOp.getLhsMutable().assign(siluOp.getInput());
+        multiplyOp->setAttr("ttnn.fused_silu_lhs", rewriter.getUnitAttr());
+      } else {
+        multiplyOp.getRhsMutable().assign(siluOp.getInput());
+        multiplyOp->setAttr("ttnn.fused_silu_rhs", rewriter.getUnitAttr());
+      }
+    });
+    rewriter.eraseOp(siluOp);
+    return success();
+  }
+};

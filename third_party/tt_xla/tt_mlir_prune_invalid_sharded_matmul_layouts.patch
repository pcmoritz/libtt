+static bool isSupportedShardedOutputLayout(TTNNLayoutAttr layout) {
+  if (!isShardedLayout(layout)) return true;
+  auto memLayout = layout.getMemLayout().getValue();
+  if (memLayout == TensorMemoryLayout::WidthSharded) return false;
+  if (memLayout == TensorMemoryLayout::BlockSharded) { auto gridShape = layout.getGridShape(); return gridShape.size() < 2 || gridShape[0] == 1; }
+  return true;
+}

+bool MatmulRuleBook::isValidOutputHintForInputs(const OpConfig &hint, llvm::ArrayRef<TTNNLayoutAttr> inputLayouts) const {
+  if (hint.outputLayout && !isSupportedShardedOutputLayout(hint.outputLayout)) return false;

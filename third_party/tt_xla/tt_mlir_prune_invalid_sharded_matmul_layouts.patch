 static bool isSharded(const OpConfig &config) {
   if (!config.outputLayout) {
     return false;
@@ -39,7 +70,41 @@ static bool isSharded(const OpConfig &config) {
   auto memLayout = config.outputLayout.getMemLayout();
   return memLayout && isShardedMemoryLayout(memLayout.getValue());
 }
 
+bool MatmulRuleBook::isValidInputCombination(
+    llvm::ArrayRef<TTNNLayoutAttr> inputLayouts) const {
+  if (inputLayouts.empty() || !isShardedLayout(inputLayouts[0])) {
+    return true;
+  }
+
+  return inputLayouts[0].getMemLayout().getValue() ==
+         TensorMemoryLayout::HeightSharded;
+}
+
+bool MatmulRuleBook::isValidOutputHintForInputs(
+    const OpConfig &hint, llvm::ArrayRef<TTNNLayoutAttr> inputLayouts) const {
+  if (hint.outputLayout && !isSupportedShardedOutputLayout(hint.outputLayout)) {
+    return false;
+  }
+
+  if (inputLayouts.empty() || !hasAnyShardedLayout(inputLayouts)) {
+    return true;
+  }
+
+  if (!hint.outputLayout || !isShardedLayout(hint.outputLayout)) {
+    return false;
+  }
+
+  if (!isShardedLayout(inputLayouts[0])) {
+    return true;
+  }
+
+  return hint.outputLayout.getBufferType() ==
+             inputLayouts[0].getBufferType() &&
+         hint.outputLayout.getMemLayout().getValue() ==
+             inputLayouts[0].getMemLayout().getValue();
+}
